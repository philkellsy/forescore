NODE_ENV=development
PORT=2080

# Postgres connection (local: run `createdb forescore_dev` first)
DATABASE_URL=postgresql://localhost:5432/forescore_dev

# Used for integration tests (run `createdb forescore_test` first)
TEST_DATABASE_URL=postgresql://localhost:5432/forescore_test

# Strong random string — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-in-production

# Absolute base URL used in emails
APP_BASE_URL=http://localhost:5050

# Brevo transactional email (leave blank to log codes to stdout in dev)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=ForeScore

# Golf course data API (optional — used by course importer)
GOLF_COURSE_API_KEY=
