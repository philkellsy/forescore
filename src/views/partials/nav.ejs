<div id="fsPageOverlay" class="page-loading-overlay" aria-hidden="true">
  <div class="spinner-border page-loading-spinner" role="status">
    <span class="visually-hidden">Loading…</span>
  </div>
</div>
<nav class="navbar navbar-expand-lg navbar-dark legends-nav">
  <div class="container">
    <a class="navbar-brand fw-bold d-inline-flex align-items-center" href="<%= typeof tenantPath === 'function' ? tenantPath('/') : '/' %>">
      <img src="/img/forescore-shield.svg" alt="" aria-hidden="true" class="legends-brand-logo me-2" />
      <span><span style="color:#8AD84A">Fore</span>Score</span>
    </a>
    <% if (user) { %>
      <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#navMenu" aria-controls="navMenu">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="offcanvas offcanvas-end text-bg-dark" tabindex="-1" id="navMenu" aria-labelledby="navMenuLabel">
        <div class="offcanvas-header">
          <h5 class="offcanvas-title d-inline-flex align-items-center" id="navMenuLabel">
            <img src="/img/forescore-shield.svg" alt="" aria-hidden="true" class="legends-brand-logo me-2" />
            <span><span style="color:#8AD84A">Fore</span>Score</span>
          </h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
          <% if (typeof tenant !== 'undefined' && tenant) { %>
            <% const memberRole = (typeof tenantMembership !== 'undefined' && tenantMembership) ? tenantMembership.role : null; %>
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
              <% if (isSuperAdmin) { %>
                <li class="nav-item"><a class="nav-link" href="/"><i class="fa-solid fa-building fa-fw me-1" aria-hidden="true"></i>Tenants</a></li>
              <% } else if (user && (user.tenantCount || 0) > 1) { %>
                <li class="nav-item"><a class="nav-link" href="/select-tenant"><i class="fa-solid fa-right-left fa-fw me-1" aria-hidden="true"></i>Switch Tour</a></li>
              <% } %>
              <li class="nav-item"><a class="nav-link" href="<%= tenantPath('/') %>"><i class="fa-solid fa-house fa-fw me-1" aria-hidden="true"></i>Dashboard</a></li>
              <li class="nav-item"><a class="nav-link" href="<%= tenantPath('/scoring') %>"><i class="fa-solid fa-pen-to-square fa-fw me-1" aria-hidden="true"></i>Scoring</a></li>
              <li class="nav-item"><a class="nav-link" href="<%= tenantPath('/leaderboards') %>"><i class="fa-solid fa-trophy fa-fw me-1" aria-hidden="true"></i>Leaderboards</a></li>
              <li class="nav-item"><a class="nav-link" href="<%= tenantPath('/itinerary') %>"><i class="fa-solid fa-calendar-days fa-fw me-1" aria-hidden="true"></i>Itinerary</a></li>
              <% if (memberRole === 'admin' || memberRole === 'owner' || hasTourAdminAccess) { %>
                <li class="nav-item"><a class="nav-link" href="<%= tenantPath('/admin') %>"><i class="fa-solid fa-gear fa-fw me-1" aria-hidden="true"></i>Admin</a></li>
              <% } %>
              <% if (memberRole === 'admin' || memberRole === 'owner') { %>
                <li class="nav-item"><a class="nav-link" href="<%= tenantPath('/admin/players') %>"><i class="fa-solid fa-users fa-fw me-1" aria-hidden="true"></i>Players</a></li>
              <% } %>
              <li class="nav-item d-none" id="pwaInstallNavItem">
                <button type="button" class="nav-link w-100 text-start" id="pwaInstallBtn" style="background:none;border:none">
                  <i class="fa-solid fa-mobile-screen-button fa-fw me-1" aria-hidden="true"></i>Install App
                </button>
              </li>
            </ul>
          <% } else { %>
            <ul class="navbar-nav me-auto mb-2 mb-lg-0"></ul>
          <% } %>
          <div class="d-flex align-items-center gap-3 mt-3 mt-lg-0">
            <% if (typeof tenant !== 'undefined' && tenant) { %>
              <a href="<%= tenantPath('/profile') %>" class="text-light text-decoration-none small"><%= user.firstName %> <%= user.lastName %></a>
            <% } else { %>
              <small class="text-light"><%= user.firstName %> <%= user.lastName %></small>
            <% } %>
            <% if (typeof tenant !== 'undefined' && tenant) { %>
              <form action="<%= tenantPath('/auth/logout') %>" method="post" class="m-0">
                <button class="btn btn-sm btn-outline-light" type="submit">Logout</button>
              </form>
            <% } %>
          </div>
          <%# Version tag — visible in mobile menu only (footer handles desktop) %>
          <div class="mt-4 d-lg-none">
            <span style="font-size:0.7rem;color:rgba(255,255,255,0.45)">v<%= typeof appVersion !== 'undefined' ? appVersion : '' %></span>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</nav>
<%# iOS install instructions modal — shown by JS when running in mobile Safari (not standalone) %>
<div class="modal fade" id="iosInstallModal" tabindex="-1" aria-labelledby="iosInstallModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header border-0 pb-1">
        <h5 class="modal-title" id="iosInstallModalLabel">
          <i class="fa-solid fa-mobile-screen-button me-2" aria-hidden="true"></i>Install ForeScore
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body pt-2">
        <ol class="mb-0 lh-lg">
          <li>Tap the <strong>Share</strong> button <i class="fa-solid fa-arrow-up-from-bracket" aria-hidden="true"></i> at the bottom of Safari</li>
          <li>Scroll down and tap <strong>Add to Home Screen</strong></li>
          <li>Tap <strong>Add</strong> to confirm</li>
        </ol>
      </div>
    </div>
  </div>
</div>

<%# Version tag — fixed bottom-right on desktop, hidden on mobile (menu handles it) %>
<div class="app-version-tag d-none d-lg-block">v<%= typeof appVersion !== 'undefined' ? appVersion : '' %></div>
<script src="/js/app.js?v=<%= assetVersion %>" defer></script>
