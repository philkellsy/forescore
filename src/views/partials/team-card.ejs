<%
  const safeTeamName = typeof teamName !== 'undefined' && teamName ? String(teamName) : 'Team';
  const safeExactHandicap = typeof exactHandicapText !== 'undefined' && exactHandicapText ? String(exactHandicapText) : '0';
  const safeMembers = Array.isArray(members) ? members : [];
  const safeCanDelete = typeof canDelete !== 'undefined' ? Boolean(canDelete) : false;
  const safeDeleteAction = typeof deleteAction !== 'undefined' ? String(deleteAction) : '';
  const safeSummary = typeof summary !== 'undefined' ? summary : null;
  const safeTourId = typeof tourId !== 'undefined' ? Number(tourId) : (typeof eventId !== 'undefined' ? Number(eventId) : 0);
  const safeDayPublished = typeof dayPublished !== 'undefined' ? Boolean(dayPublished) : false;
  const safeReturnTo = typeof returnTo !== 'undefined' ? String(returnTo) : '';
  const safeClassName = typeof className !== 'undefined' && className ? String(className) : '';
  const safeShowGhostTag = typeof showGhostTag !== 'undefined' ? Boolean(showGhostTag) : false;
  const safeMembersLayout = typeof membersLayout !== 'undefined' && membersLayout ? String(membersLayout) : 'wrap';
  const displayMembers = safeShowGhostTag
    ? [...safeMembers].sort((a, b) => Number(a.is_dual_assigned || 0) - Number(b.is_dual_assigned || 0))
    : safeMembers;
  const membersContainerClass = safeMembersLayout === 'grid-2'
    ? 'd-grid gap-2 mt-2'
    : 'd-flex flex-wrap gap-2 mt-2';
  const membersContainerStyle = safeMembersLayout === 'grid-2'
    ? 'grid-template-columns: repeat(2, minmax(0, 1fr));'
    : '';
  const reviewHref = safeSummary && Number(safeSummary.scorecardId || 0) > 0
    ? `/leaderboards/tour/${safeTourId}/scorecards/team/${Number(safeSummary.scorecardId)}?returnTo=${encodeURIComponent(safeReturnTo)}`
    : null;
%>
<div class="team-card border rounded p-2 <%= safeClassName || 'mb-2' %>">
  <div class="d-flex justify-content-between align-items-start gap-2">
    <strong><%= safeTeamName %> (<%= safeExactHandicap %>)</strong>
    <% if (safeCanDelete && safeDeleteAction) { %>
      <form action="<%= safeDeleteAction %>" method="post" class="m-0">
        <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
      </form>
    <% } %>
  </div>

  <% if (displayMembers.length) { %>
    <div class="<%= membersContainerClass %>" style="<%= membersContainerStyle %>">
      <% displayMembers.forEach((m) => { %>
        <%- include('./participant-card', {
          name: `${m.first_name || ''} ${m.last_name || ''}`.trim(),
          handicapText: m.handicap_display || '',
          isGhost: safeShowGhostTag && Number(m.is_dual_assigned || 0) === 1,
          className: 'border rounded px-2 py-1 bg-light small d-inline-flex align-items-center gap-1'
        }) %>
      <% }) %>
    </div>
  <% } else { %>
    <div class="small text-muted mt-2">No players assigned.</div>
  <% } %>

  <% if (safeSummary) { %>
    <div class="score-summary-chip border rounded p-2 bg-light mt-2">
      <div>
        <div class="small text-muted">Score</div>
        <div class="fw-semibold">Net <%= Number(safeSummary.netExact || 0).toFixed(2).replace(/\.00$/, '') %></div>
      </div>
      <% if (reviewHref) { %>
        <div class="score-summary-actions">
          <a class="btn btn-sm btn-outline-secondary" href="<%= reviewHref %>" title="View scorecard" aria-label="View scorecard">
            <i class="fa-solid fa-eye"></i>
          </a>
          <% if (!safeDayPublished) { %>
            <a class="btn btn-sm btn-outline-dark" href="<%= `${reviewHref}#adjustments` %>" title="Adjust scorecard" aria-label="Adjust scorecard">
              <i class="fa-solid fa-pen"></i>
            </a>
          <% } %>
        </div>
      <% } %>
    </div>
  <% } %>
</div>
