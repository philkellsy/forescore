<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> | ForeScore</title>
  <meta name="theme-color" content="#215463" />
  <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
  <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
</head>
<body>
  <%- include('../partials/nav') %>
  <main class="container py-3 py-md-4" style="max-width:720px">
    <%
      const TYPE_META = {
        accommodation: { label: 'Accommodation', icon: 'fa-bed' },
        transfer:      { label: 'Transfer',       icon: 'fa-van-shuttle' },
        meal:          { label: 'Meal',            icon: 'fa-utensils' },
        activity:      { label: 'Activity',        icon: 'fa-person-hiking' },
        note:          { label: 'Note',            icon: 'fa-circle-info' },
        flight:        { label: 'Flight',          icon: 'fa-plane-departure' },
      };
      const CALC_LABELS = {
        stableford:   'Stableford',
        ambrose_nett: 'Ambrose',
        stroke:       'Stroke Play',
      };
      function fmtDate(d) {
        if (!d) return '';
        return new Date(d).toLocaleDateString('en-AU', { weekday: 'short', day: 'numeric', month: 'short', timeZone: 'UTC' });
      }
      function fmtTime(t) {
        if (!t) return '';
        return String(t).slice(0, 5);
      }

      const allDateKeys = Object.keys(byDate).sort();
    %>

    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1 class="h5 mb-0">Itinerary</h1>
        <p class="text-muted small mb-0"><%= tour.label %></p>
      </div>
      <div class="d-flex gap-2">
        <button type="button" class="btn btn-sm btn-legends" id="addBtn"
          data-bs-toggle="modal" data-bs-target="#itemModal">
          <i class="fa-solid fa-plus me-1"></i>Add Item
        </button>
        <a href="<%= tenantPath(`/admin/tours/${tour.id}`) %>" class="btn btn-sm btn-outline-secondary">
          <i class="fa-solid fa-arrow-left me-1"></i>Back
        </a>
      </div>
    </div>

    <% if (message) { %><div class="alert alert-success"><%= message %></div><% } %>
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

    <% if (!allDateKeys.length) { %>
      <div class="text-center py-5 text-muted">
        <i class="fa-solid fa-calendar-days fa-3x mb-3 opacity-25"></i>
        <p class="mb-0">No rounds or itinerary items yet.</p>
      </div>
    <% } else { %>
      <% allDateKeys.forEach((dateKey) => { %>
        <section class="mb-4">
          <div class="d-flex align-items-center gap-2 mb-2 ps-1">
            <h2 class="h6 text-muted text-uppercase small fw-semibold mb-0"><%= fmtDate(dateKey) %></h2>
            <button type="button" class="btn btn-sm btn-outline-secondary quick-add-btn py-0 px-1 lh-1"
              data-bs-toggle="modal" data-bs-target="#itemModal" data-date="<%= dateKey %>"
              title="Add item for this day" style="font-size:.75rem">
              <i class="fa-solid fa-plus"></i>
            </button>
          </div>
          <div class="card border-0 shadow-sm">

            <% byDate[dateKey].forEach((entry, i) => { %>
              <% if (entry._kind === 'round') { %>
                <div class="card-body <%= i > 0 ? 'border-top' : '' %> py-2 d-flex align-items-start gap-3 bg-light">
                  <div class="text-muted mt-1 flex-shrink-0" style="width:20px;text-align:center">
                    <i class="fa-solid fa-golf-ball-tee fa-fw"></i>
                  </div>
                  <div class="flex-grow-1 min-w-0">
                    <div class="fw-semibold">Round <%= entry.round_number %> &mdash; <%= entry.course_name %> (<%= entry.tee_name %>)</div>
                    <div class="small text-muted">
                      <%= CALC_LABELS[entry.calc_type] || entry.calc_type %>
                      <% if (entry.first_tee_time) { %><span class="ms-2"><%= fmtTime(entry.first_tee_time) %> first tee</span><% } %>
                    </div>
                  </div>
                  <a href="<%= tenantPath(`/admin/tours/${tour.id}/rounds/${entry.round_number}`) %>"
                    class="btn btn-sm btn-outline-secondary flex-shrink-0">Configure</a>
                </div>
              <% } else { %>
              <%
                const item = entry;
                const meta = TYPE_META[item.type] || { label: item.type, icon: 'fa-circle' };
                const det = item.details
                  ? (typeof item.details === 'string' ? JSON.parse(item.details) : item.details)
                  : {};
                const nights = item.type === 'accommodation' && item.end_date
                  ? Math.round((new Date(item.end_date) - new Date(item.item_date)) / 86400000)
                  : null;
              %>
              <div class="card-body <%= i > 0 ? 'border-top' : '' %> py-2 d-flex align-items-start gap-3">
                <div class="text-muted mt-1 flex-shrink-0" style="width:20px;text-align:center">
                  <i class="fa-solid <%= meta.icon %> fa-fw"></i>
                </div>
                <div class="flex-grow-1 min-w-0">
                  <div class="fw-semibold"><%= item.title %></div>

                  <% if (item.type === 'accommodation') { %>
                    <% if (item._display === 'checkout') { %>
                      <div class="small fw-medium">
                        Check-out<% if (item.end_time) { %> <%= fmtTime(item.end_time) %><% } %>
                        <% if (nights) { %><span class="ms-1 badge text-bg-light border fw-normal"><%= nights %> night<%= nights !== 1 ? 's' : '' %></span><% } %>
                      </div>
                      <% if (det.checkout_notes) { %><div class="small text-muted"><%= det.checkout_notes %></div><% } %>
                    <% } else { %>
                      <div class="small fw-medium">
                        Check-in<% if (item.start_time) { %> <%= fmtTime(item.start_time) %><% } %>
                        <% if (nights) { %><span class="ms-1 badge text-bg-light border fw-normal"><%= nights %> night<%= nights !== 1 ? 's' : '' %></span><% } %>
                      </div>
                      <% if (det.checkin_notes) { %><div class="small text-muted"><%= det.checkin_notes %></div><% } %>
                    <% } %>
                  <% } %>

                  <% if (item.type === 'transfer') { %>
                    <% if (det.from || det.to) { %>
                      <div class="small text-muted">
                        <%= det.from || '' %><% if (det.from && det.to) { %> &rarr; <% } %><%= det.to || '' %>
                        <% if (det.vehicle) { %><span class="ms-1">&middot; <%= det.vehicle %></span><% } %>
                      </div>
                    <% } %>
                    <% if (item.start_time) { %><div class="small fw-medium"><%= fmtTime(item.start_time) %></div><% } %>
                    <% if (det.notes) { %><div class="small text-muted"><%= det.notes %></div><% } %>
                  <% } %>

                  <% if ((item.type === 'meal' || item.type === 'activity') && det.venue) { %>
                    <div class="small text-muted"><%= det.venue %></div>
                  <% } %>

                  <% if (item.type !== 'accommodation' && item.type !== 'transfer' && item.start_time) { %>
                    <div class="small fw-medium">
                      <%= fmtTime(item.start_time) %><% if (item.end_time) { %> &ndash; <%= fmtTime(item.end_time) %><% } %>
                    </div>
                  <% } %>

                  <% if (item.location) { %>
                    <div class="small text-muted">
                      <i class="fa-solid fa-location-dot fa-fw me-1 opacity-50"></i><%= item.location %>
                    </div>
                  <% } %>
                  <% if (item.description) { %>
                    <div class="small text-muted mt-1" style="white-space:pre-wrap"><%= item.description %></div>
                  <% } %>
                </div>
                <div class="d-flex gap-1 flex-shrink-0">
                  <button type="button" class="btn btn-sm btn-outline-dark edit-btn"
                    data-bs-toggle="modal" data-bs-target="#itemModal"
                    title="<%= item._display === 'checkout' ? 'Edit accommodation' : 'Edit' %>"
                    data-item='<%- JSON.stringify({
                      id: item.id,
                      type: item.type,
                      item_date: String(item.item_date).slice(0, 10),
                      end_date: item.end_date ? String(item.end_date).slice(0, 10) : '',
                      title: item.title,
                      description: item.description || '',
                      location: item.location || '',
                      start_time: item.start_time ? String(item.start_time).slice(0, 5) : '',
                      end_time: item.end_time ? String(item.end_time).slice(0, 5) : '',
                      details: det,
                    }) %>'>
                    <i class="fa-solid fa-pen fa-fw"></i>
                  </button>
                  <% if (item._display !== 'checkout') { %>
                    <button type="button" class="btn btn-sm btn-outline-danger"
                      data-bs-toggle="modal" data-bs-target="#deleteModal"
                      data-delete-url="<%= tenantPath(`/admin/tours/${tour.id}/itinerary/${item.id}/delete`) %>"
                      data-item-title="<%= item.title %>">
                      <i class="fa-solid fa-trash fa-fw"></i>
                    </button>
                  <% } %>
                </div>
              </div>
              <% } %>
            <% }) %>

          </div>
        </section>
      <% }) %>
    <% } %>
  </main>

  <%# Add / Edit Modal %>
  <div class="modal fade" id="itemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h2 class="modal-title fs-5" id="itemModalTitle">Add Item</h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <form id="itemForm" method="post">
          <div class="modal-body">

            <div class="mb-3">
              <label class="form-label">Type</label>
              <select name="type" id="typeSelect" class="form-select">
                <option value="accommodation">Accommodation</option>
                <option value="transfer">Transfer</option>
                <option value="meal">Meal</option>
                <option value="activity">Activity</option>
                <option value="note">Note</option>
                <option value="flight">Flight</option>
              </select>
            </div>

            <div class="row g-3 mb-3">
              <div class="col">
                <label class="form-label" id="startDateLabel">Date</label>
                <input type="date" name="itemDate" id="itemDate" class="form-control" required />
              </div>
              <div class="col" id="endDateCol" style="display:none">
                <label class="form-label">Check-out Date</label>
                <input type="date" name="endDate" id="endDate" class="form-control" />
              </div>
            </div>

            <div class="mb-3">
              <label class="form-label" id="titleLabel">Title</label>
              <input type="text" name="title" id="itemTitle" class="form-control" required />
            </div>

            <%# Shared — start time %>
            <div id="field-startTime" class="dyn-field mb-3" style="display:none">
              <label class="form-label" id="startTimeLabel">Time</label>
              <input type="time" name="startTime" id="startTime" class="form-control" style="max-width:160px" />
            </div>

            <%# Shared — end time %>
            <div id="field-endTime" class="dyn-field mb-3" style="display:none">
              <label class="form-label" id="endTimeLabel">End Time</label>
              <input type="time" name="endTime" id="endTime" class="form-control" style="max-width:160px" />
            </div>

            <%# Shared — location %>
            <div id="field-location" class="dyn-field mb-3" style="display:none">
              <label class="form-label" id="locationLabel">Location</label>
              <input type="text" name="location" id="location" class="form-control" />
            </div>

            <%# Accommodation notes %>
            <div id="field-checkinNotes" class="dyn-field mb-3" style="display:none">
              <label class="form-label">Check-in Notes</label>
              <input type="text" name="detail_checkin_notes" id="detail_checkin_notes" class="form-control"
                placeholder="e.g. Pick up keys from reception" />
            </div>
            <div id="field-checkoutNotes" class="dyn-field mb-3" style="display:none">
              <label class="form-label">Check-out Notes</label>
              <input type="text" name="detail_checkout_notes" id="detail_checkout_notes" class="form-control"
                placeholder="e.g. Leave bags with concierge" />
            </div>

            <%# Transfer — from / to / vehicle %>
            <div id="field-fromTo" class="dyn-field mb-3" style="display:none">
              <div class="row g-2">
                <div class="col-6">
                  <label class="form-label">From</label>
                  <input type="text" name="detail_from" id="detail_from" class="form-control" placeholder="e.g. Hotel" />
                </div>
                <div class="col-6">
                  <label class="form-label">To</label>
                  <input type="text" name="detail_to" id="detail_to" class="form-control" placeholder="e.g. Golf Club" />
                </div>
              </div>
            </div>
            <div id="field-vehicle" class="dyn-field mb-3" style="display:none">
              <label class="form-label">Vehicle</label>
              <input type="text" name="detail_vehicle" id="detail_vehicle" class="form-control"
                placeholder="e.g. Coach, Minibus" />
            </div>
            <div id="field-transferNotes" class="dyn-field mb-3" style="display:none">
              <label class="form-label">Notes</label>
              <input type="text" name="detail_notes" id="detail_notes" class="form-control"
                placeholder="e.g. Meet in hotel lobby" />
            </div>

            <%# Meal / Activity — venue %>
            <div id="field-venue" class="dyn-field mb-3" style="display:none">
              <label class="form-label">Venue</label>
              <input type="text" name="detail_venue" id="detail_venue" class="form-control" />
            </div>

            <%# Note — description %>
            <div id="field-description" class="dyn-field" style="display:none">
              <label class="form-label">Description</label>
              <textarea name="description" id="description" class="form-control" rows="3"></textarea>
            </div>

            <%# Flight — departure / arrival airports %>
            <div id="field-flightRoutes" class="dyn-field mb-3" style="display:none">
              <div class="row g-2">
                <div class="col-6">
                  <label class="form-label">Departure Airport</label>
                  <input type="text" name="detail_departure_airport" id="detail_departure_airport" class="form-control"
                         placeholder="e.g. SYD" style="text-transform:uppercase" />
                </div>
                <div class="col-6">
                  <label class="form-label">Arrival Airport</label>
                  <input type="text" name="detail_arrival_airport" id="detail_arrival_airport" class="form-control"
                         placeholder="e.g. BNE" style="text-transform:uppercase" />
                </div>
              </div>
            </div>
            <%# Flight — airline / flight number %>
            <div id="field-flightMeta" class="dyn-field mb-3" style="display:none">
              <div class="row g-2">
                <div class="col-6">
                  <label class="form-label">Airline</label>
                  <input type="text" name="detail_airline" id="detail_airline" class="form-control" placeholder="e.g. Qantas" />
                </div>
                <div class="col-6">
                  <label class="form-label">Flight No.</label>
                  <input type="text" name="detail_flight_number" id="detail_flight_number" class="form-control"
                         placeholder="e.g. QF123" />
                </div>
              </div>
            </div>
            <%# Flight — terminal / booking ref %>
            <div id="field-flightRef" class="dyn-field mb-3" style="display:none">
              <div class="row g-2">
                <div class="col-6">
                  <label class="form-label">Terminal</label>
                  <input type="text" name="detail_terminal" id="detail_terminal" class="form-control" placeholder="e.g. T1" />
                </div>
                <div class="col-6">
                  <label class="form-label">Booking Ref</label>
                  <input type="text" name="detail_booking_ref" id="detail_booking_ref" class="form-control"
                         placeholder="e.g. ABC123" />
                </div>
              </div>
            </div>

          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-legends" id="itemSubmitBtn">Add Item</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <%# Delete Confirmation Modal %>
  <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
      <div class="modal-content">
        <div class="modal-header border-0 pb-1">
          <h2 class="modal-title fs-6">Delete item?</h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body pt-0 pb-2">
          <p class="mb-0 small text-muted"><strong id="deleteItemTitle"></strong> will be permanently removed.</p>
        </div>
        <div class="modal-footer border-0 pt-0">
          <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
          <form id="deleteForm" method="post" class="m-0">
            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  <script>
    const BASE_URL = '<%= tenantPath(`/admin/tours/${tour.id}/itinerary`) %>';

    const TYPE_CONFIG = {
      accommodation: { fields: ['endDateCol', 'startTime', 'endTime', 'location', 'checkinNotes', 'checkoutNotes'], startTimeLabel: 'Check-in Time', endTimeLabel: 'Check-out Time', endDateLabel: 'Check-out Date', locationLabel: 'Address' },
      transfer:      { fields: ['startTime', 'fromTo', 'vehicle', 'transferNotes'], startTimeLabel: 'Departure Time', locationLabel: null },
      meal:          { fields: ['startTime', 'location', 'venue'],            startTimeLabel: 'Time',          locationLabel: 'Location' },
      activity:      { fields: ['startTime', 'endTime', 'location', 'venue', 'description'], startTimeLabel: 'Start Time',    endTimeLabel: 'End Time', locationLabel: 'Location' },
      note:          { fields: ['description'],                                startTimeLabel: null,            locationLabel: null },
      flight:        { fields: ['endDateCol', 'startTime', 'endTime', 'flightRoutes', 'flightMeta', 'flightRef'], startTimeLabel: 'Departure Time', endTimeLabel: 'Arrival Time', endDateLabel: 'Arrival Date', locationLabel: null },
    };

    const ALL_DYN_FIELDS = ['endDateCol', 'startTime', 'endTime', 'location', 'checkinNotes', 'checkoutNotes', 'fromTo', 'vehicle', 'transferNotes', 'venue', 'description', 'flightRoutes', 'flightMeta', 'flightRef'];

    function applyType(type) {
      const cfg = TYPE_CONFIG[type] || { fields: [] };
      ALL_DYN_FIELDS.forEach((f) => {
        const el = document.getElementById('field-' + f) || document.getElementById(f);
        if (el) el.style.display = cfg.fields.includes(f) ? '' : 'none';
      });
      if (cfg.startTimeLabel) document.getElementById('startTimeLabel').textContent = cfg.startTimeLabel;
      if (cfg.endTimeLabel)   document.getElementById('endTimeLabel').textContent   = cfg.endTimeLabel || 'End Time';
      if (cfg.locationLabel)  document.getElementById('locationLabel').textContent  = cfg.locationLabel;
      const endDateLbl = document.querySelector('#endDateCol label');
      if (endDateLbl) endDateLbl.textContent = cfg.endDateLabel || 'End Date';
    }

    document.getElementById('typeSelect').addEventListener('change', function () {
      applyType(this.value);
    });

    document.getElementById('addBtn').addEventListener('click', () => {
      document.getElementById('itemModalTitle').textContent = 'Add Item';
      document.getElementById('itemSubmitBtn').textContent = 'Add Item';
      document.getElementById('itemForm').action = BASE_URL;
      document.getElementById('itemForm').reset();
      document.getElementById('itemDate').value = '';
      applyType('accommodation');
    });

    document.querySelectorAll('.quick-add-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.getElementById('itemModalTitle').textContent = 'Add Item';
        document.getElementById('itemSubmitBtn').textContent = 'Add Item';
        document.getElementById('itemForm').action = BASE_URL;
        document.getElementById('itemForm').reset();
        document.getElementById('itemDate').value = btn.dataset.date;
        applyType('accommodation');
      });
    });

    document.querySelectorAll('.edit-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const item = JSON.parse(btn.dataset.item);
        document.getElementById('itemModalTitle').textContent = 'Edit Item';
        document.getElementById('itemSubmitBtn').textContent = 'Save Changes';
        document.getElementById('itemForm').action = BASE_URL + '/' + item.id;

        document.getElementById('typeSelect').value = item.type;
        applyType(item.type);

        document.getElementById('itemDate').value = item.item_date;
        document.getElementById('endDate').value = item.end_date || '';
        document.getElementById('itemTitle').value = item.title;
        document.getElementById('startTime').value = item.start_time || '';
        document.getElementById('endTime').value = item.end_time || '';
        document.getElementById('location').value = item.location || '';
        document.getElementById('description').value = item.description || '';

        const d = item.details || {};
        document.getElementById('detail_checkin_notes').value = d.checkin_notes || '';
        document.getElementById('detail_checkout_notes').value = d.checkout_notes || '';
        document.getElementById('detail_from').value = d.from || '';
        document.getElementById('detail_to').value = d.to || '';
        document.getElementById('detail_vehicle').value = d.vehicle || '';
        document.getElementById('detail_notes').value = d.notes || '';
        document.getElementById('detail_venue').value = d.venue || '';
        document.getElementById('detail_departure_airport').value = d.departure_airport || '';
        document.getElementById('detail_arrival_airport').value   = d.arrival_airport   || '';
        document.getElementById('detail_airline').value           = d.airline            || '';
        document.getElementById('detail_flight_number').value     = d.flight_number      || '';
        document.getElementById('detail_terminal').value          = d.terminal           || '';
        document.getElementById('detail_booking_ref').value       = d.booking_ref        || '';
      });
    });

    applyType('accommodation');

    document.getElementById('deleteModal').addEventListener('show.bs.modal', function (e) {
      const btn = e.relatedTarget;
      document.getElementById('deleteItemTitle').textContent = btn.dataset.itemTitle || 'This item';
      document.getElementById('deleteForm').action = btn.dataset.deleteUrl;
    });
  </script>
</body>
</html>
