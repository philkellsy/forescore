<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | Legends</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#0e5135" />
    <link rel="icon" type="image/png" href="/img/icons/icon-192.png?v=<%= assetVersion %>" />
    <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container py-3 py-md-4">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
          <h1 class="h4 mb-1">Calcutta - <%= event.year %></h1>
          <p class="text-muted mb-0"><%= event.location %></p>
        </div>
        <a class="btn btn-outline-dark" href="/admin/events/<%= event.id %>">Back To Event Setup</a>
      </div>

      <% if (message) { %>
        <div class="alert alert-success"><%= message %></div>
      <% } %>
      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <section class="card border-0 shadow-sm mb-3">
        <div class="card-body">
          <div class="row g-3">
            <div class="col-12 col-md-4">
              <div class="border rounded p-3 h-100">
                <div class="small text-muted">Players</div>
                <div class="h5 mb-0"><%= totalPlayers %></div>
              </div>
            </div>
            <div class="col-12 col-md-4">
              <div class="border rounded p-3 h-100">
                <div class="small text-muted">Drawn / Sold</div>
                <div class="h5 mb-0"><%= drawnPlayers %> / <%= totalPlayers %></div>
              </div>
            </div>
            <div class="col-12 col-md-4">
              <div class="border rounded p-3 h-100">
                <div class="small text-muted">Pool Total (50%)</div>
                <div class="h5 mb-0">$<%= Number(poolTotal || 0).toFixed(2) %></div>
              </div>
            </div>
          </div>
          <div class="d-flex flex-wrap gap-2 mt-3">
            <form action="/admin/events/<%= event.id %>/calcutta/draw" method="post">
              <button class="btn btn-legends" type="submit" <%= pendingPlayer || allDrawn ? 'disabled' : '' %>>
                <i class="fa-solid fa-shuffle me-1"></i>Draw Player
              </button>
            </form>
            <a class="btn btn-outline-secondary" href="/admin/events/<%= event.id %>/calcutta/projector" target="_blank" rel="noopener noreferrer">
              <i class="fa-solid fa-display me-1"></i>Open Projector View
            </a>
            <form action="/admin/events/<%= event.id %>/calcutta/day2/generate" method="post">
              <button class="btn btn-outline-dark" type="submit" <%= !allDrawn || pendingPlayer || String(day2Status?.status || 'draft') !== 'draft' ? 'disabled' : '' %>>
                <i class="fa-solid fa-people-group me-1"></i>Generate Day 2 / Round 1 Groups
              </button>
            </form>
            <form action="/admin/events/<%= event.id %>/calcutta/finalise" method="post">
              <button class="btn btn-outline-dark" type="submit" <%= !allDrawn || ownerMissingCount > 0 || pendingPlayer ? 'disabled' : '' %>>
                <i class="fa-solid fa-flag-checkered me-1"></i>Finalise Calcutta
              </button>
            </form>
            <% if (day2GroupCount > 0) { %>
              <span class="badge text-bg-success align-self-center">Day 2 / Round 1 Groups: <%= day2GroupCount %></span>
            <% } %>
            <% if (ownerMissingCount > 0) { %>
              <span class="badge text-bg-warning align-self-center">Missing owners: <%= ownerMissingCount %></span>
            <% } %>
          </div>
        </div>
      </section>

      <section class="card border-0 shadow-sm mb-3">
        <div class="card-body">
          <h2 class="h6 mb-3">Player Up For Auction</h2>
          <% if (!pendingPlayer) { %>
            <p class="text-muted mb-0"><%= allDrawn ? 'All players have been drawn.' : 'Draw a player to begin the next auction.' %></p>
          <% } else { %>
            <div class="border rounded p-3 bg-light mb-3">
              <div class="small text-muted mb-1">Current Player</div>
              <div class="h4 mb-0">
                <%- include('../partials/participant-card', {
                  name: `${pendingPlayer.first_name || ''} ${pendingPlayer.last_name || ''}`.trim(),
                  handicapText: pendingPlayer.playing_handicap === null || pendingPlayer.playing_handicap === undefined
                    ? ''
                    : (Number.isInteger(Number(pendingPlayer.playing_handicap))
                        ? String(Math.trunc(Number(pendingPlayer.playing_handicap)))
                        : String(Number(pendingPlayer.playing_handicap))),
                  isDefendingChampion: Number(pendingPlayer.is_previous_year_winner || 0) === 1,
                  isPreviousWinner: Number(pendingPlayer.is_previous_winner || 0) === 1,
                  className: 'border rounded px-2 py-1 bg-white small d-inline-flex align-items-center gap-1'
                }) %>
              </div>
            </div>

            <form action="/admin/events/<%= event.id %>/calcutta/sell" method="post" class="row g-2 align-items-end">
              <div class="col-12 col-md-3">
                <label class="form-label">Sold Price</label>
                <input class="form-control" type="number" min="1" step="1" name="soldPrice" required />
              </div>
              <div class="col-12 col-md-4">
                <label class="form-label">Buyer</label>
                <select class="form-select" name="buyerUserId" required>
                  <option value="">Select buyer</option>
                  <% eventPlayers.forEach((p) => { %>
                    <option value="<%= p.id %>"><%= p.first_name %> <%= p.last_name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-12 col-md-4">
                <label class="form-label">Owner (optional)</label>
                <select class="form-select" name="ownerUserId">
                  <option value="">Unassigned</option>
                  <% eventPlayers.forEach((p) => { %>
                    <option value="<%= p.id %>"><%= p.first_name %> <%= p.last_name %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-12 col-md-1 d-grid">
                <button class="btn btn-legends" type="submit">Save</button>
              </div>
            </form>
          <% } %>
        </div>
      </section>

      <section class="card border-0 shadow-sm">
        <div class="card-body">
          <h2 class="h6 mb-3">Calcutta Sales</h2>
          <% if (!sales.length) { %>
            <p class="text-muted mb-0">No sales recorded yet.</p>
          <% } else { %>
            <div class="table-responsive">
              <table class="table table-sm align-middle mb-0">
                <thead>
                  <tr>
                    <th>Draw</th>
                    <th>Player</th>
                    <th>Sold Price</th>
                    <th>Buyer</th>
                    <th>Owner</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  <% sales.forEach((sale) => { %>
                    <tr>
                      <td><%= sale.draw_order %></td>
                      <td>
                        <%= sale.auctioned_first_name %> <%= sale.auctioned_last_name %>
                        <% if (sale.auctioned_playing_handicap !== null && sale.auctioned_playing_handicap !== undefined) { %>
                          (<%= Number.isInteger(Number(sale.auctioned_playing_handicap))
                            ? Math.trunc(Number(sale.auctioned_playing_handicap))
                            : Number(sale.auctioned_playing_handicap) %>)
                        <% } %>
                      </td>
                      <td>$<%= Number(sale.auction_bid_amount || 0).toFixed(2) %></td>
                      <td><%= sale.buyer_first_name %> <%= sale.buyer_last_name %></td>
                      <td><%= sale.owner_user_id ? `${sale.owner_first_name} ${sale.owner_last_name}` : '-' %></td>
                      <td class="text-end">
                        <button
                          type="button"
                          class="btn btn-sm btn-outline-dark"
                          data-bs-toggle="modal"
                          data-bs-target="#editSaleModal"
                          data-sale-id="<%= sale.id %>"
                          data-sale-price="<%= Number(sale.auction_bid_amount || 0) %>"
                          data-sale-buyer-id="<%= sale.buyer_user_id %>"
                          data-sale-owner-id="<%= sale.owner_user_id || '' %>"
                        >
                          <i class="fa-solid fa-pen-to-square"></i>
                        </button>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </section>
    </main>

    <div class="modal fade" id="editSaleModal" tabindex="-1" aria-labelledby="editSaleModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <form id="editSaleForm" method="post">
            <div class="modal-header">
              <h2 class="modal-title fs-6" id="editSaleModalLabel">Edit Sale</h2>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
              <div class="mb-3">
                <label class="form-label">Sold Price</label>
                <input class="form-control" type="number" min="1" step="1" id="editSalePrice" name="soldPrice" required />
              </div>
              <div class="mb-3">
                <label class="form-label">Buyer</label>
                <select class="form-select" id="editSaleBuyer" name="buyerUserId" required>
                  <option value="">Select buyer</option>
                  <% eventPlayers.forEach((p) => { %>
                    <option value="<%= p.id %>"><%= p.first_name %> <%= p.last_name %></option>
                  <% }) %>
                </select>
              </div>
              <div>
                <label class="form-label">Owner (optional)</label>
                <select class="form-select" id="editSaleOwner" name="ownerUserId">
                  <option value="">Unassigned</option>
                  <% eventPlayers.forEach((p) => { %>
                    <option value="<%= p.id %>"><%= p.first_name %> <%= p.last_name %></option>
                  <% }) %>
                </select>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" class="btn btn-legends">Save Changes</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
    <script>
      document.addEventListener('DOMContentLoaded', function initSaleEditor() {
        const modal = document.getElementById('editSaleModal');
        const form = document.getElementById('editSaleForm');
        const price = document.getElementById('editSalePrice');
        const buyer = document.getElementById('editSaleBuyer');
        const owner = document.getElementById('editSaleOwner');
        if (!modal || !form || !price || !buyer || !owner) return;

        modal.addEventListener('show.bs.modal', function onShow(event) {
          const trigger = event.relatedTarget;
          if (!trigger) return;
          const saleId = trigger.getAttribute('data-sale-id');
          form.action = '/admin/events/<%= event.id %>/calcutta/sales/' + encodeURIComponent(saleId) + '/update';
          price.value = trigger.getAttribute('data-sale-price') || '';
          buyer.value = trigger.getAttribute('data-sale-buyer-id') || '';
          owner.value = trigger.getAttribute('data-sale-owner-id') || '';
        });
      });
    </script>
  </body>
</html>
