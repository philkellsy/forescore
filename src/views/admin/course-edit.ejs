<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | Legends</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#0e5135" />
    <link rel="icon" type="image/png" href="/img/icons/icon-192.png?v=<%= assetVersion %>" />
    <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container py-3 py-md-4">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
          <h1 class="h4 mb-1"><%= course.course_name %> - <%= course.tee_name %></h1>
          <p class="text-muted mb-0">Global course definition</p>
        </div>
        <a class="btn btn-outline-dark" href="/admin/courses">Back</a>
      </div>

      <% if (message) { %>
        <div class="alert alert-success"><%= message %></div>
      <% } %>
      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>
      <% if (courseEditLocked) { %>
        <div class="alert alert-warning">Editing locked: active event has entered scores.</div>
      <% } %>

      <section class="card border-0 shadow-sm">
        <div class="card-body p-0">
          <form action="/admin/courses/<%= course.id %>" method="post">
            <div class="p-3 border-bottom">
              <div class="row g-3">
                <div class="col-12 col-md-8">
                  <label class="form-label">Course Name</label>
                  <input
                    class="form-control"
                    name="courseName"
                    type="text"
                    value="<%= course.course_name %>"
                    <%= courseEditLocked ? 'disabled' : '' %>
                    required
                  />
                </div>
                <div class="col-12 col-md-4">
                  <label class="form-label">Tee Name</label>
                  <input
                    class="form-control"
                    name="teeName"
                    type="text"
                    value="<%= course.tee_name %>"
                    <%= courseEditLocked ? 'disabled' : '' %>
                    required
                  />
                </div>
              </div>
            </div>
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead>
                  <tr>
                    <th>Hole</th>
                    <th>Par</th>
                    <th>Meters</th>
                    <th>SI Primary</th>
                    <th>SI Secondary</th>
                  </tr>
                </thead>
                <tbody>
                  <% holes.forEach((hole) => { %>
                    <tr>
                      <td><%= hole.hole_number %></td>
                      <td>
                        <input class="form-control form-control-sm" name="par_<%= hole.id %>" type="number" min="3" max="5" value="<%= hole.par %>" <%= courseEditLocked ? 'disabled' : '' %> required />
                      </td>
                      <td>
                        <input class="form-control form-control-sm" name="meters_<%= hole.id %>" type="number" min="50" max="700" value="<%= hole.length_meters || '' %>" <%= courseEditLocked ? 'disabled' : '' %> required />
                      </td>
                      <td>
                        <input class="form-control form-control-sm" name="si_primary_<%= hole.id %>" type="number" min="1" max="18" value="<%= hole.stroke_index_primary %>" <%= courseEditLocked ? 'disabled' : '' %> required />
                      </td>
                      <td>
                        <input class="form-control form-control-sm" name="si_secondary_<%= hole.id %>" type="number" min="19" max="36" value="<%= hole.stroke_index_secondary %>" <%= courseEditLocked ? 'disabled' : '' %> required />
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
            <div class="p-3 border-top d-flex justify-content-end">
              <button class="btn btn-legends" type="submit" <%= courseEditLocked ? 'disabled' : '' %>>Save Course</button>
            </div>
          </form>
        </div>
      </section>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  </body>
</html>
