<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> | ForeScore</title>
  <meta name="theme-color" content="#215463" />
  <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
  <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
</head>
<body>
  <%- include('../partials/nav') %>
  <main class="container py-3 py-md-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <div>
        <h1 class="h4 mb-0"><%= course.course_name %> — <%= course.tee_name %></h1>
      </div>
      <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-secondary btn-sm"
          data-bs-toggle="modal" data-bs-target="#duplicateCourseModal">
          <i class="fa-solid fa-copy me-1"></i>Duplicate
        </button>
        <% if (!courseEditLocked) { %>
          <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#deleteCourseModal">
            Delete
          </button>
        <% } %>
        <a class="btn btn-outline-secondary btn-sm" href="<%= tenantPath('/admin/courses') %>">Back</a>
      </div>
    </div>

    <% if (message) { %><div class="alert alert-success"><%= message %></div><% } %>
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
    <% if (holesLocked) { %>
      <div class="alert alert-warning">
        <i class="fa-solid fa-lock me-1"></i>A round using this course is currently open. Par, SI and distances cannot be edited until the round is closed.
      </div>
    <% } %>

    <section class="card border-0 shadow-sm">
      <div class="card-body p-0">
        <form action="<%= tenantPath(`/admin/courses/${course.id}`) %>" method="post">
          <div class="p-3 border-bottom">
            <div class="row g-3">
              <div class="col-12 col-md-6">
                <label class="form-label">Course Name</label>
                <input class="form-control" name="courseName" type="text"
                  value="<%= course.course_name %>" required />
              </div>
              <div class="col-12 col-md-3">
                <label class="form-label">Tee Name</label>
                <input class="form-control" name="teeName" type="text"
                  value="<%= course.tee_name %>" required />
              </div>
              <div class="col-12 col-md-3">
                <label class="form-label">Gender</label>
                <select class="form-select" name="gender">
                  <option value="mens" <%= course.gender === 'mens' ? 'selected' : '' %>>Men's</option>
                  <option value="womens" <%= course.gender === 'womens' ? 'selected' : '' %>>Women's</option>
                  <option value="open" <%= course.gender === 'open' ? 'selected' : '' %>>Open (all)</option>
                </select>
              </div>
              <div class="col-6 col-md-3">
                <label class="form-label">Course Rating</label>
                <input class="form-control" name="courseRating" type="number" step="0.1" min="50" max="85"
                  value="<%= course.course_rating != null ? course.course_rating : '' %>" />
              </div>
              <div class="col-6 col-md-3">
                <label class="form-label">Slope Rating</label>
                <input class="form-control" name="slopeRating" type="number" min="55" max="155"
                  value="<%= course.slope_rating != null ? course.slope_rating : '' %>" />
              </div>
              <div class="col-12">
                <div class="form-check form-switch mt-1">
                  <input class="form-check-input" type="checkbox" role="switch"
                    id="splitRatingsToggle" name="supportsSplitRatings" value="1"
                    <%= course.supports_split_ratings ? 'checked' : '' %>
                    <%= holesLocked ? 'disabled' : '' %> />
                  <label class="form-check-label" for="splitRatingsToggle">
                    Split ratings — set SI Secondary (19–36) independently per hole
                  </label>
                </div>
              </div>
            </div>
          </div>

          <% if (holes.length) { %>
            <div class="table-responsive">
              <table class="table table-sm table-hover align-middle mb-0">
                <thead>
                  <tr>
                    <th class="ps-3">Hole</th>
                    <th>Par</th>
                    <th>Metres</th>
                    <th>SI Primary</th>
                    <th id="siSecondaryHeader">SI Secondary</th>
                  </tr>
                </thead>
                <tbody>
                  <% holes.forEach((hole) => { %>
                    <tr>
                      <td class="ps-3 fw-semibold"><%= hole.hole_number %></td>
                      <td>
                        <input class="form-control form-control-sm" style="width:70px"
                          name="par_<%= hole.id %>" type="number" min="3" max="5"
                          value="<%= hole.par %>"
                          <%= holesLocked ? 'disabled' : '' %> required />
                      </td>
                      <td>
                        <input class="form-control form-control-sm" style="width:80px"
                          name="meters_<%= hole.id %>" type="number" min="50" max="700"
                          value="<%= hole.length_meters || '' %>"
                          <%= holesLocked ? 'disabled' : '' %> />
                      </td>
                      <td>
                        <input class="form-control form-control-sm" style="width:70px"
                          name="si_primary_<%= hole.id %>" type="number" min="1" max="18"
                          value="<%= hole.stroke_index_primary %>"
                          data-hole-id="<%= hole.id %>"
                          <%= holesLocked ? 'disabled' : '' %> required />
                      </td>
                      <td>
                        <%# Editable input — shown when split ratings on %>
                        <input class="form-control form-control-sm si-secondary-input <%= course.supports_split_ratings ? '' : 'd-none' %>"
                          style="width:70px"
                          name="si_secondary_<%= hole.id %>" type="number" min="1" max="36"
                          value="<%= hole.stroke_index_secondary %>"
                          data-hole-id="<%= hole.id %>"
                          <%= (!course.supports_split_ratings || holesLocked) ? 'disabled' : '' %> />
                        <%# Calculated display — shown when split ratings off %>
                        <span class="si-secondary-calc text-muted small <%= course.supports_split_ratings ? 'd-none' : '' %>"
                          data-hole-id="<%= hole.id %>">
                          <%= hole.stroke_index_primary + 18 %>
                        </span>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
                <tfoot class="table-light">
                  <tr>
                    <td class="ps-3 fw-semibold">Total</td>
                    <td id="parTotal" class="fw-semibold"></td>
                    <td></td><td></td><td></td>
                  </tr>
                </tfoot>
              </table>
            </div>
          <% } %>

          <div class="p-3 border-top d-flex justify-content-end">
            <button class="btn btn-legends" type="submit">Save Course</button>
          </div>
        </form>
      </div>
    </section>
  </main>

  <%# Duplicate Course Modal %>
  <div class="modal fade" id="duplicateCourseModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h2 class="modal-title fs-5">Duplicate Course</h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <form action="<%= tenantPath(`/admin/courses/${course.id}/duplicate`) %>" method="post">
          <div class="modal-body">
            <p class="text-muted small mb-3">
              Creates a copy of <strong><%= course.course_name %></strong> with all 18 holes.
              Useful for adding a new tee set.
            </p>
            <label class="form-label">New Tee Name</label>
            <input type="text" name="teeName" class="form-control"
              value="<%= course.tee_name %>" required autofocus />
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-legends">Duplicate</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <%# Delete Course Modal %>
  <div class="modal fade" id="deleteCourseModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h2 class="modal-title fs-5">Delete Course</h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p>Delete <strong><%= course.course_name %> — <%= course.tee_name %></strong>? All hole data will be removed.</p>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <form action="<%= tenantPath(`/admin/courses/${course.id}/delete`) %>" method="post" class="m-0">
            <button type="submit" class="btn btn-danger">Delete Course</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  <script>
    // Live par total
    function updateParTotal() {
      const inputs = document.querySelectorAll('[name^="par_"]');
      let total = 0;
      inputs.forEach(i => { total += parseInt(i.value, 10) || 0; });
      const el = document.getElementById('parTotal');
      if (el) el.textContent = total || '';
    }
    document.querySelectorAll('[name^="par_"]').forEach(i => i.addEventListener('input', updateParTotal));
    updateParTotal();

    // Split ratings toggle
    const splitToggle = document.getElementById('splitRatingsToggle');
    splitToggle?.addEventListener('change', function () {
      const isOn = this.checked;
      const inputs  = document.querySelectorAll('.si-secondary-input');
      const calcs   = document.querySelectorAll('.si-secondary-calc');

      inputs.forEach((input) => {
        if (isOn) {
          // Seed from primary + 18 when first enabling
          const holeId  = input.dataset.holeId;
          const primary = document.querySelector(`[name="si_primary_${holeId}"]`);
          input.value   = (parseInt(primary?.value, 10) || 0) + 18;
          input.disabled = false;
          input.classList.remove('d-none');
        } else {
          input.disabled = true;
          input.classList.add('d-none');
        }
      });

      calcs.forEach((span) => {
        if (isOn) {
          span.classList.add('d-none');
        } else {
          // Refresh displayed calc from current primary value
          const holeId  = span.dataset.holeId;
          const primary = document.querySelector(`[name="si_primary_${holeId}"]`);
          span.textContent = (parseInt(primary?.value, 10) || 0) + 18;
          span.classList.remove('d-none');
        }
      });
    });

    // Keep calc spans in sync when primary changes (split ratings off)
    document.querySelectorAll('[data-hole-id]').forEach((input) => {
      if (!input.name?.startsWith('si_primary_')) return;
      input.addEventListener('input', function () {
        const holeId = this.dataset.holeId;
        const calc   = document.querySelector(`.si-secondary-calc[data-hole-id="${holeId}"]`);
        if (calc && !calc.classList.contains('d-none')) {
          calc.textContent = (parseInt(this.value, 10) || 0) + 18;
        }
      });
    });
  </script>
</body>
</html>
