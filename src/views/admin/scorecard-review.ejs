<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> | ForeScore</title>
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="theme-color" content="#215463" />
  <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
  <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
</head>
<body>
  <%- include('../partials/nav') %>
  <main class="container py-3 py-md-4" style="max-width:860px">

    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1 class="h5 mb-0"><%= model.title %></h1>
        <p class="text-muted small mb-0"><%= tour.label %> &mdash; Round <%= roundNumber %></p>
      </div>
      <a href="<%= tenantPath(`/admin/tours/${tour.id}/rounds/${roundNumber}/scores`) %>" class="btn btn-sm btn-outline-secondary">
        <i class="fa-solid fa-arrow-left me-1"></i>Back
      </a>
    </div>

    <% if (message) { %><div class="alert alert-success"><%= message %></div><% } %>
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

    <%- include('../partials/scorecard-viewer', { model }) %>

    <% if (!canEdit) { %>
      <div class="alert alert-info mt-4">
        <i class="fa-solid fa-lock me-2"></i>This round's leaderboard is published. Unpublish Round <%= roundNumber %> to enable score editing.
      </div>
    <% } else { %>
      <div class="card border-0 shadow-sm mt-4">
        <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
          <h2 class="h6 mb-0">Edit Scores</h2>
          <span class="badge text-bg-warning">Leaderboard unpublished</span>
        </div>
        <div class="table-responsive">
          <table class="table table-sm align-middle mb-0">
            <thead>
              <tr>
                <th>Hole</th>
                <th class="text-center">Par</th>
                <th class="text-center">SI</th>
                <th class="text-center">Current Gross</th>
                <% if (model.showStablefordTotals) { %><th class="text-center text-muted">Pts</th><% } %>
                <th style="min-width:140px">New Gross</th>
              </tr>
            </thead>
            <tbody>
              <% model.holes.forEach((hole) => { %>
                <tr>
                  <td class="text-muted"><%= hole.holeNumber %></td>
                  <td class="text-center"><%= hole.par %></td>
                  <td class="text-center text-muted small"><%= hole.siPrimary %></td>
                  <td class="text-center"><%= hole.gross != null ? hole.gross : '—' %></td>
                  <% if (model.showStablefordTotals) { %>
                    <td class="text-center text-muted small"><%= hole.stableford != null ? hole.stableford : '—' %></td>
                  <% } %>
                  <td>
                    <form action="<%= tenantPath(`/admin/tours/${tour.id}/rounds/${roundNumber}/scores/${userId}/holes/${hole.holeNumber}`) %>"
                          method="post"
                          class="d-flex gap-2 edit-score-form">
                      <input type="number" name="grossScore" class="form-control form-control-sm"
                             style="width:90px" min="1" max="25"
                             placeholder="blank=clear"
                             value="<%= hole.gross != null ? hole.gross : '' %>" />
                      <button type="submit" class="btn btn-sm btn-outline-primary" title="Save">
                        <i class="fa-solid fa-floppy-disk"></i>
                      </button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>

    <% if (editLogs && editLogs.length) { %>
      <div class="card border-0 shadow-sm mt-4">
        <div class="card-header bg-transparent">
          <h2 class="h6 mb-0">Edit History</h2>
        </div>
        <div class="table-responsive">
          <table class="table table-sm align-middle mb-0">
            <thead>
              <tr>
                <th>Hole</th>
                <th>Change</th>
                <th>Editor</th>
                <th>When</th>
              </tr>
            </thead>
            <tbody>
              <% editLogs.forEach((log) => { %>
                <%
                  const editorName = ((log.first_name || '') + ' ' + (log.last_name || '')).trim() || 'Admin';
                  const fromGross = log.previous_gross_score != null ? log.previous_gross_score : '—';
                  const toGross = log.new_gross_score != null ? log.new_gross_score : '—';
                  const fromPts = log.previous_stableford_points != null ? log.previous_stableford_points : '—';
                  const toPts = log.new_stableford_points != null ? log.new_stableford_points : '—';
                  const editedAt = log.created_at ? new Date(log.created_at).toLocaleString('en-AU', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' }) : '—';
                %>
                <tr>
                  <td><strong><%= log.hole_number %></strong></td>
                  <td>
                    Gross: <span class="text-muted"><%= fromGross %></span> &rarr; <strong><%= toGross %></strong>
                    <% if (model.showStablefordTotals) { %>
                      <span class="text-muted small ms-2">(S: <%= fromPts %> &rarr; <%= toPts %>)</span>
                    <% } %>
                  </td>
                  <td class="text-muted small"><%= editorName %></td>
                  <td class="text-muted small"><%= editedAt %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>

  </main>

  <% if (canEdit) { %>
    <div class="modal fade" id="confirmEditModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Edit submitted score?</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <p class="mb-0">This scorecard has been submitted. Save the new score anyway?</p>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
            <button type="button" class="btn btn-primary btn-sm" id="confirmEditBtn">Save</button>
          </div>
        </div>
      </div>
    </div>
  <% } %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <% if (canEdit) { %>
    <script>
      (function () {
        const isSubmitted = <%= JSON.stringify(round && round.status === 'submitted') %>;
        if (!isSubmitted) return;

        const modalEl = document.getElementById('confirmEditModal');
        const modal = new bootstrap.Modal(modalEl);
        let pendingForm = null;

        document.querySelectorAll('.edit-score-form').forEach((form) => {
          form.addEventListener('submit', (e) => {
            e.preventDefault();
            pendingForm = form;
            modal.show();
          });
        });

        document.getElementById('confirmEditBtn').addEventListener('click', () => {
          modal.hide();
          if (pendingForm) {
            const btn = pendingForm.querySelector('button[type="submit"]');
            if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>'; }
            pendingForm.submit();
            pendingForm = null;
          }
        });

        modalEl.addEventListener('hidden.bs.modal', () => { pendingForm = null; });
      })();
    </script>
  <% } %>
</body>
</html>
