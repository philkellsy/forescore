<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> | ForeScore</title>
  <meta name="theme-color" content="#215463" />
  <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
  <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
</head>
<body>
  <%- include('../partials/nav') %>
  <main class="container py-3 py-md-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h1 class="h4 mb-0">Courses</h1>
      <div class="d-flex gap-2">
        <a class="btn btn-outline-dark btn-sm" href="<%= tenantPath('/admin/courses/import') %>">
          <i class="fa-solid fa-cloud-arrow-down me-1"></i>Import from API
        </a>
        <button type="button" class="btn btn-legends btn-sm" data-bs-toggle="modal" data-bs-target="#addCourseModal">
          <i class="fa-solid fa-plus me-1"></i>Add Course
        </button>
        <a class="btn btn-outline-secondary btn-sm" href="<%= tenantPath('/admin') %>">Dashboard</a>
      </div>
    </div>

    <% if (message) { %><div class="alert alert-success"><%= message %></div><% } %>
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

    <section class="card border-0 shadow-sm">
      <div class="card-body p-0">
        <% if (!courses.length) { %>
          <div class="text-center py-5 text-muted">
            <i class="fa-solid fa-flag fa-3x mb-3 opacity-25"></i>
            <p class="mb-0">No courses yet. Add one to get started.</p>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <thead>
                <tr>
                  <th>Course</th>
                  <th>Tee</th>
                  <th>Gender</th>
                  <th class="text-center">Holes</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% courses.forEach((c) => { %>
                  <%
                    const genderLabel = c.gender === 'womens' ? "Women's"
                      : c.gender === 'open' ? 'Open'
                      : "Men's";
                    const genderClass = c.gender === 'womens' ? 'text-bg-warning text-dark'
                      : c.gender === 'open' ? 'text-bg-light border'
                      : 'text-bg-info text-dark';
                  %>
                  <tr>
                    <td>
                      <%= c.course_name %>
                      <% if (c.api_course_id) { %>
                        <i class="fa-solid fa-cloud text-muted small ms-1" title="Imported from API"></i>
                      <% } %>
                    </td>
                    <td><%= c.tee_name %></td>
                    <td><span class="badge <%= genderClass %>"><%= genderLabel %></span></td>
                    <td class="text-center"><%= Number(c.holes_count || 0) %></td>
                    <td class="text-end pe-3">
                      <a class="btn btn-sm btn-outline-dark me-1" href="<%= tenantPath(`/admin/courses/${c.id}`) %>">Edit</a>
                      <button type="button" class="btn btn-sm btn-outline-danger"
                        data-bs-toggle="modal" data-bs-target="#deleteCourseModal"
                        data-course-id="<%= c.id %>"
                        data-course-name="<%= c.course_name %>"
                        data-tee-name="<%= c.tee_name %>"
                        data-in-use="<%= c.in_use ? '1' : '' %>">
                        Delete
                      </button>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </section>
  </main>

  <%# Add Course Modal %>
  <div class="modal fade" id="addCourseModal" tabindex="-1" aria-labelledby="addCourseModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h2 class="modal-title fs-5" id="addCourseModalLabel">Add Course</h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <form action="<%= tenantPath('/admin/courses') %>" method="post">
          <div class="modal-body">
            <div class="mb-3">
              <label class="form-label">Course Name</label>
              <input type="text" name="courseName" class="form-control" placeholder="e.g. Royal Melbourne" required />
            </div>
            <div class="mb-3">
              <label class="form-label">Tee Name</label>
              <input type="text" name="teeName" class="form-control" placeholder="e.g. Blue" required />
            </div>
            <div class="mb-0">
              <label class="form-label">Gender</label>
              <select name="gender" class="form-select">
                <option value="mens">Men's</option>
                <option value="womens">Women's</option>
                <option value="open">Open (all)</option>
              </select>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-legends">Add Course</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <%# Delete Course Modal %>
  <div class="modal fade" id="deleteCourseModal" tabindex="-1" aria-labelledby="deleteCourseModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h2 class="modal-title fs-5" id="deleteCourseModalLabel">Delete Course</h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p>Delete <strong id="deleteCourseLabel"></strong>? All hole data will be removed.</p>
          <div id="inUseWarning" class="alert alert-danger d-none">
            This course is assigned to one or more event days and cannot be deleted. Unassign it first.
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <form id="deleteCourseForm" method="post" class="m-0">
            <button id="deleteCourseBtn" type="submit" class="btn btn-danger">Delete</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  <script>
    document.getElementById('deleteCourseModal').addEventListener('show.bs.modal', function (e) {
      const btn = e.relatedTarget;
      document.getElementById('deleteCourseLabel').textContent = btn.dataset.courseName + ' — ' + btn.dataset.teeName;
      document.getElementById('deleteCourseForm').action = '<%= tenantPath("/admin/courses/") %>' + btn.dataset.courseId + '/delete';
      const inUse = Boolean(btn.dataset.inUse);
      document.getElementById('inUseWarning').classList.toggle('d-none', !inUse);
      document.getElementById('deleteCourseBtn').disabled = inUse;
    });
  </script>
</body>
</html>
