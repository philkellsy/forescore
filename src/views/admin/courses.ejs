<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | Legends</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#0e5135" />
    <link rel="icon" type="image/png" href="/img/icons/icon-192.png?v=<%= assetVersion %>" />
    <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container py-3 py-md-4">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4 mb-0">Global Courses</h1>
        <div class="d-flex gap-2">
          <button type="button" class="btn btn-legends" data-bs-toggle="modal" data-bs-target="#addCourseModal">Add Course</button>
          <a class="btn btn-outline-dark" href="/admin/dashboard">Dashboard</a>
        </div>
      </div>

      <% if (message) { %>
        <div class="alert alert-success"><%= message %></div>
      <% } %>
      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <section class="card border-0 shadow-sm">
        <div class="card-body">
          <% if (!courses.length) { %>
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
              <p class="mb-0 text-muted">No courses yet. Seed Bonville to start quickly.</p>
              <form action="/admin/courses/seed-white" method="post" class="m-0">
                <button class="btn btn-legends" type="submit"><i class="fa-solid fa-plus me-1"></i>Add Bonville Course</button>
              </form>
            </div>
          <% } %>
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <thead>
                <tr>
                  <th>Course</th>
                  <th>Tee</th>
                  <th>Holes</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% courses.forEach((c) => { %>
                  <tr>
                    <td><%= c.course_name %></td>
                    <td><%= c.tee_name %></td>
                    <td><%= Number(c.holes_count || 0) %></td>
                    <td><a class="btn btn-sm btn-outline-dark" href="/admin/courses/<%= c.id %>">Edit</a></td>
                  </tr>
                <% }) %>
                <% if (!courses.length) { %>
                  <tr><td colspan="4" class="text-muted">No courses configured yet.</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <div class="modal fade" id="addCourseModal" tabindex="-1" aria-labelledby="addCourseModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content">
            <div class="modal-header">
              <h2 class="modal-title fs-5" id="addCourseModalLabel">Add Course</h2>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="/admin/courses" method="post">
              <div class="modal-body">
                <div class="mb-3">
                  <label class="form-label">Course Name</label>
                  <input type="text" name="courseName" class="form-control" value="Bonville International Golf Resort" required />
                </div>
                <div class="mb-3">
                  <label class="form-label">Tee Name</label>
                  <input type="text" name="teeName" class="form-control" placeholder="Blue" required />
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="seedBonville" id="seedBonvilleTemplate" checked />
                  <label class="form-check-label" for="seedBonvilleTemplate">Seed with Bonville Bloodwood 18-hole template</label>
                </div>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-legends">Add Course</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  </body>
</html>
