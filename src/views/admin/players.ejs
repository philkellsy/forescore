<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | Legends</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#0e5135" />
    <link rel="icon" type="image/png" href="/img/icons/icon-192.png?v=<%= assetVersion %>" />
    <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container py-3 py-md-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h4 mb-0">Player Management</h1>
      </div>

      <% if (message) { %>
        <div class="alert alert-success"><%= message %></div>
      <% } %>
      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <section class="card border-0 shadow-sm mb-3">
        <div class="card-body">
          <h2 class="h6 mb-3">Add Player</h2>
          <form action="/admin/players" method="post" class="row g-2">
            <div class="col-12 col-md-2"><input name="firstName" class="form-control form-control-sm" placeholder="First name" required /></div>
            <div class="col-12 col-md-2"><input name="lastName" class="form-control form-control-sm" placeholder="Last name" required /></div>
            <div class="col-12 col-md-3"><input name="email" type="email" class="form-control form-control-sm" placeholder="Email" required /></div>
            <div class="col-12 col-md-2"><input name="phoneNumber" class="form-control form-control-sm" placeholder="Phone" /></div>
            <div class="col-8 col-md-2">
              <select name="role" class="form-select form-select-sm" required>
                <option value="player">player</option>
                <option value="scorer">scorer</option>
                <option value="admin">admin</option>
              </select>
            </div>
            <div class="col-4 col-md-1 d-flex align-items-center justify-content-md-center">
              <label class="form-check-label small text-muted me-2 d-inline-flex align-items-center" for="addPrevWinner" title="Past Champion" aria-label="Past Champion">
                <i class="fa-solid fa-trophy winner-badge" aria-hidden="true"></i>
              </label>
              <input id="addPrevWinner" type="checkbox" name="isPreviousWinner" class="form-check-input" />
            </div>
            <div class="col-12">
              <button class="btn btn-sm btn-legends" type="submit">Create Player</button>
            </div>
          </form>
        </div>
      </section>

      <section class="row g-3">
        <div class="col-12">
          <div class="card border-0 shadow-sm">
            <div class="card-body">
              <label for="playerSearchInput" class="form-label small text-muted mb-1">Search Players</label>
              <input
                id="playerSearchInput"
                type="search"
                class="form-control form-control-sm"
                placeholder="Search by name, email, phone or role..."
                autocomplete="off"
              />
            </div>
          </div>
        </div>
        <% users.forEach((u) => { %>
          <article
            class="col-12 col-md-6 col-xl-4 js-player-card"
            data-search="<%= `${u.first_name || ''} ${u.last_name || ''} ${u.email || ''} ${u.phone_number || ''} ${u.role || ''}`.toLowerCase() %>"
          >
            <div class="card border-0 shadow-sm h-100">
              <div class="card-body d-flex flex-column gap-2">
                <div class="d-flex justify-content-between align-items-start gap-2">
                  <h3 class="h6 mb-0 d-flex align-items-center gap-1">
                    <span><%= u.first_name %> <%= u.last_name %></span>
                    <% if (Number(u.is_previous_winner) === 1) { %>
                      <%- include('../partials/winner-badge', { showText: false, className: '' }) %>
                    <% } %>
                  </h3>
                  <button
                    type="button"
                    class="btn btn-sm btn-outline-dark js-edit-player"
                    data-bs-toggle="modal"
                    data-bs-target="#editPlayerModal"
                    title="Edit player"
                    aria-label="Edit player"
                    data-id="<%= u.id %>"
                    data-first-name="<%= u.first_name %>"
                    data-last-name="<%= u.last_name %>"
                    data-email="<%= u.email %>"
                    data-phone-number="<%= u.phone_number || '' %>"
                    data-role="<%= u.role %>"
                    data-is-previous-winner="<%= Number(u.is_previous_winner) === 1 ? '1' : '0' %>"
                  >
                    <i class="fa-solid fa-pen-to-square" aria-hidden="true"></i>
                  </button>
                </div>
                <div class="small text-muted"><%= u.email %></div>
                <div class="small"><strong>Phone:</strong> <%= u.phone_number || '-' %></div>
                <div class="small"><strong>Role:</strong> <%= u.role %></div>
              </div>
            </div>
          </article>
        <% }) %>
      </section>

      <div class="modal fade" id="editPlayerModal" tabindex="-1" aria-labelledby="editPlayerModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content">
            <form id="editPlayerForm" method="post">
              <div class="modal-header">
                <h2 class="modal-title fs-6" id="editPlayerModalLabel">Edit Player</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <div class="modal-body">
                <div class="row g-2">
                  <div class="col-6">
                    <label class="form-label small mb-1" for="editPlayerFirstName">First Name</label>
                    <input id="editPlayerFirstName" name="firstName" class="form-control form-control-sm" required />
                  </div>
                  <div class="col-6">
                    <label class="form-label small mb-1" for="editPlayerLastName">Last Name</label>
                    <input id="editPlayerLastName" name="lastName" class="form-control form-control-sm" required />
                  </div>
                  <div class="col-12">
                    <label class="form-label small mb-1" for="editPlayerEmail">Email</label>
                    <input id="editPlayerEmail" name="email" type="email" class="form-control form-control-sm" required />
                  </div>
                  <div class="col-7">
                    <label class="form-label small mb-1" for="editPlayerPhoneNumber">Phone</label>
                    <input id="editPlayerPhoneNumber" name="phoneNumber" class="form-control form-control-sm" />
                  </div>
                  <div class="col-5">
                    <label class="form-label small mb-1" for="editPlayerRole">Role</label>
                    <select id="editPlayerRole" name="role" class="form-select form-select-sm" required>
                      <option value="player">player</option>
                      <option value="scorer">scorer</option>
                      <option value="admin">admin</option>
                    </select>
                  </div>
                  <div class="col-12">
                    <label class="form-check-label small" for="editPlayerPreviousWinner">
                      <input id="editPlayerPreviousWinner" type="checkbox" name="isPreviousWinner" class="form-check-input me-1" />
                      Past champion
                    </label>
                  </div>
                </div>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-sm btn-legends">Save Player</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const editForm = document.getElementById('editPlayerForm');
        const searchInput = document.getElementById('playerSearchInput');
        const playerCards = [...document.querySelectorAll('.js-player-card')];

        if (searchInput && playerCards.length) {
          const applySearch = () => {
            const q = (searchInput.value || '').trim().toLowerCase();
            playerCards.forEach((card) => {
              const haystack = card.getAttribute('data-search') || '';
              card.style.display = !q || haystack.includes(q) ? '' : 'none';
            });
          };
          searchInput.addEventListener('input', applySearch);
        }

        if (editForm) {
          const firstNameEl = document.getElementById('editPlayerFirstName');
          const lastNameEl = document.getElementById('editPlayerLastName');
          const emailEl = document.getElementById('editPlayerEmail');
          const phoneEl = document.getElementById('editPlayerPhoneNumber');
          const roleEl = document.getElementById('editPlayerRole');
          const prevWinnerEl = document.getElementById('editPlayerPreviousWinner');

          document.querySelectorAll('.js-edit-player').forEach((btn) => {
            btn.addEventListener('click', () => {
              const playerId = btn.getAttribute('data-id');
              editForm.action = `/admin/players/${playerId}`;
              firstNameEl.value = btn.getAttribute('data-first-name') || '';
              lastNameEl.value = btn.getAttribute('data-last-name') || '';
              emailEl.value = btn.getAttribute('data-email') || '';
              phoneEl.value = btn.getAttribute('data-phone-number') || '';
              roleEl.value = btn.getAttribute('data-role') || 'player';
              prevWinnerEl.checked = btn.getAttribute('data-is-previous-winner') === '1';
            });
          });
        }
      });
    </script>
  </body>
</html>
