<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> | ForeScore</title>
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="theme-color" content="#215463" />
  <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
  <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
</head>
<body>
  <%- include('../partials/nav') %>
  <main class="container py-3 py-md-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1 class="h4 mb-0">Players</h1>
        <p class="text-muted small mb-0"><%= tenant.name %></p>
      </div>
      <a href="<%= tenantPath('/admin') %>" class="btn btn-sm btn-outline-secondary">
        <i class="fa-solid fa-arrow-left me-1"></i>Admin
      </a>
    </div>

    <% if (message) { %><div class="alert alert-success"><%= message %></div><% } %>
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

    <%# Add member %>
    <section class="card border-0 shadow-sm mb-4">
      <div class="card-body border-bottom">
        <h2 class="h6 mb-0">Add Player</h2>
      </div>
      <div class="card-body">
        <p class="text-muted small mb-3">Enter an existing ForeScore user's email to add them, or fill in all fields to create a new account.</p>
        <form action="<%= tenantPath('/admin/players') %>" method="post">
          <div class="row g-2">
            <div class="col-12 col-md-3">
              <input type="text" name="firstName" class="form-control form-control-sm" placeholder="First name" />
            </div>
            <div class="col-12 col-md-2">
              <input type="text" name="lastName" class="form-control form-control-sm" placeholder="Last name" />
            </div>
            <div class="col-12 col-md-3">
              <input type="email" name="email" class="form-control form-control-sm" placeholder="Email" required />
            </div>
            <div class="col-12 col-md-2">
              <input type="text" name="phoneNumber" class="form-control form-control-sm" placeholder="Phone (optional)" />
            </div>
            <div class="col-6 col-md-1">
              <select name="gender" class="form-select form-select-sm">
                <option value="male">M</option>
                <option value="female">F</option>
              </select>
            </div>
            <div class="col-6 col-md-1">
              <select name="role" class="form-select form-select-sm">
                <option value="player">Player</option>
                <option value="scorer">Scorer</option>
                <option value="admin">Admin</option>
                <% if (tenantMembership && tenantMembership.role === 'owner') { %>
                  <option value="owner">Owner</option>
                <% } %>
              </select>
            </div>
            <div class="col-12 col-md-auto d-grid">
              <button class="btn btn-sm btn-legends" type="submit">Add</button>
            </div>
          </div>
        </form>
      </div>
    </section>

    <%# Member list %>
    <section class="card border-0 shadow-sm">
      <div class="card-body border-bottom">
        <h2 class="h6 mb-0">Current Players <span class="badge text-bg-light border ms-1"><%= members.length %></span></h2>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Gender</th>
                <th>Role</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% members.forEach((m) => { %>
                <% const isSelf = m.user_id === user.id; %>
                <tr>
                  <td><%= m.first_name %> <%= m.last_name %></td>
                  <td class="text-muted small"><%= m.email %></td>
                  <td class="text-muted small"><%= m.phone_number || '—' %></td>
                  <td>
                    <span class="badge <%= m.gender === 'female' ? 'text-bg-warning text-dark' : 'text-bg-info text-dark' %>">
                      <%= m.gender === 'female' ? 'F' : 'M' %>
                    </span>
                  </td>
                  <td>
                    <span class="badge <%=
                      m.role === 'owner' ? 'text-bg-dark'
                      : m.role === 'admin' ? 'text-bg-primary'
                      : m.role === 'scorer' ? 'text-bg-info text-dark'
                      : 'text-bg-light border'
                    %>"><%= m.role %></span>
                  </td>
                  <td class="text-end">
                    <% if (!isSelf) { %>
                      <div class="d-flex gap-1 justify-content-end">
                        <button type="button" class="btn btn-sm btn-outline-dark"
                          data-gender-btn
                          data-member-id="<%= m.user_id %>"
                          data-member-name="<%= m.first_name %> <%= m.last_name %>"
                          data-current-gender="<%= m.gender || 'male' %>"
                          title="Edit gender"
                        >
                          <i class="fa-solid fa-venus-mars"></i>
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-dark"
                          data-role-btn
                          data-member-id="<%= m.user_id %>"
                          data-member-name="<%= m.first_name %> <%= m.last_name %>"
                          data-current-role="<%= m.role %>"
                          title="Change role"
                        >
                          <i class="fa-solid fa-user-tag"></i>
                        </button>
                        <form action="<%= tenantPath(`/admin/players/${m.user_id}/remove`) %>" method="post"
                          onsubmit="return confirm('Remove <%= m.first_name %> from this tour?')">
                          <button type="submit" class="btn btn-sm btn-outline-danger" title="Remove">
                            <i class="fa-solid fa-trash"></i>
                          </button>
                        </form>
                      </div>
                    <% } else { %>
                      <span class="text-muted small">You</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
              <% if (!members.length) { %>
                <tr><td colspan="6" class="text-muted text-center py-3">No players yet.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </section>
  </main>

  <%# Change Role Modal %>
  <div class="modal fade" id="changeRoleModal" tabindex="-1" aria-labelledby="changeRoleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <form id="changeRoleForm" method="post">
          <div class="modal-header">
            <h2 class="modal-title fs-6" id="changeRoleModalLabel">Change Role</h2>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <p class="small text-muted mb-3" id="changeRoleMemberName"></p>
            <div class="mb-0">
              <label class="form-label">Role</label>
              <select name="role" id="changeRoleSelect" class="form-select">
                <option value="player">Player</option>
                <option value="scorer">Scorer</option>
                <option value="admin">Admin</option>
                <% if (tenantMembership && tenantMembership.role === 'owner') { %>
                  <option value="owner">Owner</option>
                <% } %>
              </select>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-legends">Update Role</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <%# Edit Gender Modal %>
  <div class="modal fade" id="editGenderModal" tabindex="-1" aria-labelledby="editGenderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <form id="editGenderForm" method="post">
          <div class="modal-header">
            <h2 class="modal-title fs-6" id="editGenderModalLabel">Edit Gender</h2>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <p class="small text-muted mb-3" id="editGenderMemberName"></p>
            <div class="mb-0">
              <label class="form-label">Gender</label>
              <select name="gender" id="editGenderSelect" class="form-select">
                <option value="male">Male</option>
                <option value="female">Female</option>
              </select>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-legends">Save</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const roleModal = new bootstrap.Modal(document.getElementById('changeRoleModal'));
      const roleForm = document.getElementById('changeRoleForm');
      const roleNameEl = document.getElementById('changeRoleMemberName');
      const roleSelect = document.getElementById('changeRoleSelect');
      document.querySelectorAll('[data-role-btn]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          roleNameEl.textContent = btn.dataset.memberName;
          roleSelect.value = btn.dataset.currentRole;
          roleForm.action = '<%= tenantPath('/admin/players/') %>' + btn.dataset.memberId + '/role';
          roleModal.show();
        });
      });

      const genderModal = new bootstrap.Modal(document.getElementById('editGenderModal'));
      const genderForm = document.getElementById('editGenderForm');
      const genderNameEl = document.getElementById('editGenderMemberName');
      const genderSelect = document.getElementById('editGenderSelect');
      document.querySelectorAll('[data-gender-btn]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          genderNameEl.textContent = btn.dataset.memberName;
          genderSelect.value = btn.dataset.currentGender || 'male';
          genderForm.action = '<%= tenantPath('/admin/players/') %>' + btn.dataset.memberId + '/update';
          genderModal.show();
        });
      });
    });
  </script>
</body>
</html>
