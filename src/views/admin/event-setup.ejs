<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | Legends</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#0e5135" />
    <link rel="icon" type="image/png" href="/img/icons/icon-192.png?v=<%= assetVersion %>" />
    <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
  </head>
  <body>
    <%
      function formatMobile(value) {
        const digits = String(value || '').replace(/\D/g, '');
        if (digits.length === 10 && digits.startsWith('0')) {
          return `${digits.slice(0, 4)} ${digits.slice(4, 7)} ${digits.slice(7)}`;
        }
        return value || '-';
      }
      function formatEventDate(value) {
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return value || '';
        return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      }
    %>
    <%- include('../partials/nav') %>
    <main class="container py-3 py-md-4">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
          <h1 class="h4 mb-1">Event Dashboard - <%= event.year %></h1>
          <p class="text-muted mb-0"><%= event.location %> (<%= formatEventDate(event.start_date) %> - <%= formatEventDate(event.end_date) %>)</p>
        </div>
        <a class="btn btn-outline-dark" href="/admin/dashboard">Back</a>
      </div>

      <% if (message) { %>
        <div class="alert alert-success"><%= message %></div>
      <% } %>
      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <section class="card border-0 shadow-sm mb-3">
        <div class="card-body">
          <div class="row g-3">
            <div class="col-12 col-lg-4">
              <div class="border rounded p-3 h-100 d-flex flex-column align-items-start gap-3">
                <div>
                  <h3 class="h6 mb-1">Event Setup</h3>
                  <ul class="text-muted small mb-0 ps-3">
                    <li>Assign course and tees</li>
                    <li>Set NTP and long drive events</li>
                    <li>Configure prizes</li>
                  </ul>
                </div>
                <a class="btn btn-legends mt-auto" href="/admin/events/<%= event.id %>/setup">Manage</a>
              </div>
            </div>
            <div class="col-12 col-lg-4">
              <div class="border rounded p-3 h-100 d-flex flex-column align-items-start gap-3">
                <div>
                  <h3 class="h6 mb-1">Calcutta</h3>
                  <ul class="text-muted small mb-0 ps-3">
                    <li>Run the random draw including projector view</li>
                    <li>Record auction sales and owners</li>
                    <li>Finalise and generate Round 1 groups</li>
                  </ul>
                </div>
                <a class="btn btn-legends mt-auto" href="/admin/events/<%= event.id %>/calcutta">Manage</a>
              </div>
            </div>
            <!--div class="col-12 col-lg-3">
              <div class="border rounded p-3 h-100 d-flex justify-content-between align-items-center">
                <div>
                  <h3 class="h6 mb-1">Manage Ambrose Teams</h3>
                  <p class="text-muted mb-0">Build <%= dayLabel(1) %> teams and create team scorecards.</p>
                </div>
                <a class="btn btn-legends" href="/admin/events/<%= event.id %>/ambrose">Manage</a>
              </div>
            </div-->
            <div class="col-12 col-lg-4">
              <div class="border rounded p-3 h-100 d-flex flex-column align-items-start gap-3">
                <div>
                  <h3 class="h6 mb-1">Manage Tee Times</h3>
                  <ul class="text-muted small mb-0 ps-3">
                    <li>Create daily groups and tee times</li>
                    <li>Manage and review results</li>
                    <li>Publish leaderboards</li>
                  </ul>
                </div>
                <a class="btn btn-legends mt-auto" href="/admin/events/<%= event.id %>/tee-times">Manage</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <% if (!hasAnyScores) { %>
        <section class="card border-0 shadow-sm mb-3">
          <div class="card-body">
            <h2 class="h6 mb-3">Add Players To Event</h2>
            <form action="/admin/events/<%= event.id %>/players" method="post" class="row g-2 align-items-end">
              <div class="col-12 col-md-8">
                <label class="form-label">Available Players</label>
                <select name="userId" class="form-select" required>
                  <option value="">Select player</option>
                  <% availableUsers.forEach((u) => { %>
                    <option value="<%= u.id %>"><%= u.first_name %> <%= u.last_name %><%= Number(u.is_previous_winner) === 1 ? ' 🏆' : '' %> (<%= u.email %>)</option>
                  <% }) %>
                </select>
              </div>
              <div class="col-12 col-md-4 d-grid">
                <button class="btn btn-legends" type="submit"><i class="fa-solid fa-user-plus me-1"></i>Add Player</button>
              </div>
            </form>
          </div>
        </section>
      <% } %>

      <section class="card border-0 shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h6 mb-0">Event Players</h2>
            <% if (hasAnyScores) { %>
              <span class="badge text-bg-secondary">Player edit/delete locked after scoring starts</span>
            <% } %>
          </div>
          <% if (eventPlayers.length) { %>
            <div class="row g-3">
              <% eventPlayers.forEach((p) => { %>
                <div class="col-12 col-md-6 col-xl-4">
                  <article class="border rounded p-3 h-100 bg-white">
                    <div class="d-flex justify-content-between align-items-start gap-2">
                      <div>
                        <h3 class="h6 mb-1">
                          <%= p.first_name %> <%= p.last_name %>
                          <% if (Number(p.is_previous_winner) === 1) { %>
                            <%- include('../partials/winner-badge', { showText: false, className: 'ms-1' }) %>
                          <% } %>
                        </h3>
                        <p class="small text-muted mb-2">Mobile: <%= formatMobile(p.phone_number) %></p>
                      </div>
                      <% if (!hasAnyScores) { %>
                        <div class="d-flex gap-1">
                          <button
                            type="button"
                            class="btn btn-sm btn-outline-dark"
                            title="Edit Player"
                            data-edit-player-btn
                            data-player-id="<%= p.id %>"
                            data-player-name="<%= p.first_name %> <%= p.last_name %>"
                            data-player-handicap="<%= p.playing_handicap === null || p.playing_handicap === undefined ? '' : p.playing_handicap %>"
                            data-player-defending="<%= Number(p.is_previous_year_winner) === 1 ? '1' : '0' %>"
                          >
                            <i class="fa-solid fa-pen-to-square"></i>
                          </button>
                          <form action="/admin/events/<%= event.id %>/players/<%= p.id %>/delete" method="post" onsubmit="return confirm('Remove this player from the event?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete Player">
                              <i class="fa-solid fa-trash"></i>
                            </button>
                          </form>
                        </div>
                      <% } %>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-2">
                      <span class="badge text-bg-light border">Handicap: <%= p.playing_handicap === null || p.playing_handicap === undefined ? '-' : p.playing_handicap %></span>
                      <% if (Number(p.is_previous_year_winner) === 1) { %>
                        <span class="badge text-bg-warning">Defending Champion</span>
                      <% } %>
                    </div>
                  </article>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <p class="text-muted mb-0">No players in this event yet.</p>
          <% } %>
        </div>
      </section>

      <% if (!hasAnyScores) { %>
        <div class="modal fade" id="editEventPlayerModal" tabindex="-1" aria-labelledby="editEventPlayerModalLabel" aria-hidden="true">
          <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
              <form id="editEventPlayerForm" method="post">
                <div class="modal-header">
                  <h2 class="modal-title fs-6" id="editEventPlayerModalLabel">Edit Player</h2>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                  <p class="mb-3 small text-muted" id="editEventPlayerName"></p>
                  <div class="mb-3">
                    <label class="form-label">Playing Handicap</label>
                    <input
                      type="number"
                      min="-10"
                      max="54"
                      step="1"
                      class="form-control handicap-input"
                      name="playingHandicap"
                      id="editEventPlayerHandicap"
                      required
                    />
                  </div>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="isPreviousYearWinner" id="editEventPlayerChampion" />
                    <label class="form-check-label" for="editEventPlayerChampion">Defending Champion</label>
                  </div>
                </div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                  <button type="submit" class="btn btn-legends">Save Changes</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      <% } %>

    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
    <% if (!hasAnyScores) { %>
      <script>
        document.addEventListener('DOMContentLoaded', function initEventPlayerModal() {
          const modalElement = document.getElementById('editEventPlayerModal');
          if (!modalElement || typeof bootstrap === 'undefined') return;

          const modal = new bootstrap.Modal(modalElement);
          const form = document.getElementById('editEventPlayerForm');
          const nameEl = document.getElementById('editEventPlayerName');
          const handicapEl = document.getElementById('editEventPlayerHandicap');
          const championEl = document.getElementById('editEventPlayerChampion');
          const buttons = document.querySelectorAll('[data-edit-player-btn]');

          buttons.forEach(function bindEdit(btn) {
            btn.addEventListener('click', function onEdit() {
              const playerId = btn.getAttribute('data-player-id');
              const playerName = btn.getAttribute('data-player-name') || 'Player';
              const playerHandicap = btn.getAttribute('data-player-handicap') || '';
              const playerDefending = btn.getAttribute('data-player-defending') === '1';

              form.action = '/admin/events/<%= event.id %>/players/' + encodeURIComponent(playerId) + '/update';
              nameEl.textContent = playerName;
              handicapEl.value = playerHandicap;
              championEl.checked = playerDefending;
              modal.show();
            });
          });
        });
      </script>
    <% } %>
  </body>
</html>
