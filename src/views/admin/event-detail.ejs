<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> | ForeScore</title>
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="theme-color" content="#215463" />
  <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
  <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
</head>
<body>
  <%- include('../partials/nav') %>
  <main class="container py-3 py-md-4">

    <%# Header %>
    <div class="d-flex justify-content-between align-items-start mb-3 gap-2 flex-wrap">
      <div>
        <div class="d-flex align-items-center gap-2 mb-1">
          <h1 class="h4 mb-0"><%= event.label %></h1>
          <% if (event.status === 'active') { %>
            <span class="badge text-bg-success">Active</span>
          <% } else if (event.status === 'completed') { %>
            <span class="badge text-bg-dark">Completed</span>
          <% } else { %>
            <span class="badge text-bg-secondary">Draft</span>
          <% } %>
        </div>
        <p class="text-muted small mb-0"><%= event.location %></p>
      </div>
      <div class="d-flex gap-2 flex-wrap">
        <% if (event.status === 'draft') { %>
          <% if (event.is_paid) { %>
            <form action="<%= tenantPath(`/admin/events/${event.id}/activate`) %>" method="post">
              <button class="btn btn-sm btn-outline-success" type="submit">Set Active</button>
            </form>
          <% } else { %>
            <span class="badge text-bg-warning text-dark align-self-center" title="A super admin must approve this event before it can be activated">
              <i class="fa-solid fa-clock me-1"></i>Awaiting Approval
            </span>
          <% } %>
        <% } else if (event.status === 'active') { %>
          <form action="<%= tenantPath(`/admin/events/${event.id}/complete`) %>" method="post"
            onsubmit="return confirm('Mark this event as completed? Scoring will be locked.')">
            <button class="btn btn-sm btn-outline-dark" type="submit">Mark Completed</button>
          </form>
        <% } %>
        <a href="<%= tenantPath(`/admin/events/${event.id}/setup`) %>" class="btn btn-sm btn-outline-dark">
          <i class="fa-solid fa-sliders me-1"></i>Setup
        </a>
        <a href="<%= tenantPath(`/admin/events/${event.id}/tee-times`) %>" class="btn btn-sm btn-outline-dark">
          <i class="fa-solid fa-clock me-1"></i>Tee Times
        </a>
        <% if (event.status !== 'completed') { %>
          <button type="button" class="btn btn-sm btn-outline-dark" data-bs-toggle="modal" data-bs-target="#editEventModal">
            <i class="fa-solid fa-pen me-1"></i>Edit
          </button>
        <% } %>
        <a href="<%= tenantPath('/admin') %>" class="btn btn-sm btn-outline-secondary">
          <i class="fa-solid fa-arrow-left me-1"></i>Back
        </a>
      </div>
    </div>

    <% if (message) { %><div class="alert alert-success"><%= message %></div><% } %>
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

    <%# Days %>
    <section class="card border-0 shadow-sm mb-3">
      <div class="card-body border-bottom d-flex justify-content-between align-items-center">
        <h2 class="h6 mb-0">
          Days
          <span class="badge text-bg-light border ms-1"><%= activeDayCount %> playing</span>
        </h2>
      </div>
      <div class="card-body">
        <% if (!courses.length) { %>
          <div class="alert alert-warning mb-0">
            No courses configured for this tour. <a href="<%= tenantPath('/admin/courses') %>">Add a course</a> before configuring days.
          </div>
        <% } else { %>
          <div class="row g-3">
            <% days.forEach(({ day, status, course, isRestDay, date, teeGroupCount, firstTeeTime }) => { %>
              <%
                const dayLabel = date
                  ? date.toLocaleDateString('en-AU', { weekday: 'short', day: 'numeric', month: 'short', timeZone: 'UTC' })
                  : null;
              %>
              <div class="col-12 col-md-6 col-xl-3">
                <% if (isRestDay) { %>
                  <div class="border rounded p-3 h-100 bg-light opacity-75">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <div>
                        <h3 class="h6 mb-0 text-muted">Day <%= day %></h3>
                        <% if (dayLabel) { %><p class="small text-muted mb-0"><%= dayLabel %></p><% } %>
                      </div>
                      <span class="badge text-bg-secondary">Rest Day</span>
                    </div>
                    <p class="small text-muted mb-3">Not a playing round.</p>
                    <form action="<%= tenantPath(`/admin/events/${event.id}/days/${day}/unmark-rest`) %>" method="post" class="mt-auto">
                      <button type="submit" class="btn btn-sm btn-outline-secondary d-block w-100">
                        <i class="fa-solid fa-rotate-left me-1"></i>Restore as Playing Day
                      </button>
                    </form>
                  </div>
                <% } else { %>
                  <div class="border rounded p-3 h-100">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <div>
                        <h3 class="h6 mb-0">Day <%= day %></h3>
                        <% if (dayLabel) { %><p class="small text-muted mb-0"><%= dayLabel %></p><% } %>
                      </div>
                      <% if (status) { %>
                        <%
                          const statusBadge = status.status === 'open' ? 'text-bg-success'
                            : status.status === 'closed' ? 'text-bg-secondary'
                            : 'text-bg-warning';
                        %>
                        <span class="badge <%= statusBadge %>"><%= status.status %></span>
                      <% } else { %>
                        <span class="badge text-bg-light border">Not configured</span>
                      <% } %>
                    </div>
                    <% if (status && course) { %>
                      <p class="small text-muted mb-1">
                        <i class="fa-solid fa-flag me-1"></i><%= course.course_name %> (<%= course.tee_name %>)
                      </p>
                      <p class="small text-muted mb-2">
                        <i class="fa-solid fa-calculator me-1"></i><%= calcTypeLabels[status.calc_type] || status.calc_type %>
                      </p>
                      <% if (status.two_ball_enabled) { %>
                        <p class="small text-muted mb-2">
                          <i class="fa-solid fa-user-group me-1"></i>2-ball <%= status.two_ball_type === 'aggregate' ? 'Aggregate' : 'Best Ball' %>
                        </p>
                      <% } %>
                      <% if (status.leaderboard_published) { %>
                        <span class="badge text-bg-info text-dark mb-2">Leaderboard Published</span>
                      <% } %>
                    <% } else { %>
                      <p class="small text-muted mb-2">Configure course and format for this day.</p>
                    <% } %>
                    <p class="small mb-2">
                      <i class="fa-solid fa-clock me-1 text-muted"></i>
                      <% if (teeGroupCount > 0) { %>
                        <%
                          const teeDisplay = firstTeeTime
                            ? firstTeeTime.slice(0, 5).replace(/^0/, '')
                            : null;
                        %>
                        <% if (teeDisplay) { %><span class="fw-medium"><%= teeDisplay %></span> &middot; <% } %>
                        <span class="fw-medium"><%= teeGroupCount %></span> tee <%= teeGroupCount === 1 ? 'group' : 'groups' %>
                      <% } else { %>
                        <span class="text-muted">No tee times</span>
                      <% } %>
                    </p>
                    <div class="d-flex gap-2 mt-auto">
                      <a href="<%= tenantPath(`/admin/events/${event.id}/days/${day}`) %>" class="btn btn-sm btn-legends flex-fill">
                        Configure
                      </a>
                      <a href="<%= tenantPath(`/admin/events/${event.id}/tee-times?day=${day}`) %>" class="btn btn-sm btn-outline-dark" title="Tee times">
                        <i class="fa-solid fa-clock"></i>
                      </a>
                      <% if (activeDayCount > 1) { %>
                        <form action="<%= tenantPath(`/admin/events/${event.id}/days/${day}/mark-rest`) %>" method="post"
                          onsubmit="return confirm('Mark Day <%= day %> as a rest day? It will be excluded from scoring and the leaderboard.')">
                          <button type="submit" class="btn btn-sm btn-outline-secondary" title="Mark as rest day">
                            <i class="fa-solid fa-moon"></i>
                          </button>
                        </form>
                      <% } %>
                    </div>
                  </div>
                <% } %>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </section>

    <%# Players %>
    <section class="card border-0 shadow-sm">
      <div class="card-body border-bottom d-flex justify-content-between align-items-center">
        <h2 class="h6 mb-0">Players <span class="badge text-bg-light border ms-1"><%= eventPlayers.length %></span></h2>
        <% if (hasAnyScores) { %>
          <span class="small text-muted">Roster locked after scoring starts</span>
        <% } %>
      </div>

      <% if (!hasAnyScores) { %>
        <div class="card-body border-bottom">
          <% if (availableMembers.length) { %>
            <form action="<%= tenantPath(`/admin/events/${event.id}/players`) %>" method="post" class="row g-2 align-items-end">
              <div class="col-12 col-md-8">
                <label class="form-label small mb-1">Add Player</label>
                <select name="userId" class="form-select form-select-sm" required>
                  <option value="">Select player to add...</option>
                  <% availableMembers.forEach((m) => { %>
                    <option value="<%= m.id %>"><%= m.first_name %> <%= m.last_name %> (<%= m.email %>)</option>
                  <% }) %>
                </select>
              </div>
              <div class="col-12 col-md-4 d-grid">
                <button class="btn btn-sm btn-legends" type="submit">
                  <i class="fa-solid fa-user-plus me-1"></i>Add to Event
                </button>
              </div>
            </form>
          <% } else { %>
            <p class="text-muted small mb-0">
              All tour players are already in this event.
              <a href="<%= tenantPath('/admin/players') %>">Add more players</a> to the tour first.
            </p>
          <% } %>
        </div>
      <% } %>

      <div class="card-body">
        <% if (eventPlayers.length) { %>
          <div class="row g-3">
            <% eventPlayers.forEach((p) => { %>
              <div class="col-12 col-md-6 col-xl-4">
                <article class="border rounded p-3 h-100 bg-white">
                  <div class="d-flex justify-content-between align-items-start gap-2">
                    <div>
                      <h3 class="h6 mb-1">
                        <%= p.first_name %> <%= p.last_name %>
                      </h3>
                      <p class="small text-muted mb-0"><%= p.email %></p>
                    </div>
                    <% if (!hasAnyScores) { %>
                      <div class="d-flex gap-1">
                        <button
                          type="button"
                          class="btn btn-sm btn-outline-dark"
                          data-edit-player-btn
                          data-player-id="<%= p.user_id %>"
                          data-player-name="<%= p.first_name %> <%= p.last_name %>"
                          data-player-handicap="<%= p.playing_handicap != null ? parseFloat(p.playing_handicap) : '' %>"
                          title="Edit"
                        >
                          <i class="fa-solid fa-pen-to-square"></i>
                        </button>
                        <form action="<%= tenantPath(`/admin/events/${event.id}/players/${p.user_id}/delete`) %>" method="post" onsubmit="return confirm('Remove this player from the event?')">
                          <button type="submit" class="btn btn-sm btn-outline-danger" title="Remove">
                            <i class="fa-solid fa-trash"></i>
                          </button>
                        </form>
                      </div>
                    <% } %>
                  </div>
                  <div class="mt-2 d-flex flex-wrap gap-2">
                    <span class="badge text-bg-light border">Handicap: <%= p.playing_handicap != null ? parseFloat(p.playing_handicap) : '—' %></span>
                  </div>
                </article>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <p class="text-muted mb-0">No players in this event yet.</p>
        <% } %>
      </div>
    </section>
  </main>

  <%# Edit Event Modal %>
  <div class="modal fade" id="editEventModal" tabindex="-1" aria-labelledby="editEventModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h2 class="modal-title fs-5" id="editEventModalLabel">Edit Event</h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <form action="<%= tenantPath(`/admin/events/${event.id}`) %>" method="post">
          <div class="modal-body">
            <div class="row g-3">
              <div class="col-12 col-md-6">
                <label class="form-label">Event Name</label>
                <input type="text" name="label" class="form-control" value="<%= event.label %>" required />
              </div>
              <div class="col-12 col-md-2">
                <label class="form-label">Year</label>
                <input type="number" name="year" class="form-control" value="<%= event.year %>" required />
              </div>
              <div class="col-12 col-md-4">
                <label class="form-label">Location</label>
                <input type="text" name="location" class="form-control" value="<%= event.location %>" required />
              </div>
              <div class="col-6">
                <label class="form-label">Start Date</label>
                <input type="date" name="startDate" class="form-control" value="<%= event.start_date ? String(event.start_date).slice(0,10) : '' %>" required />
              </div>
              <div class="col-6">
                <label class="form-label">End Date</label>
                <input type="date" name="endDate" class="form-control" value="<%= event.end_date ? String(event.end_date).slice(0,10) : '' %>" required />
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-legends">Save Changes</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <%# Edit Player Modal %>
  <% if (!hasAnyScores) { %>
    <div class="modal fade" id="editPlayerModal" tabindex="-1" aria-labelledby="editPlayerModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <form id="editPlayerForm" method="post">
            <div class="modal-header">
              <h2 class="modal-title fs-6" id="editPlayerModalLabel">Edit Player</h2>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
              <p class="small text-muted mb-3" id="editPlayerName"></p>
              <div class="mb-3">
                <label class="form-label">Playing Handicap</label>
                <input type="number" name="playingHandicap" id="editPlayerHandicap" min="-10" max="54" step="0.1" class="form-control" />
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" class="btn btn-legends">Save</button>
            </div>
          </form>
        </div>
      </div>
    </div>
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const modal = new bootstrap.Modal(document.getElementById('editPlayerModal'));
        const form = document.getElementById('editPlayerForm');
        const nameEl = document.getElementById('editPlayerName');
        const handicapEl = document.getElementById('editPlayerHandicap');
        document.querySelectorAll('[data-edit-player-btn]').forEach(function (btn) {
          btn.addEventListener('click', function () {
            const uid = btn.dataset.playerId;
            nameEl.textContent = btn.dataset.playerName;
            handicapEl.value = btn.dataset.playerHandicap;
            form.action = '<%= tenantPath(`/admin/events/${event.id}/players/`) %>' + uid + '/update';
            modal.show();
          });
        });
      });
    </script>
  <% } %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
</body>
</html>
