<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> | ForeScore</title>
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="theme-color" content="#215463" />
  <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
  <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
</head>
<body>
  <%- include('../partials/nav') %>
  <main class="container py-3 py-md-4" style="max-width:860px">

    <div class="d-flex justify-content-between align-items-start mb-3">
      <div>
        <h1 class="h5 mb-0">Tee Times</h1>
        <p class="text-muted small mb-0"><%= tour.label %></p>
      </div>
      <a href="<%= tenantPath(`/admin/tours/${tour.id}`) %>" class="btn btn-sm btn-outline-secondary">
        <i class="fa-solid fa-arrow-left me-1"></i>Back
      </a>
    </div>

    <% if (message) { %><div class="alert alert-success"><%= message %></div><% } %>
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

    <%# Round sub-nav %>
    <ul class="nav nav-pills mb-4 border-bottom pb-2">
      <% allRoundNumbers.forEach((rn) => { %>
        <li class="nav-item">
          <a href="<%= tenantPath(`/admin/tours/${tour.id}/tee-times?round=${rn}`) %>"
             class="nav-link <%= rn === roundNumber ? 'active' : '' %>">
            Round <%= rn %>
          </a>
        </li>
      <% }) %>
      <% if (round && round.status !== 'draft') { %>
        <li class="nav-item ms-auto">
          <a href="<%= tenantPath(`/admin/tours/${tour.id}/rounds/${roundNumber}/scores`) %>" class="nav-link text-muted">
            <i class="fa-solid fa-list-ol me-1"></i>Scores
          </a>
        </li>
      <% } %>
    </ul>

    <%
      const isLocked = round && round.status !== 'draft';
      const twoBall = round && round.two_ball_enabled;
      const twoBallLabel = round && round.two_ball_type === 'aggregate' ? 'Aggregate' : 'Best ball';
    %>

    <% if (!round) { %>
      <div class="alert alert-warning">Round <%= roundNumber %> is not configured yet.
        <a href="<%= tenantPath(`/admin/tours/${tour.id}/rounds/${roundNumber}`) %>">Configure it</a> before setting up tee times.</div>
    <% } else { %>

    <% if (isLocked) { %>
      <div class="alert alert-info mb-3">
        <i class="fa-solid fa-lock me-1"></i>Scoring is <strong><%= round.status %></strong> — tee groups are locked.
      </div>
    <% } %>

    <% if (isTestTenant && round && round.status === 'open') { %>
      <div class="alert alert-warning py-2 d-flex justify-content-between align-items-center mb-3">
        <span class="small"><i class="fa-solid fa-flask me-1"></i>Test environment</span>
        <div class="d-flex gap-2">
          <form action="<%= tenantPath(`/admin/tours/${tour.id}/rounds/${roundNumber}/unsubmit-scores`) %>" method="post"
                onsubmit="return confirm('Unsubmit all submitted scorecards for this round?')">
            <button class="btn btn-sm btn-outline-warning">Unsubmit all</button>
          </form>
          <form action="<%= tenantPath(`/admin/tours/${tour.id}/rounds/${roundNumber}/seed-scores`) %>" method="post"
                onsubmit="return confirm('Seed random scores for all players in this round? Existing scores will be overwritten.')">
            <button class="btn btn-sm btn-warning">Seed scores</button>
          </form>
        </div>
      </div>
    <% } %>

    <%# Course + format strip %>
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-body py-2 d-flex flex-wrap gap-3 small text-muted">
        <span>
          <i class="fa-solid fa-golf-ball-tee fa-fw me-1"></i>
          <% if (course) { %>
            <strong class="text-body"><%= course.course_name %></strong> &mdash; <%= course.tee_name %>
            <% if (course.slope_rating) { %>&nbsp; Slope <%= course.slope_rating %> · Rating <%= course.course_rating %> · Par <%= coursePar %><% } %>
          <% } else { %>No course set<% } %>
        </span>
        <span><i class="fa-solid fa-list-check fa-fw me-1"></i><%= round.calc_type %></span>
        <% if (twoBall) { %>
          <span><i class="fa-solid fa-people-arrows fa-fw me-1"></i>2-ball: <%= twoBallLabel %></span>
        <% } %>
      </div>
    </div>

    <div class="row g-4">

      <%# ── Tee groups column ────────────────────────────────────────── %>
      <div class="col-12 col-md-7">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <h2 class="h6 mb-0">Groups (<%= groups.length %>)</h2>
          <% if (!isLocked) { %>
            <div class="d-flex gap-2">
              <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#generateModal">
                <i class="fa-solid fa-wand-magic-sparkles me-1"></i>Generate
              </button>
              <button class="btn btn-sm btn-legends" data-bs-toggle="modal" data-bs-target="#addGroupModal">
                <i class="fa-solid fa-plus me-1"></i>Add group
              </button>
            </div>
          <% } %>
        </div>

        <% if (!groups.length) { %>
          <p class="text-muted small">No groups yet. Add one manually or use Generate.</p>
        <% } %>

        <% groups.forEach((g) => { %>
          <div class="card border-0 shadow-sm mb-3">
            <div class="card-body py-2 px-3 border-bottom d-flex justify-content-between align-items-center gap-2">
              <span class="fw-semibold small">
                Group <%= g.group_number %>
                <span class="text-muted fw-normal">&nbsp;·&nbsp; <%= g.tee_time %> &nbsp;·&nbsp; Hole <%= g.starting_hole %></span>
              </span>
              <% if (!isLocked) { %>
                <div class="d-flex gap-1 flex-shrink-0">
                  <button class="btn btn-sm btn-outline-secondary py-0 px-2"
                    data-bs-toggle="modal" data-bs-target="#editGroupModal"
                    data-group-id="<%= g.id %>"
                    data-tee-time="<%= g.tee_time %>"
                    data-starting-hole="<%= g.starting_hole %>"
                    data-tee-location="<%= g.tee_location || '' %>">
                    <i class="fa-solid fa-pen-to-square fa-sm"></i>
                  </button>
                  <form action="<%= tenantPath(`/admin/tours/${tour.id}/tee-times/${g.id}/delete`) %>" method="post"
                        onsubmit="return confirm('Delete this group and unassign all players?')">
                    <button class="btn btn-sm btn-outline-danger py-0 px-2">
                      <i class="fa-solid fa-trash fa-sm"></i>
                    </button>
                  </form>
                </div>
              <% } %>
            </div>
            <ul class="list-group list-group-flush">
              <% if (!g.players.length) { %>
                <li class="list-group-item text-muted small py-1 px-3">No players assigned</li>
              <% } %>
              <% g.players.forEach((p, idx) => {
                const pData = players.find((pl) => pl.user_id === Number(p.user_id));
                const pairBadge = twoBall ? (idx < 2 ? 'A' : 'B') : null;
              %>
                <li class="list-group-item py-2 px-3">
                  <div class="d-flex justify-content-between align-items-center">
                    <span class="small">
                      <% if (pairBadge) { %>
                        <span class="badge text-bg-secondary me-1"><%= pairBadge %></span>
                      <% } %>
                      <%= p.first_name %> <%= p.last_name %>
                      <% if (pData) { %>
                        <% if (pData.courseHandicap !== null) { %>
                          <span class="badge text-bg-light border ms-1">Hcp <%= pData.courseHandicap %></span>
                        <% } else if (pData.effectiveHandicapIndex !== null) { %>
                          <span class="badge text-bg-light border ms-1">Idx <%= pData.effectiveHandicapIndex %></span>
                        <% } %>
                        <% if (pData.dayHandicapOverride !== null) { %>
                          <span class="badge text-bg-warning ms-1" title="Round handicap override">Override</span>
                        <% } %>
                        <% if (!isLocked) { %>
                          <button class="btn btn-link btn-sm py-0 px-1 text-muted"
                            data-bs-toggle="collapse"
                            data-bs-target="#hcpEdit<%= p.user_id %>"
                            aria-expanded="false"
                            title="Edit round handicap">
                            <i class="fa-solid fa-pen fa-xs"></i>
                          </button>
                        <% } %>
                      <% } %>
                    </span>
                    <% if (!isLocked) { %>
                      <form action="<%= tenantPath(`/admin/tours/${tour.id}/tee-times/${g.id}/players/${p.user_id}/remove`) %>" method="post">
                        <button class="btn btn-sm btn-outline-danger border-0 py-0 px-1">
                          <i class="fa-solid fa-xmark fa-sm"></i>
                        </button>
                      </form>
                    <% } %>
                  </div>
                  <% if (!isLocked && pData) { %>
                    <div class="collapse mt-1" id="hcpEdit<%= p.user_id %>">
                      <form action="<%= tenantPath(`/admin/tours/${tour.id}/players/${p.user_id}/round-handicap`) %>" method="post"
                            class="d-flex gap-1 align-items-center flex-wrap mb-1">
                        <input type="hidden" name="roundNumber" value="<%= roundNumber %>" />
                        <input type="number" name="handicapIndex" class="form-control form-control-sm"
                          style="width:90px" step="0.1" min="-10" max="54"
                          value="<%= pData.dayHandicapOverride !== null ? pData.dayHandicapOverride : (pData.eventHandicapIndex !== null ? pData.eventHandicapIndex : '') %>"
                          placeholder="Index" />
                        <button class="btn btn-sm btn-legends">Save</button>
                      </form>
                      <% if (pData.dayHandicapOverride !== null) { %>
                        <form action="<%= tenantPath(`/admin/tours/${tour.id}/players/${p.user_id}/round-handicap`) %>" method="post">
                          <input type="hidden" name="roundNumber" value="<%= roundNumber %>" />
                          <input type="hidden" name="handicapIndex" value="" />
                          <button class="btn btn-sm btn-outline-secondary">Remove override</button>
                        </form>
                      <% } %>
                    </div>
                  <% } %>
                </li>
              <% }) %>
            </ul>
          </div>
        <% }) %>
      </div>

      <%# ── Players column (unassigned + handicap overrides) ──────── %>
      <div class="col-12 col-md-5">
        <% const unassigned = players.filter((p) => !p.assigned); %>

        <h2 class="h6 mb-2">Unassigned (<%= unassigned.length %>)</h2>
        <% if (!unassigned.length) { %>
          <p class="text-muted small">All players are in a group.</p>
        <% } %>
        <% unassigned.forEach((p) => { %>
          <div class="card border-0 shadow-sm mb-2">
            <div class="card-body py-2 px-3">
              <div class="d-flex justify-content-between align-items-center mb-1">
                <span class="small fw-semibold"><%= p.name %></span>
                <% const availableGroups = groups.filter((g) => g.players.length < 4); %>
                <% if (!isLocked && availableGroups.length) { %>
                  <button class="btn btn-sm btn-outline-secondary py-0 px-2"
                    data-bs-toggle="modal" data-bs-target="#assignModal"
                    data-user-id="<%= p.user_id %>"
                    data-player-name="<%= p.name %>">
                    Assign
                  </button>
                <% } else if (!isLocked && groups.length) { %>
                  <span class="text-muted small">All full</span>
                <% } %>
              </div>
              <%- include('./partials/player-hcp-row', { p, tourId: tour.id, roundNumber, isLocked }) %>
            </div>
          </div>
        <% }) %>

      </div>
    </div>

    <% if (noveltyEvents && noveltyEvents.length) { %>
    <div class="card border-0 shadow-sm mt-4">
      <div class="card-body border-bottom">
        <h2 class="h6 mb-0"><i class="fa-solid fa-flag fa-fw me-1 text-muted"></i>Novelty Results</h2>
      </div>
      <div class="card-body">
        <form action="<%= tenantPath(`/admin/tours/${tour.id}/rounds/${roundNumber}/novelties/results`) %>" method="post">
          <% noveltyEvents.forEach((ne) => {
            const result = noveltyResultsByEventId && noveltyResultsByEventId[ne.id];
            const currentWinnerId = result && !result.is_no_winner ? result.winner_user_id : null;
          %>
            <div class="mb-3">
              <label class="form-label small fw-semibold">
                <%= ne.label %>
                <span class="text-muted fw-normal ms-1">Hole <%= ne.hole_number %></span>
              </label>
              <select name="winner_<%= ne.id %>" class="form-select form-select-sm">
                <option value="">— Not yet recorded —</option>
                <option value="no_winner" <%= result && result.is_no_winner ? 'selected' : '' %>>No winner</option>
                <% players.forEach((p) => { %>
                  <option value="<%= p.user_id %>" <%= Number(currentWinnerId) === p.user_id ? 'selected' : '' %>><%= p.name %></option>
                <% }) %>
              </select>
            </div>
          <% }) %>
          <button type="submit" class="btn btn-sm btn-legends">Save results</button>
        </form>
      </div>
    </div>
    <% } %>
    <% } %>
  </main>

  <%# ── Modals ───────────────────────────────────────────────────────── %>

  <%# Add group %>
  <div class="modal fade" id="addGroupModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
      <div class="modal-content">
        <form action="<%= tenantPath(`/admin/tours/${tour.id}/tee-times`) %>" method="post">
          <input type="hidden" name="roundNumber" value="<%= roundNumber %>" />
          <div class="modal-header">
            <h5 class="modal-title h6">Add Group</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <div class="mb-3">
              <label class="form-label small">Tee time</label>
              <input type="time" name="teeTime" class="form-control form-control-sm" value="08:00" required />
            </div>
            <div class="mb-3">
              <label class="form-label small">Starting hole</label>
              <select name="startingHole" class="form-select form-select-sm">
                <% for (let h = 1; h <= 18; h++) { %>
                  <option value="<%= h %>" <%= h === 1 ? 'selected' : '' %>><%= h %></option>
                <% } %>
              </select>
            </div>
            <div>
              <label class="form-label small">Location label <span class="text-muted">(optional, e.g. 1A)</span></label>
              <input type="text" name="teeLocation" class="form-control form-control-sm" />
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-sm btn-legends">Add</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <%# Edit group %>
  <div class="modal fade" id="editGroupModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
      <div class="modal-content">
        <form id="editGroupForm" method="post">
          <div class="modal-header">
            <h5 class="modal-title h6">Edit Group</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <div class="mb-3">
              <label class="form-label small">Tee time</label>
              <input type="time" name="teeTime" id="editTeeTime" class="form-control form-control-sm" required />
            </div>
            <div class="mb-3">
              <label class="form-label small">Starting hole</label>
              <select name="startingHole" id="editStartingHole" class="form-select form-select-sm">
                <% for (let h = 1; h <= 18; h++) { %>
                  <option value="<%= h %>"><%= h %></option>
                <% } %>
              </select>
            </div>
            <div>
              <label class="form-label small">Location label</label>
              <input type="text" name="teeLocation" id="editTeeLocation" class="form-control form-control-sm" />
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-sm btn-legends">Save</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <%# Assign player to group %>
  <div class="modal fade" id="assignModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
      <div class="modal-content">
        <form action="<%= tenantPath(`/admin/tours/${tour.id}/tee-times/assign`) %>" method="post">
          <div class="modal-header">
            <h5 class="modal-title h6">Assign <span id="assignPlayerName"></span></h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <input type="hidden" name="userIds" id="assignUserId" />
            <label class="form-label small">Group</label>
            <select name="groupId" class="form-select form-select-sm">
              <% groups.filter((g) => g.players.length < 4).forEach((g) => { %>
                <option value="<%= g.id %>">
                  Group <%= g.group_number %> — <%= g.tee_time %>, Hole <%= g.starting_hole %> (<%= g.players.length %>/4)
                </option>
              <% }) %>
            </select>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-sm btn-legends">Assign</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <%# Generate groups %>
  <% if (round && !isLocked) { %>
  <div class="modal fade" id="generateModal" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <form action="<%= tenantPath(`/admin/tours/${tour.id}/tee-times/generate`) %>" method="post"
          onsubmit="return !<%= groups.length %> || confirm('This will replace all existing groups for Round <%= roundNumber %>. Continue?')">
          <input type="hidden" name="roundNumber" value="<%= roundNumber %>" />
          <div class="modal-header">
            <h5 class="modal-title h6">Generate Groups — Round <%= roundNumber %></h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <div class="mb-4">
              <label class="form-label fw-semibold">Strategy</label>
              <div class="form-check mb-2">
                <input class="form-check-input" type="radio" name="strategy" id="strategyDistribute" value="distribute" checked />
                <label class="form-check-label" for="strategyDistribute">
                  <strong>Mix up partners</strong>
                  <span class="d-block small text-muted">Minimise repeat playing partners from all previous days</span>
                </label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="strategy" id="strategyLeaderboard" value="leaderboard" />
                <label class="form-check-label" for="strategyLeaderboard">
                  <strong>Reverse leaderboard</strong>
                  <span class="d-block small text-muted">Lowest-placed players go out first, leaders go out last</span>
                </label>
              </div>
            </div>
            <div class="row g-3">
              <div class="col-4">
                <label class="form-label small">First tee time</label>
                <input type="time" name="startTime" class="form-control form-control-sm" value="08:00" />
              </div>
              <div class="col-4">
                <label class="form-label small">Starting hole</label>
                <select name="startingHole" class="form-select form-select-sm">
                  <% for (let h = 1; h <= 18; h++) { %>
                    <option value="<%= h %>" <%= h === 1 ? 'selected' : '' %>><%= h %></option>
                  <% } %>
                </select>
              </div>
              <div class="col-4">
                <label class="form-label small">Gap (mins)</label>
                <input type="number" name="gapMinutes" class="form-control form-control-sm" value="10" min="5" max="60" />
              </div>
            </div>
            <%
              const genSizes = groupSizes(players.length);
              const genSummary = genSizes.join(' + ') || '—';
            %>
            <p class="text-muted small mt-3 mb-0">
              <%= players.length %> players → <%= genSizes.length %> groups (<%= genSummary %>)
            </p>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-sm btn-legends">Generate</button>
          </div>
        </form>
      </div>
    </div>
  </div>
  <% } %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  <script>
    document.getElementById('editGroupModal').addEventListener('show.bs.modal', function (e) {
      const btn = e.relatedTarget;
      const form = document.getElementById('editGroupForm');
      form.action = '<%= tenantPath(`/admin/tours/${tour.id}/tee-times/`) %>' + btn.dataset.groupId + '/update';
      document.getElementById('editTeeTime').value = btn.dataset.teeTime;
      document.getElementById('editStartingHole').value = btn.dataset.startingHole;
      document.getElementById('editTeeLocation').value = btn.dataset.teeLocation || '';
    });

    const assignModal = document.getElementById('assignModal');
    if (assignModal) {
      assignModal.addEventListener('show.bs.modal', function (e) {
        const btn = e.relatedTarget;
        document.getElementById('assignPlayerName').textContent = btn.dataset.playerName;
        document.getElementById('assignUserId').value = btn.dataset.userId;
      });
    }
  </script>
</body>
</html>
