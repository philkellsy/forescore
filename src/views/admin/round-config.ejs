<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> | ForeScore</title>
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="theme-color" content="#215463" />
  <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
  <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
</head>
<body>
  <%- include('../partials/nav') %>
  <main class="container py-3 py-md-4" style="max-width:640px">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1 class="h5 mb-0">
          Round <%= roundNumber %> Configuration
          <% if (round && round.tour_date) { %>
            <span class="text-muted fw-normal fs-6 ms-1">
              &mdash; <%= new Date(round.tour_date).toLocaleDateString('en-AU', { weekday: 'short', day: 'numeric', month: 'short', timeZone: 'UTC' }) %>
            </span>
          <% } %>
        </h1>
        <p class="text-muted small mb-0"><%= tour.label %></p>
      </div>
      <div class="d-flex gap-2">
        <% if (round) { %>
          <a href="<%= tenantPath(`/admin/tours/${tour.id}/rounds/${roundNumber}/results`) %>" class="btn btn-sm btn-outline-primary">
            <i class="fa-solid fa-chart-bar me-1"></i>Results
          </a>
        <% } %>
        <a href="<%= tenantPath(`/admin/tours/${tour.id}`) %>" class="btn btn-sm btn-outline-secondary">
          <i class="fa-solid fa-arrow-left me-1"></i>Back
        </a>
      </div>
    </div>

    <% if (message) { %><div class="alert alert-success"><%= message %></div><% } %>
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

    <% const primaryCourses = tour.gender === 'womens' ? womensCourses : mensCourses; %>
    <% if (!primaryCourses.length) { %>
      <div class="alert alert-warning">
        No <%= tour.gender === 'womens' ? "women's" : "men's" %> courses configured.
        <a href="<%= tenantPath('/admin/courses') %>" target="_blank">Add a course</a> first.
      </div>
    <% } else { %>
      <%
        const ambrosePrizes = round && round.ambrose_prizes
          ? (Array.isArray(round.ambrose_prizes)
              ? round.ambrose_prizes
              : JSON.parse(round.ambrose_prizes || '[]'))
          : [];
        const isAmbrose = round && round.calc_type === 'ambrose_nett';
      %>
      <form id="roundConfigForm" action="<%= tenantPath(`/admin/tours/${tour.id}/rounds/${roundNumber}`) %>" method="post">
        <div class="card border-0 shadow-sm mb-4">
          <div class="card-body">
            <div class="mb-3">
              <label class="form-label">Date</label>
              <%
                const defaultDate = round && round.tour_date ? String(round.tour_date).slice(0, 10) : '';
              %>
              <input type="date" name="tourDate" class="form-control" value="<%= defaultDate %>" />
            </div>

            <div class="mb-3">
              <div class="d-flex justify-content-between align-items-baseline mb-1">
                <label class="form-label mb-0"><%= tour.gender === 'mixed' ? "Men's Course" : "Course" %></label>
                <a href="<%= tenantPath('/admin/courses') %>" target="_blank" class="small text-muted">
                  <i class="fa-solid fa-arrow-up-right-from-square me-1" style="font-size:.7rem"></i>Manage courses
                </a>
              </div>
              <select name="courseId" class="form-select" required>
                <option value="">Select course...</option>
                <% primaryCourses.forEach((c) => { %>
                  <option value="<%= c.id %>" <%= round && round.course_id === c.id ? 'selected' : '' %>>
                    <%= c.course_name %> — <%= c.tee_name %>
                  </option>
                <% }) %>
              </select>
            </div>

            <% if (tour.gender === 'mixed') { %>
              <div class="mb-3">
                <div class="d-flex justify-content-between align-items-baseline mb-1">
                  <label class="form-label mb-0">Women's Course</label>
                  <a href="<%= tenantPath('/admin/courses') %>" target="_blank" class="small text-muted">
                    <i class="fa-solid fa-arrow-up-right-from-square me-1" style="font-size:.7rem"></i>Manage courses
                  </a>
                </div>
                <select name="femaleCourseId" class="form-select">
                  <option value="">Select course...</option>
                  <% womensCourses.forEach((c) => { %>
                    <option value="<%= c.id %>" <%= round && round.female_course_id === c.id ? 'selected' : '' %>>
                      <%= c.course_name %> — <%= c.tee_name %>
                    </option>
                  <% }) %>
                </select>
              </div>
            <% } %>

            <div class="mb-3">
              <label class="form-label">Format</label>
              <select name="calcType" id="calcTypeSelect" class="form-select">
                <% calcTypes.forEach(([value, label]) => { %>
                  <option value="<%= value %>" <%= round && round.calc_type === value ? 'selected' : '' %>>
                    <%= label %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="mb-3">
              <label class="form-label">Scoring Status</label>
              <select name="status" id="roundStatusSelect" class="form-select"
                      data-current-status="<%= round?.status || 'draft' %>">
                <option value="draft" <%= !round || round.status === 'draft' ? 'selected' : '' %>>Draft — not visible to players</option>
                <option value="open" <%= round && round.status === 'open' ? 'selected' : '' %>>Open — players can enter scores</option>
                <option value="closed" <%= round && round.status === 'closed' ? 'selected' : '' %>>Closed — scoring locked</option>
              </select>
            </div>
            <input type="hidden" name="confirmDeleteScores" id="confirmDeleteScores" value="">

            <div class="form-check mb-2">
              <input type="checkbox" name="leaderboardPublished" id="leaderboardPublished" class="form-check-input" value="1"
                <%= round && round.leaderboard_published ? 'checked' : '' %> />
              <label class="form-check-label" for="leaderboardPublished">Publish leaderboard to players</label>
            </div>
            <div id="showInProgressRow" class="form-check mb-3 ms-3<%= round && round.leaderboard_published ? '' : ' d-none' %>">
              <input type="checkbox" name="showInProgress" id="showInProgress" class="form-check-input" value="1"
                <%= round && round.leaderboard_show_in_progress ? 'checked' : '' %> />
              <label class="form-check-label small" for="showInProgress">Show in-progress players on the published leaderboard, final score hidden until submitted</label>
            </div>

            <hr class="my-3" />
            <h2 class="h6 mb-3"><i class="fa-solid fa-people-group fa-fw me-1 text-muted"></i>Virtual Teams</h2>
            <div class="form-check mb-2">
              <input type="checkbox" name="virtualTeamsEnabled" id="virtualTeamsEnabled" class="form-check-input" value="1"
                <%= round && round.virtual_teams_enabled ? 'checked' : '' %> />
              <label class="form-check-label" for="virtualTeamsEnabled">Include virtual team results for this round</label>
            </div>
            <p class="text-muted small mb-0">Teams are configured on the tour page. Results show average stableford score per team.</p>

            <hr class="my-3" />
            <h2 class="h6 mb-3"><i class="fa-solid fa-people-arrows fa-fw me-1 text-muted"></i>2-Ball Competition</h2>
            <div class="form-check mb-2">
              <input type="checkbox" name="twoBallEnabled" id="twoBallEnabled" class="form-check-input" value="1"
                <%= round && round.two_ball_enabled ? 'checked' : '' %> />
              <label class="form-check-label" for="twoBallEnabled">Play a 2-ball competition alongside the main format</label>
            </div>
            <div id="twoBallTypeRow" style="display:<%= round && round.two_ball_enabled ? '' : 'none' %>">
              <label class="form-label small">2-Ball type</label>
              <select name="twoBallType" class="form-select form-select-sm" style="max-width:220px">
                <option value="best_ball" <%= round && round.two_ball_type === 'best_ball' ? 'selected' : '' %>>Best ball (lower score counts)</option>
                <option value="aggregate" <%= round && round.two_ball_type === 'aggregate' ? 'selected' : '' %>>Aggregate (sum of both scores)</option>
              </select>
              <p class="text-muted small mt-1 mb-0">Partners are positions 1+2 and 3+4 within each tee group.</p>
            </div>
          </div>
        </div>

        <%# Ambrose prizes — shown only when format is Ambrose %>
        <div class="card border-0 shadow-sm mb-4" id="ambrosePrizesCard" style="display:<%= isAmbrose ? '' : 'none' %>">
          <div class="card-body border-bottom">
            <h2 class="h6 mb-0"><i class="fa-solid fa-users fa-fw me-1 text-muted"></i>Ambrose Round Prizes</h2>
          </div>
          <div class="card-body">
            <p class="small text-muted mb-3">Cash prizes for the ambrose team result on this round.</p>
            <div id="ambrosePrizeRows">
              <% ambrosePrizes.forEach((p) => { %>
                <div class="row g-2 align-items-center mb-2 prize-row">
                  <div class="col-5 col-sm-4">
                    <input type="text" name="ambrose_prize_label[]" class="form-control form-control-sm"
                      placeholder="e.g. 1st" value="<%= p.label %>" />
                  </div>
                  <div class="col-5 col-sm-5">
                    <div class="input-group input-group-sm">
                      <span class="input-group-text">$</span>
                      <input type="number" name="ambrose_prize_amount[]" class="form-control"
                        min="0" step="1" value="<%= Number(p.amount || 0).toFixed(0) %>" />
                    </div>
                  </div>
                  <div class="col-2 col-sm-3">
                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="removePrizeRow(this)">
                      <i class="fa-solid fa-trash"></i>
                    </button>
                  </div>
                </div>
              <% }) %>
            </div>
            <button type="button" class="btn btn-sm btn-outline-secondary mt-2"
              onclick="addAmbroseRow()">
              <i class="fa-solid fa-plus me-1"></i>Add Place
            </button>
          </div>
        </div>

        <div class="d-grid">
          <button type="submit" class="btn btn-legends">Save Round <%= roundNumber %> Config</button>
        </div>
      </form>
      <% if (round && round.status === 'draft') { %>
        <div class="mt-3 d-grid">
          <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#deleteRoundModal">
            Delete Round <%= roundNumber %>
          </button>
        </div>
      <% } %>
    <% } %>

    <% if (round) { %>
    <div class="card border-0 shadow-sm mb-4 mt-4">
      <div class="card-body border-bottom">
        <h2 class="h6 mb-0"><i class="fa-solid fa-flag fa-fw me-1 text-muted"></i>Novelty Events</h2>
      </div>
      <div class="card-body">
        <% if (noveltyEvents.length) { %>
          <div class="mb-3">
            <% noveltyEvents.forEach((ne) => { %>
              <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                <div class="small">
                  <span class="badge text-bg-secondary me-2"><%= ne.novelty_type %></span>
                  <strong><%= ne.label %></strong>
                  <span class="text-muted ms-2">Hole <%= ne.hole_number %></span>
                </div>
                <form action="<%= tenantPath(`/admin/tours/${tour.id}/rounds/${roundNumber}/novelties/${ne.id}/delete`) %>" method="post">
                  <button class="btn btn-sm btn-outline-danger border-0 py-0 px-1" title="Remove">
                    <i class="fa-solid fa-trash fa-sm"></i>
                  </button>
                </form>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <p class="text-muted small mb-3">No novelty events added yet.</p>
        <% } %>
        <form action="<%= tenantPath(`/admin/tours/${tour.id}/rounds/${roundNumber}/novelties`) %>" method="post" class="row g-2 align-items-end">
          <div class="col-5 col-sm-3">
            <label class="form-label small mb-1">Type</label>
            <select name="noveltyType" class="form-select form-select-sm">
              <option value="NTP">NTP</option>
              <option value="Long Drive">Long Drive</option>
            </select>
          </div>
          <div class="col-4 col-sm-2">
            <label class="form-label small mb-1">Hole</label>
            <select name="holeNumber" class="form-select form-select-sm">
              <% for (let h = 1; h <= 18; h++) { %><option value="<%= h %>"><%= h %></option><% } %>
            </select>
          </div>
          <div class="col-12 col-sm-4">
            <label class="form-label small mb-1">Label <span class="text-muted">(optional)</span></label>
            <input type="text" name="label" class="form-control form-control-sm" placeholder="e.g. Men's NTP" />
          </div>
          <div class="col-12 col-sm-3">
            <button type="submit" class="btn btn-sm btn-outline-secondary w-100">
              <i class="fa-solid fa-plus me-1"></i>Add
            </button>
          </div>
        </form>
      </div>
      <% if (noveltyEvents.length && noveltyPlayers && noveltyPlayers.length) { %>
        <div class="card-body border-top">
          <h3 class="h6 mb-3">Results</h3>
          <form action="<%= tenantPath(`/admin/tours/${tour.id}/rounds/${roundNumber}/novelties/results`) %>" method="post" class="row g-3">
            <% noveltyEvents.forEach((ne) => {
              const result = noveltyResultsByEventId && noveltyResultsByEventId[ne.id];
              const currentWinnerId = result && !result.is_no_winner ? Number(result.winner_user_id) : null;
            %>
              <div class="col-12 col-sm-6">
                <label class="form-label small fw-semibold mb-1">
                  <%= ne.label %>
                  <span class="text-muted fw-normal ms-1">Hole <%= ne.hole_number %></span>
                </label>
                <select name="winner_<%= ne.id %>" class="form-select form-select-sm">
                  <option value="">— Not yet recorded —</option>
                  <option value="no_winner" <%= result && result.is_no_winner ? 'selected' : '' %>>No winner</option>
                  <% noveltyPlayers.forEach((p) => { %>
                    <option value="<%= p.user_id %>" <%= currentWinnerId === Number(p.user_id) ? 'selected' : '' %>><%= `${p.first_name || ''} ${p.last_name || ''}`.trim() %></option>
                  <% }) %>
                </select>
              </div>
            <% }) %>
            <div class="col-12">
              <button type="submit" class="btn btn-sm btn-outline-secondary">Save results</button>
            </div>
          </form>
        </div>
      <% } %>
    </div>
    <% } %>

    <% if (isTestTenant && round && round.status === 'open') { %>
    <div class="alert alert-warning py-2 d-flex justify-content-between align-items-center mt-4">
      <span class="small"><i class="fa-solid fa-flask me-1"></i>Test environment</span>
      <div class="d-flex gap-2">
        <form action="<%= tenantPath(`/admin/tours/${tour.id}/rounds/${roundNumber}/unsubmit-scores`) %>" method="post"
              onsubmit="return confirm('Unsubmit all submitted scorecards for this round?')">
          <input type="hidden" name="returnTo" value="round-config" />
          <button class="btn btn-sm btn-outline-warning">Unsubmit all</button>
        </form>
        <form action="<%= tenantPath(`/admin/tours/${tour.id}/rounds/${roundNumber}/seed-scores`) %>" method="post"
              onsubmit="return confirm('Seed random scores for all players in this round? Existing scores will be overwritten.')">
          <input type="hidden" name="returnTo" value="round-config" />
          <button class="btn btn-sm btn-warning">Seed scores</button>
        </form>
      </div>
    </div>
    <% } %>
  </main>

  <% if (round && round.status === 'draft') { %>
  <div class="modal fade" id="deleteRoundModal" tabindex="-1" aria-labelledby="deleteRoundModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
      <div class="modal-content">
        <div class="modal-header border-0 pb-0">
          <h5 class="modal-title text-danger" id="deleteRoundModalLabel">
            <i class="fa-solid fa-triangle-exclamation me-1"></i>Delete Round <%= roundNumber %>?
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body pt-2">
          <p class="small text-muted mb-0">This will permanently remove the round and all associated tee groups. This cannot be undone.</p>
        </div>
        <div class="modal-footer border-0 pt-0">
          <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <form action="<%= tenantPath(`/admin/tours/${tour.id}/rounds/${roundNumber}/delete`) %>" method="post" class="m-0">
            <button type="submit" class="btn btn-sm btn-danger">Delete Round</button>
          </form>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <div class="modal fade" id="deleteScoresModal" tabindex="-1" aria-labelledby="deleteScoresModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
      <div class="modal-content">
        <div class="modal-header border-0 pb-0">
          <h5 class="modal-title text-danger" id="deleteScoresModalLabel">
            <i class="fa-solid fa-triangle-exclamation me-1"></i>Delete scores?
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body pt-2">
          <p class="small mb-2" id="deleteScoresSummary"></p>
          <p class="small text-muted mb-0">Reverting to Draft cannot be undone.</p>
        </div>
        <div class="modal-footer border-0 pt-0">
          <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-sm btn-danger" id="confirmDeleteAndSave">Delete &amp; revert to Draft</button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  <script>
    const ORDINALS = ['1st','2nd','3rd','4th','5th','6th','7th','8th','9th','10th'];
    const calcTypeSelect = document.getElementById('calcTypeSelect');
    const ambrosePrizesCard = document.getElementById('ambrosePrizesCard');

    const twoBallToggle = document.getElementById('twoBallEnabled');
    const twoBallTypeRow = document.getElementById('twoBallTypeRow');
    twoBallToggle.addEventListener('change', () => {
      twoBallTypeRow.style.display = twoBallToggle.checked ? '' : 'none';
    });

    const publishToggle = document.getElementById('leaderboardPublished');
    const showInProgressRow = document.getElementById('showInProgressRow');
    const showInProgressCheck = document.getElementById('showInProgress');
    publishToggle.addEventListener('change', () => {
      showInProgressRow.classList.toggle('d-none', !publishToggle.checked);
      if (!publishToggle.checked) showInProgressCheck.checked = false;
    });

    function syncAmbroseCard() {
      ambrosePrizesCard.style.display = calcTypeSelect.value === 'ambrose_nett' ? '' : 'none';
    }
    calcTypeSelect.addEventListener('change', syncAmbroseCard);

    function addAmbroseRow() {
      const container = document.getElementById('ambrosePrizeRows');
      const idx = container.querySelectorAll('.prize-row').length;
      const label = ORDINALS[idx] || (idx + 1) + 'th';
      const row = document.createElement('div');
      row.className = 'row g-2 align-items-center mb-2 prize-row';
      row.innerHTML = `
        <div class="col-5 col-sm-4">
          <input type="text" name="ambrose_prize_label[]" class="form-control form-control-sm"
            placeholder="e.g. ${label}" value="${label}" />
        </div>
        <div class="col-5 col-sm-5">
          <div class="input-group input-group-sm">
            <span class="input-group-text">$</span>
            <input type="number" name="ambrose_prize_amount[]" class="form-control"
              min="0" step="1" value="0" />
          </div>
        </div>
        <div class="col-2 col-sm-3">
          <button type="button" class="btn btn-sm btn-outline-danger" onclick="removePrizeRow(this)">
            <i class="fa-solid fa-trash"></i>
          </button>
        </div>`;
      container.appendChild(row);
      row.querySelector('input[type="number"]').focus();
    }

    function removePrizeRow(btn) {
      btn.closest('.prize-row').remove();
    }

    // Intercept form submit — check for open→draft transition
    const roundForm = document.getElementById('roundConfigForm');
    if (roundForm) {
    const statusSelect = document.getElementById('roundStatusSelect');
    const confirmDeleteScoresInput = document.getElementById('confirmDeleteScores');
    const scoreCountUrl = '<%= tenantPath(`/admin/tours/${tour.id}/rounds/${roundNumber}/score-count`) %>';

    function getDeleteScoresModal() {
      return bootstrap.Modal.getOrCreateInstance(document.getElementById('deleteScoresModal'));
    }

    document.getElementById('confirmDeleteAndSave').addEventListener('click', () => {
      confirmDeleteScoresInput.value = '1';
      getDeleteScoresModal().hide();
      roundForm.submit();
    });

    roundForm.addEventListener('submit', async (e) => {
      const currentStatus = statusSelect.dataset.currentStatus;
      const newStatus = statusSelect.value;
      if (currentStatus === 'open' && newStatus === 'draft' && confirmDeleteScoresInput.value !== '1') {
        e.preventDefault();
        try {
          const resp = await fetch(scoreCountUrl);
          const data = await resp.json();
          if (data.holesScored > 0 || data.playersScored > 0) {
            document.getElementById('deleteScoresSummary').textContent =
              `This will permanently delete scores for ${data.playersScored} player${data.playersScored !== 1 ? 's' : ''} (${data.holesScored} hole score${data.holesScored !== 1 ? 's' : ''}).`;
            getDeleteScoresModal().show();
          } else {
            confirmDeleteScoresInput.value = '1';
            roundForm.submit();
          }
        } catch {
          confirmDeleteScoresInput.value = '1';
          roundForm.submit();
        }
      }
    });
    } // end if (roundForm)
  </script>
</body>
</html>
