<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> | ForeScore</title>
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="theme-color" content="#215463" />
  <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
  <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
</head>
<body>
  <%- include('../partials/nav') %>
  <main class="container py-3 py-md-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1 class="h4 mb-0">Admin</h1>
        <p class="text-muted small mb-0"><%= tenant.name %></p>
      </div>
      <div class="d-flex gap-2">
        <a href="<%= tenantPath('/admin/courses') %>" class="btn btn-outline-dark btn-sm">
          <i class="fa-solid fa-flag me-1"></i>Courses
        </a>
        <a href="<%= tenantPath('/admin/players') %>" class="btn btn-outline-dark btn-sm">
          <i class="fa-solid fa-users me-1"></i>Players
        </a>
        <% if (user.isSuperAdmin) { %>
          <a href="<%= tenantPath('/admin/session-logs') %>" class="btn btn-outline-dark btn-sm">
            <i class="fa-solid fa-clock-rotate-left me-1"></i>Session Logs
          </a>
        <% } %>
      </div>
    </div>

    <% if (message) { %><div class="alert alert-success"><%= message %></div><% } %>
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

    <section class="card border-0 shadow-sm">
      <div class="card-body border-bottom d-flex justify-content-between align-items-center">
        <h2 class="h6 mb-0">Tours</h2>
        <button type="button" class="btn btn-sm btn-legends" data-bs-toggle="modal" data-bs-target="#createTourModal">
          <i class="fa-solid fa-plus me-1"></i>Create Tour
        </button>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Name</th>
                <th>Year</th>
                <th>Location</th>
                <th>Status</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% tours.forEach((tour) => { %>
                <tr>
                  <td><strong><%= tour.label %></strong></td>
                  <td><%= tour.year %></td>
                  <td class="text-muted small"><%= tour.location %></td>
                  <td>
                    <% if (tour.status === 'active') { %>
                      <span class="badge text-bg-success">Active</span>
                    <% } else if (tour.status === 'completed') { %>
                      <span class="badge text-bg-dark">Completed</span>
                    <% } else { %>
                      <span class="badge text-bg-secondary">Draft</span>
                      <% if (!tour.is_paid) { %>
                        <span class="badge text-bg-warning text-dark ms-1" title="Awaiting payment approval from super admin">Awaiting Approval</span>
                      <% } %>
                    <% } %>
                  </td>
                  <td class="text-end">
                    <a class="btn btn-sm btn-outline-dark" href="<%= tenantPath(`/admin/tours/${tour.id}`) %>">Manage</a>
                  </td>
                </tr>
              <% }) %>
              <% if (!tours.length) { %>
                <tr><td colspan="5" class="text-muted py-3 text-center">No tours yet — create one to get started.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </section>
  </main>

  <%# Create Tour Modal %>
  <div class="modal fade" id="createTourModal" tabindex="-1" aria-labelledby="createTourModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h2 class="modal-title fs-5" id="createTourModalLabel">Create Tour</h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <form action="<%= tenantPath('/admin/tours') %>" method="post">
          <div class="modal-body">
            <div class="row g-3">
              <div class="col-12 col-md-6">
                <label class="form-label">Tour Name</label>
                <input type="text" name="label" class="form-control" placeholder="e.g. ForeScore 2026" required />
              </div>
              <div class="col-12 col-md-2">
                <label class="form-label">Year</label>
                <input type="number" name="year" min="2000" max="2100" class="form-control" value="<%= new Date().getFullYear() %>" required />
              </div>
              <div class="col-12 col-md-4">
                <label class="form-label">Location</label>
                <input type="text" name="location" class="form-control" required />
              </div>
              <div class="col-12 col-md-4">
                <label class="form-label">Competition</label>
                <select name="gender" class="form-select">
                  <option value="mens">Men's</option>
                  <option value="womens">Women's</option>
                  <option value="mixed">Mixed</option>
                </select>
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-legends">Create Tour</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
</body>
</html>
