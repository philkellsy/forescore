<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | Legends</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#0e5135" />
    <link rel="icon" type="image/png" href="/img/icons/icon-192.png?v=<%= assetVersion %>" />
    <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container py-3 py-md-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h4 mb-0">Admin Dashboard</h1>
      </div>

      <% if (message) { %>
        <div class="alert alert-success"><%= message %></div>
      <% } %>
      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <section class="card border-0 shadow-sm mb-4">
        <div class="card-body border-bottom d-flex justify-content-between align-items-center">
          <h2 class="h6 mb-0">Events</h2>
          <div class="d-flex gap-2">
            <% if (Number(user?.id || 0) === 1) { %>
              <a class="btn btn-outline-warning btn-sm" href="/admin/test-data" target="_blank">Test Data</a>
            <% } %>
            <a class="btn btn-outline-dark btn-sm" href="/admin/courses">Courses</a>
            <button type="button" class="btn btn-legends btn-sm" data-bs-toggle="modal" data-bs-target="#createEventModal">Create Event</button>
          </div>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th>Year</th>
                  <th>Location</th>
                  <th>Dates</th>
                  <th>Courses</th>
                  <th>Status</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% events.forEach((event) => { %>
                  <tr>
                    <td><%= event.year %></td>
                    <td><%= event.location %></td>
                    <td><%= event.start_date %> to <%= event.end_date %></td>
                    <td><span class="badge text-bg-light border"><%= Number(event.courses_count || 0) %></span></td>
                    <td>
                      <% if (Number(event.is_active) === 1) { %>
                        <span class="badge text-bg-success">Active</span>
                      <% } else { %>
                        <span class="badge text-bg-secondary">Inactive</span>
                      <% } %>
                    </td>
                    <td>
                      <% if (Number(event.is_active) === 1) { %>
                        <a class="btn btn-sm btn-outline-dark" href="/admin/events/<%= event.id %>">Manage Event</a>
                      <% } else { %>
                        <a class="btn btn-sm btn-outline-primary" href="/leaderboards/event/<%= event.id %>">Leaderboards</a>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
                <% if (!events.length) { %>
                  <tr><td colspan="6" class="text-muted">No events created yet.</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <section class="card border-0 shadow-sm">
        <div class="card-body d-flex justify-content-between align-items-center">
          <div>
            <h2 class="h6 mb-1">Players</h2>
            <p class="text-muted mb-0">Create and edit players, roles, and previous winner flags.</p>
          </div>
          <a class="btn btn-legends" href="/admin/players">Manage Players</a>
        </div>
      </section>

      <div class="modal fade" id="createEventModal" tabindex="-1" aria-labelledby="createEventModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
          <div class="modal-content">
            <div class="modal-header">
              <h2 class="modal-title fs-5" id="createEventModalLabel">Create Event</h2>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="/admin/events" method="post">
              <div class="modal-body">
                <div class="row g-3">
                  <div class="col-12 col-md-3">
                    <label class="form-label">Year</label>
                    <input type="number" name="year" min="2000" max="2100" class="form-control" required />
                  </div>
                  <div class="col-12 col-md-5">
                    <label class="form-label">Location</label>
                    <input type="text" name="location" class="form-control" value="Bonville International Golf Resort" required />
                  </div>
                  <div class="col-6 col-md-2">
                    <label class="form-label">Start</label>
                    <input type="date" name="startDate" class="form-control" required />
                  </div>
                  <div class="col-6 col-md-2">
                    <label class="form-label">End</label>
                    <input type="date" name="endDate" class="form-control" required />
                  </div>
                  <div class="col-12">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" name="isActive" id="isActiveEvent" checked />
                      <label class="form-check-label" for="isActiveEvent">Set as active event</label>
                    </div>
                  </div>
                </div>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-legends">Create Event</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </main>
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  </body>
</html>
