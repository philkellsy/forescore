<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> | ForeScore</title>
  <meta name="theme-color" content="#215463" />
  <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
  <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
</head>
<body>
  <%- include('../partials/nav') %>
  <main class="container py-3 py-md-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h1 class="h4 mb-0">Import Course</h1>
      <a class="btn btn-outline-secondary btn-sm" href="<%= tenantPath('/admin/courses') %>">Back to Courses</a>
    </div>

    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

    <% if (!hasApiKey) { %>
      <div class="alert alert-warning">
        <strong>API key not configured.</strong>
        Set the <code>GOLF_COURSE_API_KEY</code> environment variable to enable course search.
        You can still <a href="<%= tenantPath('/admin/courses') %>" class="alert-link">add courses manually</a>.
      </div>
    <% } %>

    <%# BlueGolf paste section %>
    <section class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-transparent">
        <h2 class="h6 mb-0">Paste from BlueGolf</h2>
      </div>
      <div class="card-body">
        <p class="text-muted small mb-2">Copy the scorecard table from BlueGolf (select from the Tee row through to the Hcp row) and paste below.</p>
        <textarea id="bluegolfInput" class="form-control form-control-sm font-monospace mb-2" rows="5" placeholder="Tee&#9;1&#9;2&#9;3&#9;...&#10;yds&#9;503&#9;387&#9;...&#10;Par&#9;5&#9;4&#9;4&#9;...&#10;Hcp&#9;13&#9;9&#9;3&#9;..."></textarea>
        <div id="bluegolfError" class="alert alert-danger py-2 small d-none"></div>
        <button type="button" class="btn btn-sm btn-outline-secondary" id="bluegolfParseBtn">Parse</button>
      </div>
    </section>

    <section class="card border-0 shadow-sm mb-3 <%= !hasApiKey ? 'opacity-50 pe-none' : '' %>">
      <div class="card-body">
        <h2 class="h6 text-muted mb-3">Step 1 — Search for a course</h2>
        <div class="input-group">
          <input type="text" id="searchInput" class="form-control" placeholder="e.g. Royal Melbourne" />
          <button class="btn btn-legends" id="searchBtn" type="button">Search</button>
        </div>
        <div id="searchSpinner" class="text-muted small mt-2 d-none">Searching…</div>
        <div id="searchError" class="alert alert-danger mt-2 d-none"></div>
      </div>
    </section>

    <section class="card border-0 shadow-sm mb-3 d-none" id="resultsSection">
      <div class="card-body">
        <h2 class="h6 text-muted mb-3">Step 2 — Select a course</h2>
        <div class="table-responsive">
          <table class="table table-sm table-hover align-middle mb-0">
            <thead>
              <tr><th>Club</th><th>Course</th><th>Location</th><th></th></tr>
            </thead>
            <tbody id="resultsBody"></tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="card border-0 shadow-sm mb-3 d-none" id="teesSection">
      <div class="card-body">
        <h2 class="h6 text-muted mb-3">Step 3 — Select a tee</h2>
        <div class="row g-2" id="teesGrid"></div>
      </div>
    </section>

    <section class="card border-0 shadow-sm d-none" id="previewSection">
      <div class="card-body">
        <h2 class="h6 text-muted mb-3">Step 4 — Preview &amp; confirm</h2>
        <form method="post" action="<%= tenantPath('/admin/courses/import') %>" id="importForm">
          <input type="hidden" name="apiCourseId" id="fApiCourseId" />
          <input type="hidden" name="apiTeeName" id="fApiTeeName" />
          <input type="hidden" name="gender" id="fGender" />
          <input type="hidden" name="holesJson" id="fHolesJson" />
          <input type="hidden" name="courseRating" id="fCourseRating" />
          <input type="hidden" name="slopeRating" id="fSlopeRating" />

          <div class="row g-3 mb-3">
            <div class="col-12 col-md-6">
              <label class="form-label fw-semibold">Course Name</label>
              <input type="text" name="courseName" id="fCourseName" class="form-control" required />
            </div>
            <div class="col-6 col-md-3">
              <label class="form-label fw-semibold">Tee Name</label>
              <input type="text" name="teeName" id="previewTee" class="form-control" required />
            </div>
            <div class="col-6 col-md-3">
              <label class="form-label fw-semibold">Gender</label>
              <input type="text" id="previewGender" class="form-control" disabled />
            </div>
            <div class="col-4 col-md-2">
              <label class="form-label fw-semibold">Par</label>
              <input type="text" id="previewPar" class="form-control" disabled />
            </div>
            <div class="col-4 col-md-2">
              <label class="form-label fw-semibold">Course Rating</label>
              <input type="text" id="previewCourseRating" class="form-control" disabled />
            </div>
            <div class="col-4 col-md-2">
              <label class="form-label fw-semibold">Slope</label>
              <input type="text" id="previewSlopeRating" class="form-control" disabled />
            </div>
          </div>

          <p class="text-muted small mb-2">Yardage converted to metres. SI Secondary defaults to SI Primary + 18 — edit after import if needed. Fill in Course Name, Tee Name and ratings before confirming.</p>

          <div class="table-responsive mb-3">
            <table class="table table-sm align-middle mb-0">
              <thead>
                <tr><th>Hole</th><th>Par</th><th>Metres</th><th>SI Primary</th><th>SI Secondary</th></tr>
              </thead>
              <tbody id="previewBody"></tbody>
            </table>
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-legends">Import Course</button>
            <button type="button" class="btn btn-outline-secondary" id="resetBtn">Start Over</button>
          </div>
        </form>
      </div>
    </section>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  <script>
    const SEARCH_URL = '<%= tenantPath("/admin/courses/import/search") %>';
    const COURSE_URL = '<%= tenantPath("/admin/courses/import/course/") %>';
    let selectedCourse = null;

    document.getElementById('searchBtn').addEventListener('click', runSearch);
    document.getElementById('searchInput').addEventListener('keydown', e => { if (e.key === 'Enter') runSearch(); });

    async function runSearch() {
      const q = document.getElementById('searchInput').value.trim();
      if (!q) return;
      setStep(1);
      document.getElementById('searchSpinner').classList.remove('d-none');
      document.getElementById('searchError').classList.add('d-none');
      try {
        const res = await fetch(SEARCH_URL + '?q=' + encodeURIComponent(q));
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Search failed');
        renderResults(data.courses || []);
      } catch (err) {
        showSearchError(err.message);
      } finally {
        document.getElementById('searchSpinner').classList.add('d-none');
      }
    }

    function renderResults(courses) {
      const tbody = document.getElementById('resultsBody');
      tbody.innerHTML = '';
      if (!courses.length) {
        tbody.innerHTML = '<tr><td colspan="4" class="text-muted">No courses found.</td></tr>';
      } else {
        courses.forEach(c => {
          const loc = [c.location?.city, c.location?.state, c.location?.country].filter(Boolean).join(', ');
          const tr = document.createElement('tr');
          tr.style.cursor = 'pointer';
          tr.innerHTML = `<td>${esc(c.club_name)}</td><td>${esc(c.course_name)}</td><td>${esc(loc)}</td><td><button class="btn btn-sm btn-outline-dark">Select</button></td>`;
          tr.querySelector('button').addEventListener('click', () => selectCourse(c));
          tbody.appendChild(tr);
        });
      }
      document.getElementById('resultsSection').classList.remove('d-none');
    }

    function selectCourse(course) {
      selectedCourse = course;
      const grid = document.getElementById('teesGrid');
      grid.innerHTML = '';
      document.getElementById('previewSection').classList.add('d-none');
      const allTees = [
        ...((course.tees?.male || []).map(t => ({ ...t, gender: 'male' }))),
        ...((course.tees?.female || []).map(t => ({ ...t, gender: 'female' })))
      ];
      if (!allTees.length) {
        grid.innerHTML = '<div class="col text-muted">No tee data available.</div>';
      } else {
        allTees.forEach(tee => {
          const col = document.createElement('div');
          col.className = 'col-12 col-sm-6 col-md-4 col-lg-3';
          const badge = tee.gender === 'female' ? ' <span class="badge bg-secondary">Ladies</span>' : '';
          const ratings = tee.course_rating ? ` &bull; CR ${tee.course_rating} / ${tee.slope_rating}` : '';
          col.innerHTML = `
            <button type="button" class="btn btn-outline-dark w-100 text-start" style="white-space:normal">
              <strong>${esc(tee.tee_name)}</strong>${badge}<br>
              <span class="text-muted small">Par ${tee.par_total} &bull; ${tee.total_meters}m${ratings}</span>
            </button>`;
          col.querySelector('button').addEventListener('click', () => selectTee(tee));
          grid.appendChild(col);
        });
      }
      document.getElementById('teesSection').classList.remove('d-none');
      document.getElementById('teesSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function selectTee(tee) {
      document.getElementById('fApiCourseId').value = selectedCourse.id;
      document.getElementById('fApiTeeName').value = tee.tee_name;
      document.getElementById('fGender').value = tee.gender;
      document.getElementById('fHolesJson').value = JSON.stringify(tee.holes || []);
      document.getElementById('fCourseRating').value = tee.course_rating || '';
      document.getElementById('fSlopeRating').value = tee.slope_rating || '';
      document.getElementById('fCourseName').value = selectedCourse.club_name;
      document.getElementById('previewTee').value = tee.tee_name;
      document.getElementById('previewGender').value = tee.gender === 'female' ? 'Female' : 'Male';
      document.getElementById('previewPar').value = tee.par_total || '';
      document.getElementById('previewCourseRating').value = tee.course_rating || '—';
      document.getElementById('previewSlopeRating').value = tee.slope_rating || '—';

      const tbody = document.getElementById('previewBody');
      tbody.innerHTML = '';
      (tee.holes || []).slice(0, 18).forEach((h, i) => {
        const metres = h.yardage ? Math.round(h.yardage * 0.9144) : '—';
        const siP = h.handicap || (i + 1);
        const tr = document.createElement('tr');
        tr.innerHTML = `<td>${i + 1}</td><td>${h.par}</td><td>${metres}</td><td>${siP}</td><td>${siP + 18}</td>`;
        tbody.appendChild(tr);
      });

      document.getElementById('previewSection').classList.remove('d-none');
      document.getElementById('previewSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function setStep(step) {
      if (step <= 1) {
        document.getElementById('resultsSection').classList.add('d-none');
        document.getElementById('teesSection').classList.add('d-none');
        document.getElementById('previewSection').classList.add('d-none');
        selectedCourse = null;
      }
    }

    function showSearchError(msg) {
      const el = document.getElementById('searchError');
      el.textContent = msg;
      el.classList.remove('d-none');
    }

    function esc(str) {
      return String(str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    document.getElementById('resetBtn').addEventListener('click', () => {
      setStep(1);
      document.getElementById('searchInput').value = '';
      document.getElementById('searchInput').focus();
    });

    // ── BlueGolf paste parser ──
    document.getElementById('bluegolfParseBtn').addEventListener('click', () => {
      const errEl = document.getElementById('bluegolfError');
      errEl.classList.add('d-none');
      try {
        const holes = parseBlueGolf(document.getElementById('bluegolfInput').value);
        populatePreviewFromPaste(holes);
      } catch (e) {
        errEl.textContent = e.message;
        errEl.classList.remove('d-none');
      }
    });

    function parseBlueGolf(raw) {
      const lines = raw.trim().split(/\r?\n/).map(l => l.trim()).filter(Boolean);
      if (lines.length < 3) throw new Error('Paste must include at least the Par and Hcp rows');

      // Split each line — prefer tabs, fall back to 2+ spaces
      function splitRow(line) {
        return line.includes('\t')
          ? line.split('\t').map(c => c.trim())
          : line.split(/  +/).map(c => c.trim());
      }

      const rowMap = {};
      let headerCells = null;
      for (const line of lines) {
        const cells = splitRow(line);
        const label = cells[0].toLowerCase().replace(/\./g, '');
        if (!headerCells && (cells[1] === '1' || cells.slice(1, 10).every(c => /^\d+$/.test(c)))) {
          headerCells = cells;
        } else if (label === 'yds' || label === 'yards' || label === 'metres' || label === 'meters') {
          rowMap.yds = cells;
        } else if (label === 'par') {
          rowMap.par = cells;
        } else if (label === 'hcp' || label === 'handicap' || label === 'si') {
          rowMap.hcp = cells;
        }
      }

      if (!rowMap.par) throw new Error('Could not find a Par row — make sure the row starts with "Par"');
      if (!rowMap.hcp) throw new Error('Could not find a Hcp row — make sure the row starts with "Hcp" or "Handicap"');

      // Determine column indices for holes 1-18 by skipping Out/In/Tot
      const SKIP = new Set(['out', 'in', 'tot', 'total', '']);
      let holeColumns = [];
      if (headerCells) {
        for (let i = 1; i < headerCells.length; i++) {
          const v = headerCells[i].toLowerCase();
          if (SKIP.has(v)) continue;
          const n = parseInt(headerCells[i], 10);
          if (Number.isFinite(n) && n >= 1 && n <= 18) holeColumns.push({ col: i, hole: n });
          if (holeColumns.length === 18) break;
        }
      }
      // Fallback: assume standard BlueGolf layout (cols 1-9 = holes 1-9, col 10 = Out, cols 11-19 = holes 10-18)
      if (holeColumns.length !== 18) {
        holeColumns = [];
        for (let h = 1; h <= 9; h++) holeColumns.push({ col: h, hole: h });
        for (let h = 10; h <= 18; h++) holeColumns.push({ col: h + 1, hole: h });
      }
      if (holeColumns.length !== 18) throw new Error('Could not identify 18 holes in the pasted data');

      const holes = holeColumns.map(({ col, hole }) => {
        const par = parseInt(rowMap.par[col], 10);
        const hcp = parseInt(rowMap.hcp[col], 10);
        const yds = rowMap.yds ? parseInt(rowMap.yds[col], 10) : NaN;
        if (!Number.isFinite(par) || par < 3 || par > 5) throw new Error(`Invalid par at hole ${hole}: "${rowMap.par[col]}"`);
        if (!Number.isFinite(hcp) || hcp < 1 || hcp > 18) throw new Error(`Invalid handicap at hole ${hole}: "${rowMap.hcp[col]}"`);
        return { holeNumber: hole, par, handicap: hcp, yardage: Number.isFinite(yds) && yds > 0 ? yds : null };
      });

      const hcpsSorted = holes.map(h => h.handicap).sort((a, b) => a - b);
      if (hcpsSorted.some((v, i) => v !== i + 1)) throw new Error('Handicap values are not unique 1–18 — check the pasted data');

      return holes;
    }

    function populatePreviewFromPaste(holes) {
      // Clear API-specific hidden fields
      document.getElementById('fApiCourseId').value = '';
      document.getElementById('fApiTeeName').value = '';
      document.getElementById('fGender').value = 'male';

      // holesJson uses same format as API import: { par, handicap, yardage }
      document.getElementById('fHolesJson').value = JSON.stringify(holes.map(h => ({ par: h.par, handicap: h.handicap, yardage: h.yardage })));
      document.getElementById('fCourseRating').value = '';
      document.getElementById('fSlopeRating').value = '';

      // Reset editable fields
      document.getElementById('fCourseName').value = '';
      document.getElementById('previewTee').value = '';
      document.getElementById('previewGender').value = 'Male';
      const totalPar = holes.reduce((s, h) => s + h.par, 0);
      document.getElementById('previewPar').value = totalPar;
      document.getElementById('previewCourseRating').value = '—';
      document.getElementById('previewSlopeRating').value = '—';

      const tbody = document.getElementById('previewBody');
      tbody.innerHTML = '';
      holes.forEach(h => {
        const metres = h.yardage ? Math.round(h.yardage * 0.9144) : '—';
        const tr = document.createElement('tr');
        tr.innerHTML = `<td>${h.holeNumber}</td><td>${h.par}</td><td>${metres}</td><td>${h.handicap}</td><td>${h.handicap + 18}</td>`;
        tbody.appendChild(tr);
      });

      document.getElementById('previewSection').classList.remove('d-none');
      document.getElementById('previewSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  </script>
</body>
</html>
