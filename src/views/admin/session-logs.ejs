<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> | ForeScore</title>
  <meta name="theme-color" content="#215463" />
  <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
  <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
</head>
<body>
  <%- include('../partials/nav') %>
  <main class="container py-3 py-md-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <div>
        <h1 class="h4 mb-0">Session Logs</h1>
        <p class="text-muted small mb-0"><%= tenant.name %></p>
      </div>
      <a href="<%= tenantPath('/admin') %>" class="btn btn-outline-secondary btn-sm">Back</a>
    </div>

    <% if (message) { %><div class="alert alert-success"><%= message %></div><% } %>
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

    <%# Filter bar %>
    <form method="get" action="<%= tenantPath('/admin/session-logs') %>" class="mb-3 d-flex gap-2 align-items-end flex-wrap">
      <div>
        <label class="form-label small mb-1">Filter by member</label>
        <select name="userId" class="form-select form-select-sm" style="min-width:200px">
          <option value="">All members</option>
          <% members.forEach((m) => { %>
            <option value="<%= m.id %>" <%= filterUserId === m.id ? 'selected' : '' %>>
              <%= m.first_name %> <%= m.last_name %> (<%= m.email %>)
            </option>
          <% }) %>
        </select>
      </div>
      <button type="submit" class="btn btn-outline-secondary btn-sm">Filter</button>
      <% if (filterUserId) { %>
        <a href="<%= tenantPath('/admin/session-logs') %>" class="btn btn-link btn-sm text-muted p-0">Clear</a>
      <% } %>
    </form>

    <section class="card border-0 shadow-sm">
      <div class="card-body p-0">
        <% if (logs.length === 0) { %>
          <p class="text-muted text-center py-4 mb-0">No session events found.</p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th class="ps-3">Time</th>
                  <th>Event</th>
                  <th>User</th>
                  <th>IP Address</th>
                  <th class="pe-3">User Agent</th>
                </tr>
              </thead>
              <tbody>
                <% logs.forEach((log) => { %>
                  <tr>
                    <td class="ps-3 text-nowrap small text-muted">
                      <%= new Date(log.created_at).toLocaleString('en-AU', {
                        year: 'numeric', month: 'short', day: 'numeric',
                        hour: '2-digit', minute: '2-digit', second: '2-digit',
                        hour12: false
                      }) %>
                    </td>
                    <td>
                      <% if (log.event === 'login_success') { %>
                        <span class="badge text-bg-success">login_success</span>
                      <% } else if (log.event === 'logout') { %>
                        <span class="badge text-bg-secondary">logout</span>
                      <% } else if (log.event === 'code_invalid') { %>
                        <span class="badge text-bg-warning text-dark">code_invalid</span>
                      <% } else if (log.event === 'no_membership') { %>
                        <span class="badge text-bg-danger">no_membership</span>
                      <% } else { %>
                        <span class="badge text-bg-light text-dark border"><%= log.event %></span>
                      <% } %>
                    </td>
                    <td class="small">
                      <% if (log.first_name) { %>
                        <span class="fw-semibold"><%= log.first_name %> <%= log.last_name %></span>
                        <span class="text-muted ms-1"><%= log.email %></span>
                      <% } else { %>
                        <span class="text-muted">—</span>
                      <% } %>
                    </td>
                    <td class="small text-muted text-nowrap"><%= log.ip_address || '—' %></td>
                    <td class="small text-muted pe-3" style="max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
                        title="<%= log.user_agent || '' %>">
                      <%= log.user_agent || '—' %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <%# Pagination %>
          <%
            const totalPages = Math.ceil(total / pageSize);
            const prevPage   = page > 1 ? page - 1 : null;
            const nextPage   = page < totalPages ? page + 1 : null;
            const pageParam  = (p) => {
              const qs = new URLSearchParams({ page: p });
              if (filterUserId) qs.set('userId', filterUserId);
              return tenantPath('/admin/session-logs') + '?' + qs.toString();
            };
          %>
          <% if (totalPages > 1) { %>
            <div class="d-flex justify-content-between align-items-center px-3 py-2 border-top bg-light">
              <span class="small text-muted">
                Showing <%= (page - 1) * pageSize + 1 %>–<%= Math.min(page * pageSize, total) %> of <%= total %>
              </span>
              <div class="d-flex gap-2">
                <% if (prevPage) { %>
                  <a href="<%= pageParam(prevPage) %>" class="btn btn-outline-secondary btn-sm">
                    <i class="fa-solid fa-chevron-left me-1"></i>Previous
                  </a>
                <% } %>
                <% if (nextPage) { %>
                  <a href="<%= pageParam(nextPage) %>" class="btn btn-outline-secondary btn-sm">
                    Next<i class="fa-solid fa-chevron-right ms-1"></i>
                  </a>
                <% } %>
              </div>
            </div>
          <% } %>
        <% } %>
      </div>
    </section>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
</body>
</html>
