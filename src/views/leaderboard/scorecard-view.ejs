<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | ForeScore</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#215463" />
    <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
    <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container py-3 py-md-4">
      <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
        <div>
          <h1 class="h4 mb-1"><%= title %></h1>
          <% if (pageSubtitle) { %><p class="text-muted mb-0"><%= pageSubtitle %></p><% } %>
        </div>
        <a class="btn btn-outline-secondary btn-sm" href="<%= backUrl %>"><%= backLabel || 'Back To Leaderboards' %></a>
      </div>

      <div class="d-grid gap-3">
        <% (models || []).forEach((model) => { %>
          <% if (model.courseName || model.tourDate) { %>
            <div class="text-muted small">
              <% if (model.dayLabel) { %><strong class="text-dark"><%= model.dayLabel %></strong><% } %>
              <% if (model.courseName) { %><% if (model.dayLabel) { %> &middot; <% } %><%= model.courseName %><% } %>
              <% if (model.tourDate) { %> &middot; <%= new Date(model.tourDate).toLocaleDateString('en-AU', { timeZone: 'UTC', weekday: 'short', day: 'numeric', month: 'short' }) %><% } %>
            </div>
          <% } %>
          <%- include('../partials/scorecard-viewer', { model }) %>
        <% }) %>
      </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  </body>
</html>
