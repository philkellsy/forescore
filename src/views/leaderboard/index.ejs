<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | ForeScore</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#215463" />
    <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
    <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container py-3 py-md-4">
      <h1 class="h4 mb-3">Leaderboards</h1>
      <% if (message) { %>
        <div class="alert alert-success"><%= message %></div>
      <% } %>
      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>
      <% if (!activeTour) { %>
        <div class="alert alert-warning">No active tour configured yet.</div>
      <% } else { %>
        <%
          const publishedByRound = {};
          (roundStates || []).forEach((r) => { publishedByRound[Number(r.roundNumber)] = Boolean(r.leaderboardPublished); });
          const rnList = stablefordRoundNumbers || [];
          const allRoundsPublished = rnList.length > 0 && rnList.every((rn) => publishedByRound[rn]);
          const dayViewRn = activeView && activeView.startsWith('day-') ? Number(activeView.split('-')[1]) : null;
          const activeDayView = dayViewRn ? (dayViews || []).find((d) => d.roundNumber === dayViewRn) : null;
        %>
        <p class="text-muted mb-4"><%= activeTour.year %> at <%= activeTour.location %></p>
        <% if (hasDirtyMarker && canManagePublish) { %>
          <div class="alert alert-warning py-2">Scores changed since last leaderboard build. Results were refreshed just now.</div>
        <% } %>

        <% if (!(dayViews && dayViews.length) && !canManagePublish) { %>
          <div class="alert alert-info mb-3">Leaderboards have not been released yet.</div>
        <% } else { %>

        <%# ── Navigation ──────────────────────────── %>
        <div class="d-flex flex-wrap gap-2 mb-3">
          <% (dayViews || []).forEach((dv) => { %>
            <a class="btn <%= activeView === `day-${dv.roundNumber}` ? 'btn-legends' : 'btn-outline-secondary' %>"
               href="<%= leaderboardBasePath %>?view=day-<%= dv.roundNumber %>">
              <%= dv.label %>
            </a>
          <% }) %>
          <a class="btn <%= activeView === 'championship' ? 'btn-legends' : 'btn-outline-secondary' %>" href="<%= leaderboardBasePath %>?view=championship">Championship</a>
          <% if ((skinsDetail && skinsDetail.length) || (payoutsData && payoutsData.grandTotal > 0)) { %>
            <a class="btn <%= activeView === 'payouts' ? 'btn-legends' : 'btn-outline-secondary' %>" href="<%= leaderboardBasePath %>?view=payouts">Payouts</a>
          <% } %>
        </div>

        <%# ── Day View ────────────────────────────── %>
        <% if (activeDayView) { %>

          <%# Day leaderboard %>
          <section class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
              <h2 class="h6 mb-0"><%= activeDayView.label %> — Stableford</h2>
              <% if (activeDayView.tourDate) { %>
                <span class="text-muted small"><%= new Date(activeDayView.tourDate).toLocaleDateString('en-AU', { weekday: 'long', day: 'numeric', month: 'long', timeZone: 'UTC' }) %></span>
              <% } %>
            </div>
            <% if (!activeDayView.dayBoard || !activeDayView.dayBoard.length) { %>
              <div class="card-body"><p class="text-muted mb-0">No scores recorded yet.</p></div>
            <% } else { %>
              <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                  <thead class="table-light">
                    <tr>
                      <th style="width:3rem">#</th>
                      <th>Player</th>
                      <th class="text-end">Pts</th>
                      <% if (activeDayView.prizes && activeDayView.prizes.length) { %><th>Prize</th><% } %>
                    </tr>
                  </thead>
                  <tbody>
                    <% activeDayView.dayBoard.forEach((row, i) => { %>
                      <% const prize = activeDayView.prizes ? activeDayView.prizes[i] : null; %>
                      <tr class="<%= prize ? 'table-warning' : '' %>">
                        <td class="fw-semibold text-muted"><%= row.position %></td>
                        <td><%- include('../partials/participant-card', { name: row.name, handicapText: '' }) %></td>
                        <td class="text-end fw-semibold"><%= row.total %></td>
                        <% if (activeDayView.prizes && activeDayView.prizes.length) { %>
                          <td>
                            <% if (prize) { %>
                              <span class="badge text-bg-warning text-dark"><%= prize.label %></span>
                              <% if (prize.amount) { %><span class="text-muted small ms-1">$<%= prize.amount %></span><% } %>
                            <% } %>
                          </td>
                        <% } %>
                      </tr>
                    <% }) %>
                    <% if (activeDayView.inProgressPlayers && activeDayView.inProgressPlayers.length) { %>
                      <% activeDayView.inProgressPlayers.forEach((player) => { %>
                        <tr class="text-muted">
                          <td>—</td>
                          <td><%- include('../partials/participant-card', { name: player.name, handicapText: '' }) %></td>
                          <td class="text-end small fst-italic">in progress</td>
                          <% if (activeDayView.prizes && activeDayView.prizes.length) { %><td></td><% } %>
                        </tr>
                      <% }) %>
                    <% } %>
                  </tbody>
                </table>
              </div>
              <% if (activeDayView.prizes && activeDayView.prizes.length) { %>
                <div class="card-footer bg-transparent">
                  <div class="d-flex flex-wrap gap-3">
                    <% activeDayView.prizes.forEach((p) => { %>
                      <span class="small text-muted"><%= p.label %>: <strong>$<%= p.amount %></strong></span>
                    <% }) %>
                  </div>
                </div>
              <% } %>
            <% } %>
          </section>

          <%# Day skins %>
          <section class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent">
              <h2 class="h6 mb-0">Skins — <%= activeDayView.label %></h2>
            </div>
            <% if (!activeDayView.skinsForDay || !activeDayView.skinsForDay.holes.length) { %>
              <div class="card-body"><p class="text-muted mb-0">No skins calculated yet.</p></div>
            <% } else { %>
              <% const skinsDay = activeDayView.skinsForDay; %>
              <% const firstHole = skinsDay.holes[0]; %>
              <% if (firstHole && firstHole.carryIn > 0) { %>
                <div class="card-body border-bottom py-2">
                  <span class="badge text-bg-warning text-dark me-2"><%= firstHole.carryIn %> skin<%= firstHole.carryIn !== 1 ? 's' : '' %> carried in</span>
                  <span class="text-muted small">from the previous round</span>
                </div>
              <% } %>
              <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                  <thead class="table-light">
                    <tr>
                      <th>Hole</th>
                      <th class="text-center">Carry In</th>
                      <th class="text-center">Score</th>
                      <th>Winner</th>
                      <th class="text-center">Skins</th>
                      <th class="text-end">Value</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% skinsDay.holes.forEach((hole) => { %>
                      <tr class="<%= hole.status === 'jackpot' ? 'table-secondary' : '' %>">
                        <td class="fw-semibold"><%= hole.holeNumber %></td>
                        <td class="text-center">
                          <% if (hole.carryIn > 0) { %>
                            <span class="badge text-bg-warning text-dark">+<%= hole.carryIn %></span>
                          <% } else { %>
                            <span class="text-muted">—</span>
                          <% } %>
                        </td>
                        <td class="text-center">
                          <% if (hole.status === 'won' && hole.winningGross != null) { %>
                            <span class="fw-semibold"><%= hole.winningGross %>/<%= hole.winningStableford %> pts</span>
                          <% } else if (hole.topStableford > 0) { %>
                            <span class="text-muted small"><%= hole.topStableford %> pts</span>
                          <% } else { %>
                            <span class="text-muted">—</span>
                          <% } %>
                        </td>
                        <td>
                          <% if (hole.status === 'won' && hole.winnerName) { %>
                            <strong><%= hole.winnerName %></strong>
                          <% } else { %>
                            <span class="text-muted fst-italic">Tied (<%= hole.tiedCount %>)</span>
                          <% } %>
                        </td>
                        <td class="text-center">
                          <% if (hole.status === 'won') { %>
                            <span class="badge text-bg-success"><%= hole.skinsAtStake %></span>
                          <% } else { %>
                            <span class="text-muted">—</span>
                          <% } %>
                        </td>
                        <td class="text-end">
                          <% if (hole.dollarAmount > 0) { %>
                            <span class="fw-semibold text-success">$<%= Math.round(hole.dollarAmount) %></span>
                          <% } else { %>
                            <span class="text-muted">—</span>
                          <% } %>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
              <% if (activeDayView.skinsWinners && activeDayView.skinsWinners.length) { %>
                <div class="card-footer bg-transparent">
                  <% activeDayView.skinsWinners.forEach((w) => { %>
                    <span class="me-3">
                      <strong><%= w.name %></strong>
                      <span class="badge text-bg-success"><%= w.skinsWon %> skin<%= w.skinsWon !== 1 ? 's' : '' %></span>
                      <% if (w.dollarWon > 0) { %><span class="text-success fw-semibold ms-1">$<%= Math.round(w.dollarWon) %></span><% } %>
                    </span>
                  <% }) %>
                  <% const lastHole = skinsDay.holes[skinsDay.holes.length - 1]; %>
                  <% if (lastHole && lastHole.status === 'jackpot') { %>
                    <p class="text-muted small mb-0 mt-2"><strong><%= lastHole.skinsAtStake %> skin<%= lastHole.skinsAtStake !== 1 ? 's' : '' %></strong> carry into the next round.</p>
                  <% } %>
                </div>
              <% } %>
            <% } %>
          </section>

          <%# Day virtual teams %>
          <% if (activeDayView.virtualTeamResults && activeDayView.virtualTeamResults.length) { %>
          <section class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent">
              <h2 class="h6 mb-0">Virtual Teams — <%= activeDayView.label %></h2>
            </div>
            <div class="table-responsive">
              <table class="table table-sm align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th style="width:3rem">#</th>
                    <th>Team</th>
                    <th class="text-end">Total</th>
                    <th class="text-end">Players</th>
                    <th class="text-end">Average</th>
                  </tr>
                </thead>
                <tbody>
                  <% activeDayView.virtualTeamResults.forEach((row) => { %>
                    <tr>
                      <td class="fw-semibold text-muted"><%= row.position %></td>
                      <td><strong><%= row.name %></strong></td>
                      <td class="text-end text-muted"><%= row.total %></td>
                      <td class="text-end text-muted small"><%= row.playerCount %></td>
                      <td class="text-end fw-semibold"><%= row.average %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </section>
          <% } %>

          <%# Day 2-ball %>
          <% if (activeDayView.twoBallEnabled) { %>
          <section class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent">
              <h2 class="h6 mb-0">2-Ball — <%= activeDayView.label %> <span class="badge text-bg-secondary ms-1 fw-normal"><%= activeDayView.twoBallType === 'best_ball' ? 'Best Ball' : 'Aggregate' %></span></h2>
            </div>
            <% if (!activeDayView.twoBallResults || !activeDayView.twoBallResults.length) { %>
              <div class="card-body"><p class="text-muted mb-0">Results available when all scores are submitted.</p></div>
            <% } else { %>
              <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                  <thead class="table-light">
                    <tr>
                      <th style="width:3rem">#</th>
                      <th>Pair</th>
                      <th class="text-end">Pts</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% activeDayView.twoBallResults.forEach((row) => { %>
                      <tr>
                        <td class="fw-semibold text-muted"><%= row.position %></td>
                        <td>
                          <strong><%= row.displayName %></strong>
                          <% if (row.countbackApplied) { %><span class="text-muted small ms-1">cb</span><% } %>
                        </td>
                        <td class="text-end fw-semibold"><%= row.total %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </section>
          <% } %>

          <%# Day novelty events %>
          <% if (activeDayView.noveltyEvents && activeDayView.noveltyEvents.length) { %>
          <section class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent">
              <h2 class="h6 mb-0">Novelty Events — <%= activeDayView.label %></h2>
            </div>
            <div class="table-responsive">
              <table class="table table-sm align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Event</th>
                    <th>Hole</th>
                    <th>Prize</th>
                    <th>Winner</th>
                  </tr>
                </thead>
                <tbody>
                  <% activeDayView.noveltyEvents.forEach((ne) => { %>
                    <tr>
                      <td><span class="badge text-bg-secondary me-1"><%= ne.noveltyType %></span><%= ne.label %></td>
                      <td><%= ne.holeNumber || '—' %></td>
                      <td><% if (ne.prizeAmount) { %><span class="text-success fw-semibold">$<%= ne.prizeAmount %></span><% } else { %><span class="text-muted">—</span><% } %></td>
                      <td>
                        <% if (!ne.result) { %>
                          <span class="text-muted">—</span>
                        <% } else if (ne.result.isNoWinner) { %>
                          <span class="text-muted fst-italic">No winner</span>
                        <% } else { %>
                          <strong><%= ne.result.winnerName || '—' %></strong>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </section>
          <% } %>

        <% } %>

        <%# ── Championship ────────────────────────── %>
        <% if (activeView === 'championship') { %>
          <section class="card border-0 shadow-sm">
            <div class="card-body">
              <h2 class="h6 mb-2">ForeScore Championship</h2>
              <% if (rnList.length) { %>
                <p class="text-muted small mb-3">
                  <%= rnList.map((rn, i) => `R${i + 1} (${dayLabel(rn)})`).join(', ') %>.
                  Ties use countback.<% if (activeTour && activeTour.leaderboard_best_of_rounds) { %> Best <%= activeTour.leaderboard_best_of_rounds %> of <%= rnList.length %> rounds count — dropped round shown as strikethrough.<% } %>
                </p>
              <% } %>
              <% if (!championshipTable.length) { %>
                <p class="text-muted mb-0"><%= canManagePublish ? 'No scores entered yet.' : 'Not released yet.' %></p>
              <% } else { %>
                <div class="table-responsive">
                  <table class="table table-sm align-middle mb-0">
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>Player</th>
                        <% rnList.forEach((rn, i) => { %><th>R<%= i + 1 %></th><% }) %>
                        <th>Total</th>
                        <th>Countback</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% championshipTable.forEach((row) => { %>
                        <% const meta = (playerMetaById && playerMetaById[row.userId]) ? playerMetaById[row.userId] : null; %>
                        <tr>
                          <td><%= row.position %></td>
                          <td>
                            <%- include('../partials/participant-card', {
                              name: meta?.name || row.name,
                              handicapText: (meta && meta.handicap !== null && meta.handicap !== undefined) ? String(meta.handicap) : ''
                            }) %>
                          </td>
                          <% rnList.forEach((rn) => { %>
                            <% const isDropped = row.droppedRounds && row.droppedRounds.includes(rn); %>
                            <td class="<%= isDropped ? 'text-muted' : '' %>">
                              <% const roundScore = (row.rounds && row.rounds[rn] != null) ? row.rounds[rn] : 0; %>
                              <% if (isDropped) { %>
                                <s><%= roundScore %></s>
                              <% } else if (publishedByRound[rn]) { %>
                                <a href="<%= tenantPath(`/leaderboards/tour/${activeTour.id}/scorecards/individual/${row.userId}?round=${rn}`) %>"><%= roundScore %></a>
                              <% } else { %>
                                <%= roundScore %>
                              <% } %>
                            </td>
                          <% }) %>
                          <td>
                            <% if (allRoundsPublished) { %>
                              <strong><a href="<%= tenantPath(`/leaderboards/tour/${activeTour.id}/scorecards/championship/${row.userId}`) %>"><%= row.total %></a></strong>
                            <% } else { %>
                              <strong><%= row.total %></strong>
                            <% } %>
                          </td>
                          <td class="text-muted">
                            <%= row.countbackUsed ? `${row.cb9}/${row.cb6}/${row.cb3}/${row.cb1}` : '-' %>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } %>
            </div>
          </section>
        <% } %>

        <%# ── Payouts ────────────────────────────── %>
        <% if (activeView === 'payouts') { %>
          <% if (!payoutsData || !payoutsData.players.length) { %>
            <div class="card border-0 shadow-sm mb-4">
              <div class="card-body text-muted">No prizes to pay out yet.</div>
            </div>
          <% } else { %>
            <% payoutsData.players.forEach((player) => { %>
              <section class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                  <h2 class="h6 mb-0 fw-semibold"><%= player.name %></h2>
                  <span class="fw-bold text-success">$<%= Number(player.total).toFixed(0) %></span>
                </div>
                <ul class="list-group list-group-flush">
                  <% player.prizes.forEach((prize) => { %>
                    <li class="list-group-item px-3 py-2 d-flex justify-content-between align-items-center">
                      <span class="small text-muted"><%= prize.label %></span>
                      <% if (prize.amount > 0) { %><span class="small fw-semibold text-success">$<%= Number(prize.amount).toFixed(0) %></span><% } %>
                    </li>
                  <% }) %>
                </ul>
              </section>
            <% }) %>
            <div class="card border-0 shadow-sm mb-4 bg-light">
              <div class="card-body d-flex justify-content-between align-items-center py-2">
                <span class="fw-semibold">Grand Total</span>
                <span class="fw-bold text-success fs-5">$<%= Number(payoutsData.grandTotal).toFixed(0) %></span>
              </div>
            </div>
          <% } %>
        <% } %>

        <% } /* end else: leaderboards released */ %>
      <% } %>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  </body>
</html>
