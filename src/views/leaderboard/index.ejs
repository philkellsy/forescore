<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | Legends</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/app.css" />
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container py-3 py-md-4">
      <h1 class="h4 mb-3">Leaderboards</h1>
      <% if (!activeEvent) { %>
        <div class="alert alert-warning">No active event configured yet.</div>
      <% } else { %>
        <p class="text-muted mb-4"><%= activeEvent.year %> at <%= activeEvent.location %></p>

        <div class="row g-3">
          <section class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
              <div class="card-body">
                <h2 class="h6">Day 1 Ambrose</h2>
                <ol class="mb-0 ps-3">
                  <% boards.ambrose.forEach((row) => { %>
                    <li><%= row.name %> (<%= Number(row.totalGross || 0) %>)</li>
                  <% }) %>
                </ol>
              </div>
            </div>
          </section>
          <section class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
              <div class="card-body">
                <h2 class="h6">Eclectic (D2-D4)</h2>
                <ol class="mb-0 ps-3">
                  <% boards.eclectic.forEach((row) => { %>
                    <li><%= row.name %> (<%= Number(row.totalGross || 0) %>)</li>
                  <% }) %>
                </ol>
              </div>
            </div>
          </section>
          <section class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
              <div class="card-body">
                <h2 class="h6">Sultans of Swing</h2>
                <ol class="mb-0 ps-3">
                  <% boards.sultans.forEach((row) => { %>
                    <li><%= row.name %> (<%= Number(row.aggregate || 0) %>)</li>
                  <% }) %>
                </ol>
              </div>
            </div>
          </section>
        </div>
      <% } %>
    </main>
  </body>
</html>
