<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | Legends</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#0e5135" />
    <link rel="icon" type="image/png" href="/img/icons/icon-192.png?v=<%= assetVersion %>" />
    <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
  </head>
  <body class="auth-body">
    <main class="container py-5">
      <div class="row justify-content-center">
        <div class="col-12 col-md-7 col-lg-5">
          <div class="card shadow-sm border-0">
            <div class="card-body p-4">
              <div class="text-center mb-3">
                <img src="/img/legends.jpeg?v=<%= assetVersion %>" alt="Legends logo" style="width:128px;max-width:38vw;height:auto;" />
              </div>
              <h1 class="h4 mb-3">Sign in to Legends</h1>
              <p class="text-muted">Enter your email to receive a secure magic link.</p>

              <% if (error) { %>
                <div class="alert alert-danger"><%= error %></div>
              <% } %>

              <% if (sent) { %>
                <div class="alert alert-success">If your email is registered, a magic link has been sent.</div>
              <% } %>

              <form action="/auth/magic-link" method="post" class="d-grid gap-3">
                <div>
                  <label for="email" class="form-label">Email</label>
                  <input id="email" name="email" type="email" class="form-control form-control-lg" required />
                </div>
                <button class="btn btn-legends btn-lg" type="submit">Send Magic Link</button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </main>
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
      <script src="/js/app.js" defer></script>
  </body>
</html>
