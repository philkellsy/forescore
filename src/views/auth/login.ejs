<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | ForeScore</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#215463" />
    <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
    <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
  </head>
  <body class="auth-body">
    <main class="container py-5">
      <div class="row justify-content-center">
        <div class="col-12 col-md-7 col-lg-5">
          <div class="card shadow-sm border-0">
            <div class="card-body p-4">
              <div class="text-center mb-2">
                <img src="/img/forescore-shield.svg" alt="ForeScore" style="height:96px;width:auto;" />
              </div>
              <h1 class="h4 text-center mb-1"><span style="color:#8AD84A">Fore</span><span style="color:#215463">Score</span></h1>
              <p class="text-center text-muted small mb-3">Golf Trip Scoring App</p>

              <% if (error) { %>
                <div class="alert alert-danger"><%= error %></div>
              <% } %>

              <% if (info) { %>
                <div class="alert alert-success"><%= info %></div>
              <% } else if (sent) { %>
                <div class="alert alert-success">If a matching account exists, a sign-in code has been sent.</div>
              <% } %>

              <% if (!codeStage) { %>
                <p class="text-muted">Enter your email or mobile. We will send a one-time sign-in code to your email address.</p>
                <form action="<%= tenantPath('/auth/send-code') %>" method="post" class="d-grid gap-3">
                  <div>
                    <label for="lookup" class="form-label">Email or mobile</label>
                    <input
                      id="lookup"
                      name="lookup"
                      type="text"
                      class="form-control form-control-lg"
                      value="<%= lookupValue || '' %>"
                      required
                      autocomplete="username"
                    />
                  </div>
                  <div class="form-check">
                    <input
                      id="rememberMe"
                      name="rememberMe"
                      type="checkbox"
                      class="form-check-input"
                      <%= rememberMe ? 'checked' : '' %>
                    />
                    <label class="form-check-label" for="rememberMe">Remember me</label>
                  </div>
                  <button class="btn btn-legends btn-lg" type="submit">Send Sign-In Code</button>
                </form>
              <% } else { %>
                <p class="text-muted">Check your email for the <%= codeLength %>-digit sign-in code. It expires in <%= codeExpiryMinutes %> minutes.</p>

                <form action="<%= tenantPath('/auth/verify-code') %>" method="post" class="d-grid gap-3 mb-3">
                  <input type="hidden" name="lookup" value="<%= lookupValue || '' %>" />
                  <div>
                    <label for="code" class="form-label">One-time code</label>
                    <input
                      id="code"
                      name="code"
                      type="text"
                      class="form-control form-control-lg text-center"
                      inputmode="numeric"
                      pattern="[0-9]*"
                      maxlength="<%= codeLength %>"
                      autocomplete="one-time-code"
                      placeholder="000000"
                      required
                    />
                  </div>
                  <button class="btn btn-legends btn-lg" type="submit">Sign In</button>
                </form>

                <form action="<%= tenantPath('/auth/resend-code') %>" method="post" class="d-grid gap-2 mb-2">
                  <input type="hidden" name="lookup" value="<%= lookupValue || '' %>" />
                  <button
                    id="resendCodeButton"
                    class="btn btn-outline-success"
                    type="submit"
                    data-resend-at="<%= Number(resendAvailableAtMs || 0) %>"
                  >
                    Send another code
                  </button>
                  <small id="resendCountdownText" class="text-muted text-center"></small>
                </form>

                <div class="d-grid">
                  <a class="btn btn-link p-0 text-decoration-none" href="<%= tenantPath('/auth/login') %>">Use a different email or mobile</a>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </main>
    <div class="login-version-tag">v<%= assetVersion %></div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
    <script src="/js/app.js?v=<%= assetVersion %>" defer></script>
  </body>
</html>
