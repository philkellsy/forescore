<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> | ForeScore</title>
  <meta name="theme-color" content="#215463" />
  <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
  <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
</head>
<body>
  <nav class="navbar navbar-dark legends-nav">
    <div class="container">
      <a class="navbar-brand fw-bold d-inline-flex align-items-center" href="/">
        <img src="/img/forescore-shield.svg" alt="" aria-hidden="true" class="legends-brand-logo me-2" />
        ForeScore
        <span class="badge text-bg-warning text-dark ms-2 fw-normal" style="font-size:.65rem">Super Admin</span>
      </a>
      <div class="d-flex align-items-center gap-3">
        <% if (user) { %><small class="text-light"><%= user.firstName %> <%= user.lastName %></small><% } %>
        <a href="/" class="btn btn-sm btn-outline-light">Tenants</a>
      </div>
    </div>
  </nav>

  <main class="container py-3 py-md-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="h4 mb-0">All Events</h1>
    </div>

    <% if (message) { %><div class="alert alert-success"><%= message %></div><% } %>
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

    <% if (events.length) { %>
      <%
        // Group by tenant
        const byTenant = [];
        const tenantIndex = new Map();
        events.forEach((e) => {
          if (!tenantIndex.has(e.tenant_id)) {
            const group = { name: e.tenant_name, slug: e.tenant_slug, events: [] };
            byTenant.push(group);
            tenantIndex.set(e.tenant_id, group);
          }
          tenantIndex.get(e.tenant_id).events.push(e);
        });
      %>
      <% byTenant.forEach((group) => { %>
        <section class="card border-0 shadow-sm mb-4">
          <div class="card-body border-bottom d-flex justify-content-between align-items-center">
            <h2 class="h6 mb-0">
              <a href="/<%= group.slug %>/admin" class="text-decoration-none text-dark"><%= group.name %></a>
              <code class="small text-muted ms-1">/<%= group.slug %></code>
            </h2>
            <a href="/<%= group.slug %>/admin" class="btn btn-sm btn-outline-dark">
              <i class="fa-solid fa-gear me-1"></i>Admin
            </a>
          </div>
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Event</th>
                  <th>Year</th>
                  <th>Dates</th>
                  <th>Status</th>
                  <th>Payment</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% group.events.forEach((e) => { %>
                  <tr>
                    <td><strong><%= e.label %></strong></td>
                    <td><%= e.year %></td>
                    <td class="text-muted small">
                      <%= new Date(e.start_date).toLocaleDateString('en-AU', { day: 'numeric', month: 'short' }) %>
                      –
                      <%= new Date(e.end_date).toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                    </td>
                    <td>
                      <% if (e.status === 'active') { %>
                        <span class="badge text-bg-success">Active</span>
                      <% } else if (e.status === 'completed') { %>
                        <span class="badge text-bg-dark">Completed</span>
                      <% } else { %>
                        <span class="badge text-bg-secondary">Draft</span>
                      <% } %>
                    </td>
                    <td>
                      <% if (e.is_paid) { %>
                        <span class="badge text-bg-success">
                          <i class="fa-solid fa-check me-1"></i>Approved
                        </span>
                        <% if (e.paid_at) { %>
                          <small class="text-muted ms-1">
                            <%= new Date(e.paid_at).toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                          </small>
                        <% } %>
                      <% } else { %>
                        <span class="badge text-bg-warning text-dark">Pending</span>
                      <% } %>
                    </td>
                    <td class="text-end">
                      <div class="d-flex justify-content-end gap-2">
                        <% if (!e.is_paid) { %>
                          <form action="/events/<%= e.id %>/mark-paid" method="post">
                            <button type="submit" class="btn btn-sm btn-success">
                              <i class="fa-solid fa-check me-1"></i>Approve
                            </button>
                          </form>
                        <% } else if (e.status !== 'active') { %>
                          <form action="/events/<%= e.id %>/mark-unpaid" method="post"
                            onsubmit="return confirm('Remove payment approval from this event?')">
                            <button type="submit" class="btn btn-sm btn-outline-warning">
                              Revoke
                            </button>
                          </form>
                        <% } %>
                        <a href="/<%= group.slug %>/admin/events/<%= e.id %>" class="btn btn-sm btn-outline-dark">
                          View
                        </a>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </section>
      <% }) %>
    <% } else { %>
      <div class="text-center py-5 text-muted">
        <i class="fa-solid fa-calendar-xmark fa-3x mb-3 opacity-25"></i>
        <p class="mb-0">No events yet across any tenant.</p>
      </div>
    <% } %>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
</body>
</html>
