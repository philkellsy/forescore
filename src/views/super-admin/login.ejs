<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> | ForeScore</title>
  <meta name="theme-color" content="#215463" />
  <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
  <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
</head>
<body class="auth-body">
  <main class="container py-5">
    <div class="row justify-content-center">
      <div class="col-12 col-md-7 col-lg-5">
        <div class="card shadow-sm border-0">
          <div class="card-body p-4">
            <div class="text-center mb-2">
              <img src="/img/forescore-shield.svg" alt="ForeScore" style="height:72px;width:auto;" />
            </div>
            <h1 class="h5 mb-4 text-center"><span style="color:#8AD84A">Fore</span><span style="color:#215463">Score</span></h1>

            <% if (error) { %>
              <div class="alert alert-danger small"><%= error %></div>
            <% } %>
            <% if (info) { %>
              <div class="alert alert-success small"><%= info %></div>
            <% } %>

            <% if (!codeStage) { %>
              <%# Step 1: enter email or mobile %>
              <form action="/auth/send-code" method="post">
                <div class="mb-3">
                  <label for="lookup" class="form-label">Email or Mobile</label>
                  <input
                    type="text"
                    id="lookup"
                    name="lookup"
                    class="form-control"
                    value="<%= lookupValue %>"
                    autocomplete="email"
                    inputmode="email"
                    autofocus
                    required
                  />
                </div>
                <div class="d-grid">
                  <button type="submit" class="btn btn-legends">Send Sign-In Code</button>
                </div>
              </form>
            <% } else { %>
              <%# Step 2: enter code %>
              <form action="/auth/verify-code" method="post">
                <input type="hidden" name="lookup" value="<%= lookupValue %>" />
                <p class="text-muted small mb-3">
                  Code sent to <strong><%= lookupValue %></strong>.
                  Expires in <%= codeExpiryMinutes %> minutes.
                </p>
                <div class="mb-3">
                  <label for="code" class="form-label">Sign-In Code</label>
                  <input
                    type="text"
                    id="code"
                    name="code"
                    class="form-control text-center fs-4 letter-spacing-wide"
                    inputmode="numeric"
                    autocomplete="one-time-code"
                    maxlength="<%= codeLength %>"
                    pattern="[0-9]*"
                    autofocus
                    required
                  />
                </div>
                <div class="d-grid mb-2">
                  <button type="submit" class="btn btn-legends">Sign In</button>
                </div>
              </form>
              <form action="/auth/send-code" method="post" class="text-center">
                <input type="hidden" name="lookup" value="<%= lookupValue %>" />
                <button type="submit" class="btn btn-link btn-sm text-muted p-0"
                  <% if (resendAvailableAtMs > Date.now()) { %>
                    disabled data-resend-at="<%= resendAvailableAtMs %>"
                  <% } %>>
                  Resend code
                </button>
              </form>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </main>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
</body>
</html>
