<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> | ForeScore</title>
  <meta name="theme-color" content="#215463" />
  <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
  <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
</head>
<body>
  <%# Minimal nav — super admin context, no tenant %>
  <nav class="navbar navbar-dark legends-nav">
    <div class="container">
      <a class="navbar-brand fw-bold d-inline-flex align-items-center" href="/">
        <img src="/img/forescore-shield.svg" alt="" aria-hidden="true" class="legends-brand-logo me-2" />
        ForeScore
        <span class="badge text-bg-warning text-dark ms-2 fw-normal" style="font-size:.65rem">Super Admin</span>
      </a>
    </div>
  </nav>

  <main class="container py-4" style="max-width:640px">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="h4 mb-0">New Tour</h1>
      <a href="/" class="btn btn-sm btn-outline-secondary">Cancel</a>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <form action="/tenants" method="post" novalidate>

      <%# Tour details %>
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body border-bottom">
          <h2 class="h6 mb-0">Tour Details</h2>
        </div>
        <div class="card-body">
          <div class="mb-3">
            <label class="form-label">Tour Name <span class="text-danger">*</span></label>
            <input type="text" name="name" id="tourName" class="form-control"
              value="<%= fields.name || '' %>" placeholder="e.g. Bonville Golf Society"
              required autofocus />
          </div>
          <div class="mb-3">
            <label class="form-label">
              Slug <span class="text-danger">*</span>
              <small class="text-muted fw-normal">— used in all URLs</small>
            </label>
            <div class="input-group">
              <span class="input-group-text text-muted">forescore.app/</span>
              <input type="text" name="slug" id="slugInput" class="form-control"
                value="<%= fields.slug || '' %>" placeholder="bonville"
                pattern="[a-z0-9][a-z0-9-]*" required />
            </div>
            <div class="form-text">Lowercase letters, numbers and hyphens only.</div>
          </div>
          <div class="mb-0">
            <label class="form-label">Plan</label>
            <select name="plan" class="form-select">
              <option value="free" <%= (fields.plan || 'free') === 'free' ? 'selected' : '' %>>Free</option>
              <option value="starter" <%= fields.plan === 'starter' ? 'selected' : '' %>>Starter</option>
              <option value="pro" <%= fields.plan === 'pro' ? 'selected' : '' %>>Pro</option>
            </select>
          </div>
        </div>
      </div>

      <%# Admin user %>
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body border-bottom">
          <h2 class="h6 mb-0">Tour Administrator</h2>
        </div>
        <div class="card-body">
          <p class="text-muted small mb-3">
            This person will have full access to manage the tour.
            If they already have a ForeScore account the name fields are optional.
          </p>
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label">Email <span class="text-danger">*</span></label>
              <input type="email" name="adminEmail" id="adminEmail" class="form-control"
                value="<%= fields.adminEmail || '' %>" placeholder="admin@example.com"
                required />
              <div id="emailStatus" class="form-text d-none"></div>
            </div>
            <div class="col-12 col-sm-6" id="firstNameWrap">
              <label class="form-label">First Name</label>
              <input type="text" name="adminFirstName" id="adminFirstName" class="form-control"
                value="<%= fields.adminFirstName || '' %>" />
            </div>
            <div class="col-12 col-sm-6" id="lastNameWrap">
              <label class="form-label">Last Name</label>
              <input type="text" name="adminLastName" id="adminLastName" class="form-control"
                value="<%= fields.adminLastName || '' %>" />
            </div>
            <div class="col-12">
              <label class="form-label">Role</label>
              <select name="adminRole" class="form-select">
                <option value="owner" <%= (fields.adminRole || 'owner') === 'owner' ? 'selected' : '' %>>Owner — full access including billing</option>
                <option value="admin" <%= fields.adminRole === 'admin' ? 'selected' : '' %>>Admin — full event management</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <div class="d-grid">
        <button type="submit" class="btn btn-legends btn-lg">Create Tour</button>
      </div>
    </form>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  <script>
    // Auto-generate slug from tour name
    const nameInput = document.getElementById('tourName');
    const slugInput = document.getElementById('slugInput');
    nameInput.addEventListener('input', function () {
      if (!slugInput.dataset.userEdited) {
        slugInput.value = nameInput.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
      }
    });
    slugInput.addEventListener('input', function () { slugInput.dataset.userEdited = '1'; });

    // Email lookup — show if existing user found
    const emailInput = document.getElementById('adminEmail');
    const emailStatus = document.getElementById('emailStatus');
    const firstNameWrap = document.getElementById('firstNameWrap');
    const lastNameWrap = document.getElementById('lastNameWrap');

    let lookupTimer = null;
    emailInput.addEventListener('input', function () {
      clearTimeout(lookupTimer);
      emailStatus.className = 'form-text d-none';
      lookupTimer = setTimeout(() => checkEmail(emailInput.value.trim()), 400);
    });

    async function checkEmail(email) {
      if (!email.includes('@')) return;
      try {
        const res = await fetch('/tenants/check-email?email=' + encodeURIComponent(email));
        const data = await res.json();
        if (data.found) {
          emailStatus.textContent = '✓ Existing ForeScore account found — ' + data.name;
          emailStatus.className = 'form-text text-success';
          firstNameWrap.style.opacity = '0.4';
          lastNameWrap.style.opacity = '0.4';
          document.getElementById('adminFirstName').placeholder = 'Not required';
          document.getElementById('adminLastName').placeholder = 'Not required';
        } else {
          emailStatus.textContent = 'New user — name is required.';
          emailStatus.className = 'form-text text-muted';
          firstNameWrap.style.opacity = '';
          lastNameWrap.style.opacity = '';
          document.getElementById('adminFirstName').placeholder = '';
          document.getElementById('adminLastName').placeholder = '';
        }
      } catch { /* ignore */ }
    }

    // Run on load if email is pre-filled (error repopulation)
    if (emailInput.value) checkEmail(emailInput.value);
  </script>
</body>
</html>
