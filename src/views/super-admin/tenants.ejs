<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> | ForeScore</title>
  <meta name="theme-color" content="#215463" />
  <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
  <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
</head>
<body>
  <%# Minimal nav — no tenant context %>
  <nav class="navbar navbar-dark legends-nav">
    <div class="container">
      <span class="navbar-brand fw-bold d-inline-flex align-items-center">
        <img src="/img/forescore-shield.svg" alt="" aria-hidden="true" class="legends-brand-logo me-2" />
        ForeScore
        <span class="badge text-bg-warning text-dark ms-2 fw-normal" style="font-size:.65rem">Super Admin</span>
      </span>
      <% if (user) { %>
        <div class="d-flex align-items-center gap-3">
          <small class="text-light"><%= user.firstName %> <%= user.lastName %></small>
          <a href="/events" class="btn btn-sm btn-outline-light">Events</a>
        </div>
      <% } %>
    </div>
  </nav>

  <main class="container py-3 py-md-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="h4 mb-0">Tours</h1>
      <a href="/tenants/new" class="btn btn-legends btn-sm">
        <i class="fa-solid fa-plus me-1"></i>New Tour
      </a>
    </div>

    <% if (message) { %><div class="alert alert-success"><%= message %></div><% } %>
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

    <% if (tenants.length) { %>
      <div class="row g-3">
        <% tenants.forEach((t) => { %>
          <div class="col-12 col-md-6 col-xl-4">
            <div class="card border-0 shadow-sm h-100">
              <div class="card-body d-flex flex-column gap-2">
                <div class="d-flex justify-content-between align-items-start">
                  <div>
                    <h2 class="h6 mb-0"><%= t.name %></h2>
                    <code class="small text-muted">/<%= t.slug %></code>
                  </div>
                  <% if (t.is_active) { %>
                    <%# is_active is per-event, not per-tenant — skip %>
                  <% } %>
                  <span class="badge <%=
                    t.plan === 'pro' ? 'text-bg-success'
                    : t.plan === 'starter' ? 'text-bg-info text-dark'
                    : 'text-bg-light border'
                  %>"><%= t.plan %></span>
                </div>
                <p class="small text-muted mb-0">
                  <i class="fa-solid fa-users me-1"></i><%= t.memberCount %> player<%= t.memberCount === 1 ? '' : 's' %>
                </p>
                <div class="d-flex gap-2 mt-auto pt-2">
                  <a href="/<%= t.slug %>/admin" class="btn btn-sm btn-legends flex-fill">
                    <i class="fa-solid fa-gear me-1"></i>Admin
                  </a>
                  <a href="/<%= t.slug %>/" class="btn btn-sm btn-outline-dark flex-fill">
                    Enter Tour
                  </a>
                  <button type="button" class="btn btn-sm btn-outline-danger"
                    data-bs-toggle="modal" data-bs-target="#deleteTenantModal"
                    data-tenant-id="<%= t.id %>"
                    data-tenant-name="<%= t.name %>">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="text-center py-5 text-muted">
        <i class="fa-solid fa-flag fa-3x mb-3 opacity-25"></i>
        <p class="mb-0">No tours yet. Create one to get started.</p>
      </div>
    <% } %>
  </main>

  <%# Delete Tenant Modal %>
  <div class="modal fade" id="deleteTenantModal" tabindex="-1" aria-labelledby="deleteTenantModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h2 class="modal-title fs-5" id="deleteTenantModalLabel">Delete Tour</h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p>Permanently delete <strong id="deleteTenantName"></strong>?</p>
          <p class="text-muted small mb-0">This will remove all events, scorecards, players, and courses for this tour. This cannot be undone.</p>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <form id="deleteTenantForm" method="post" class="m-0">
            <button type="submit" class="btn btn-danger">Delete Tour</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  <script>
    document.getElementById('deleteTenantModal').addEventListener('show.bs.modal', function (e) {
      const btn = e.relatedTarget;
      document.getElementById('deleteTenantName').textContent = btn.dataset.tenantName;
      document.getElementById('deleteTenantForm').action = '/tenants/' + btn.dataset.tenantId + '/delete';
    });
  </script>
</body>
</html>
