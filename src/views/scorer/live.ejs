<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | ForeScore</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#215463" />
    <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
    <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
  </head>
  <body>
    <div id="holeLoadingOverlay" class="hole-loading-overlay" aria-hidden="true">
      <div class="hole-loading-spinner">
        <div class="spinner-border" style="width:3rem;height:3rem" role="status">
          <span class="visually-hidden">Loading…</span>
        </div>
        <div class="hole-loading-label">Loading hole…</div>
      </div>
    </div>
    <%- include('../partials/nav') %>
    <main class="container py-3 py-md-4 live-score-main">
      <header class="mb-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <div id="offlineCacheStatus" class="offline-cache-status d-none" aria-live="polite"></div>
          <% if (user && Number(user.id) === 1) { %>
            <button id="offlineTestToggleBtn" type="button" class="btn btn-sm btn-link text-muted p-0" style="font-size:0.7rem;opacity:0.5">offline test</button>
          <% } %>
        </div>
        <p class="text-muted small mb-1 text-center"><%= dayLabel(payload.roundNumber) %> - <%= payload.mode === 'ambrose' ? 'Ambrose Team Scoring' : 'Group Player Scoring' %></p>
        <p id="groupMeta" class="text-muted small mb-1 text-center"></p>
        <div class="live-hole-nav">
          <button id="prevHoleBtn" class="btn btn-outline-dark btn-sm live-hole-nav-btn" aria-label="Previous hole">
            <i class="fa-solid fa-arrow-left"></i>
          </button>
          <h1 class="h5 mb-0 text-center">
            Hole <span id="holeNumber">—</span>
            <span class="text-muted">Par <span id="holePar">—</span> SI <span id="holeSi">—</span></span>
          </h1>
          <button id="nextHoleBtn" class="btn btn-outline-dark btn-sm live-hole-nav-btn" aria-label="Next hole">
            <i class="fa-solid fa-arrow-right"></i>
          </button>
        </div>
      </header>

      <% if (dayStatus.status !== 'open') { %>
        <div class="alert alert-warning">
          Scoring is currently <strong><%= dayStatus.status %></strong> for this day. Entry is disabled until the day is opened.
        </div>
      <% } %>

      <section id="entriesContainer" class="d-grid gap-2"></section>
    </main>

    <script>
      window.__SCORECARD_LIVE__ = <%- JSON.stringify(payload) %>;
      window.__DAY_STATUS__ = "<%= dayStatus.status %>";
      window.__OFFLINE_TEST_ALLOWED__ = <%= user && Number(user.id) === 1 ? 'true' : 'false' %>;
      window.__TENANT_PATH__ = "<%= tenant.slug %>";
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
    <script src="/js/offline-store.js?v=<%= assetVersion %>" defer></script>
    <script src="/js/offline-sync.js?v=<%= assetVersion %>" defer></script>
    <script src="/js/scoring-live.js?v=<%= assetVersion %>" defer></script>
  </body>
</html>
