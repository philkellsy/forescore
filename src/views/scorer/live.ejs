<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | ForeScore</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#215463" />
    <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
    <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
  </head>
  <body>
    <div id="holeLoadingOverlay" class="hole-loading-overlay" aria-hidden="true">
      <div class="hole-loading-spinner">
        <div class="golf-shot-scene">
          <div class="golf-hole-cup"></div>
          <div class="golf-x-track">
            <div class="golf-ball-anim"></div>
          </div>
        </div>
        <div class="hole-loading-label">Loading hole…</div>
      </div>
    </div>
    <%- include('../partials/nav') %>
    <main class="container py-3 py-md-4 live-score-main">
      <header class="mb-3">
        <p id="groupMeta" class="text-muted small mb-1 text-center"></p>
        <div class="live-hole-nav">
          <button id="prevHoleBtn" class="btn btn-outline-dark btn-sm live-hole-nav-btn" aria-label="Previous hole">
            <i id="prevArrowIcon" class="fa-solid fa-arrow-left"></i> <span id="prevHoleLabel" class="live-hole-nav-label"></span>
          </button>
          <h1 class="h5 mb-0 text-center">
            Hole <span id="holeNumber">—</span>
            <span class="text-muted">Par <span id="holePar">—</span> SI <span id="holeSi">—</span></span>
          </h1>
          <button id="nextHoleBtn" class="btn btn-outline-dark btn-sm live-hole-nav-btn" aria-label="Next hole">
            <span id="nextHoleLabel" class="live-hole-nav-label"></span> <i class="fa-solid fa-arrow-right"></i>
          </button>
        </div>
      </header>

      <% if (dayStatus.status !== 'open') { %>
        <div class="alert alert-warning">
          Scoring is currently <strong><%= dayStatus.status %></strong> for this day. Entry is disabled until the day is opened.
        </div>
      <% } %>

      <section id="entriesContainer" class="d-grid gap-2"></section>

      <div id="twoBallNavBar" class="d-none text-center mt-3">
        <button id="twoBallStatusBtn" type="button" class="btn btn-outline-secondary btn-sm two-ball-nav-btn" aria-label="2-ball team scores">
          <i class="fa-solid fa-people-group me-1"></i>Teams
        </button>
      </div>

      <div class="d-flex align-items-center mt-3">
        <div id="offlineCacheStatus" class="offline-cache-status d-none" aria-live="polite"></div>
        <span class="flex-grow-1 text-center text-muted swipe-hint">↔️ swipe to move holes</span>
        <button id="wakeLockToggleBtn" type="button" class="btn btn-sm btn-link p-0 ms-2" aria-label="Toggle screen wake lock" title="Keep screen on">
          <i class="fa-solid fa-sun"></i>
        </button>
        <% if (user && Number(user.id) === 1) { %>
          <button id="offlineTestToggleBtn" type="button" class="btn btn-sm btn-link text-muted p-0 ms-1" style="font-size:0.7rem;opacity:0.5">Go Offline</button>
        <% } %>
      </div>
    </main>

    <div class="offcanvas offcanvas-bottom round-summary-offcanvas" tabindex="-1" id="roundSummaryOffcanvas" aria-labelledby="roundSummaryTitle">
      <div class="offcanvas-header border-bottom py-2">
        <h5 class="offcanvas-title h6 mb-0" id="roundSummaryTitle">Round Summary</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
      </div>
      <div class="offcanvas-body px-3 py-2" id="roundSummaryBody"></div>
    </div>

    <div class="offcanvas offcanvas-bottom round-summary-offcanvas" tabindex="-1" id="twoBallOffcanvas" aria-labelledby="twoBallOffcanvasTitle">
      <div class="offcanvas-header border-bottom py-2">
        <h5 class="offcanvas-title h6 mb-0" id="twoBallOffcanvasTitle">2-Ball</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
      </div>
      <div class="offcanvas-body px-3 py-2" id="twoBallOffcanvasBody">
        <p class="text-center text-muted py-3"><span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Loading…</p>
      </div>
    </div>

    <script>
      window.__SCORECARD_LIVE__ = <%- JSON.stringify(payload) %>;
      window.__DAY_STATUS__ = "<%= dayStatus.status %>";
      window.__OFFLINE_TEST_ALLOWED__ = <%= user && Number(user.id) === 1 ? 'true' : 'false' %>;
      window.__TENANT_PATH__ = "<%= tenant.slug %>";
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
    <script src="/js/app.js?v=<%= assetVersion %>" defer></script>
    <script src="/js/offline-store.js?v=<%= assetVersion %>" defer></script>
    <script src="/js/offline-sync.js?v=<%= assetVersion %>" defer></script>
    <script src="/js/scoring-live.js?v=<%= assetVersion %>" defer></script>
  </body>
</html>
