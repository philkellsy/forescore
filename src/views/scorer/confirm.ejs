<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | ForeScore</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#215463" />
    <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
    <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container py-3 py-md-4">
      <header class="mb-3">
        <h1 class="h4 mb-1">Review Scores</h1>
        <p class="text-muted mb-0"><%= dayLabel(scorecard.round_number) %> - <%= confirmation.mode === 'ambrose' ? 'Ambrose' : 'Individual' %> scorecard</p>
      </header>

      <% if (submitError) { %>
        <div class="alert alert-danger"><%= submitError %></div>
      <% } %>

      <section class="card border-0 shadow-sm mb-3">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap mb-3">
            <div>
              <h2 class="h6 mb-1">Hole Summary</h2>
              <p class="text-muted small mb-0">Tap a hole number to go back and edit it.</p>
            </div>
            <% if (!confirmation.hasMissing) { %>
              <span class="confirm-review-status">All holes scored</span>
            <% } %>
          </div>

          <% if (confirmation.entries && confirmation.entries.length) { %>
            <div class="table-responsive">
              <table class="table table-sm align-middle confirm-score-grid mb-0">
                <thead>
                  <tr>
                    <th scope="col">Hole</th>
                    <% confirmation.entries.forEach((entry) => { %>
                      <th scope="col">
                        <div class="confirm-score-grid-header">
                          <span class="fw-semibold"><%= entry.displayName %></span>
                          <span class="text-muted"><%= entry.type === 'team' ? `Net ${entry.netTotalDisplay || Number(entry.netTotalRaw || 0)}` : `${Number(entry.stablefordTotal || 0)} pts` %></span>
                        </div>
                      </th>
                    <% }) %>
                  </tr>
                </thead>
                <tbody>
                  <% (confirmation.holes || []).forEach((hole) => { %>
                    <tr>
                      <th scope="row">
                        <a class="confirm-hole-pill" href="<%= tenantPath(`/scoring/live/${scorecard.id}?hole=${hole.holeNumber}&from=confirm`) %>" aria-label="Edit hole <%= hole.holeNumber %>"><%= hole.holeNumber %></a>
                      </th>
                      <% hole.cells.forEach((cell) => { %>
                        <td class="<%= cell.missing ? 'is-missing' : '' %>">
                          <div class="confirm-score-cell">
                            <span class="confirm-score-value"><%= cell.displayScore %></span>
                            <% if (!cell.missing && confirmation.mode !== 'ambrose' && cell.stablefordPoints !== null) { %>
                              <span class="confirm-score-meta"><%= Number(cell.stablefordPoints) %> pts</span>
                            <% } %>
                            <% if (cell.missing) { %>
                              <span class="confirm-score-meta">Missing</span>
                            <% } %>
                          </div>
                        </td>
                      <% }) %>

                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <p class="text-muted mb-0">No score entries found.</p>
          <% } %>
        </div>
      </section>

      <% if (scorecard.status === 'submitted') { %>
        <div class="alert alert-info">This scorecard has been submitted and locked.</div>
        <a class="btn btn-outline-secondary" href="<%= tenantPath('/scoring') %>">Back to Scoring</a>
      <% } else { %>
        <%
          const _liveUrl = tenantPath(`/scoring/live/${scorecard.id}${returnHole ? `?hole=${returnHole}` : ''}`);
        %>
        <div class="d-flex gap-2 flex-wrap">
          <% if (canSubmit) { %>
            <a id="reviewSubmitBtn" class="btn btn-success" href="<%= tenantPath(`/scoring/confirm/${scorecard.id}/final`) %>">Review Final Submission</a>
          <% } %>
          <a class="btn btn-outline-secondary" href="<%= _liveUrl %>">Back to Live Scorecard</a>
        </div>
        <p class="small text-muted mt-2 mb-0">The final submission step appears after every score is complete.</p>
      <% } %>
    </main>

    <script>
      (function initConfirmPage() {
        const scorecardId = <%= Number(scorecard.id) %>;
        const storageKey = `scorecardConflictState:${scorecardId}`;
        const reviewSubmitBtn = document.getElementById('reviewSubmitBtn');
        let conflicts = [];
        try {
          const raw = sessionStorage.getItem(storageKey);
          const parsed = raw ? JSON.parse(raw) : null;
          conflicts = Array.isArray(parsed?.conflicts) ? parsed.conflicts : [];
        } catch (_error) {
          conflicts = [];
        }

        if (conflicts.length && reviewSubmitBtn) reviewSubmitBtn.classList.add('d-none');
      })();
    </script>
  </body>
</html>
