<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | Legends</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#0e5135" />
    <link rel="icon" type="image/png" href="/img/icons/icon-192.png?v=<%= assetVersion %>" />
    <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container py-3 py-md-4">
      <header class="mb-3">
        <h1 class="h4 mb-1">Score Confirmation</h1>
        <p class="text-muted mb-0"><%= dayLabel(scorecard.day) %> - <%= confirmation.mode === 'ambrose' ? 'Ambrose' : 'Individual' %> scorecard</p>
      </header>

      <% if (submitError) { %>
        <div class="alert alert-danger"><%= submitError %></div>
      <% } %>

      <section class="card border-0 shadow-sm mb-3">
        <div class="card-body">
          <h2 class="h6 mb-2">Final Scores</h2>
          <% if (confirmation.entries && confirmation.entries.length) { %>
            <div class="d-grid gap-2">
              <% confirmation.entries.forEach((entry) => { %>
                <div class="border rounded p-2 bg-light">
                  <div class="d-flex justify-content-between align-items-center gap-2">
                    <div class="d-flex align-items-center gap-1 flex-wrap">
                      <% if (entry.type === 'team') { %>
                        <strong><%= entry.displayName %></strong>
                        <span class="small text-muted">(Hcp <%= entry.teamHandicapDisplay || Number(entry.teamHandicapRaw || 0) %>)</span>
                      <% } else { %>
                        <%- include('../partials/participant-card', {
                          name: entry.fullName || entry.displayName,
                          handicapText: entry.handicapDisplay || '-',
                          isPreviousWinner: Boolean(entry.isPreviousWinner),
                          isDefendingChampion: Boolean(entry.isDefendingChampion),
                          className: 'border rounded px-2 py-1 bg-white small d-inline-flex align-items-center gap-1'
                        }) %>
                      <% } %>
                    </div>
                    <% if (entry.type === 'team') { %>
                      <span class="small">Net <strong><%= entry.netTotalDisplay || Number(entry.netTotalRaw || 0) %></strong></span>
                    <% } else { %>
                      <span class="small"><strong><%= Number(entry.stablefordTotal || 0) %></strong> pts</span>
                    <% } %>
                  </div>
                  <div class="small text-muted">
                    <% if (entry.type === 'team') { %>
                      Gross <%= Number(entry.grossTotal || 0) %> - Handicap <%= entry.teamHandicapDisplay || Number(entry.teamHandicapRaw || 0) %>
                    <% } else { %>
                      Stableford total across 18 holes
                    <% } %>
                  </div>
                  <% if (entry.type === 'team' && entry.members && entry.members.length) { %>
                    <div class="d-grid gap-2 mt-2">
                      <% entry.members.forEach((member) => { %>
                        <%- include('../partials/participant-card', {
                          name: member.fullName || member.displayName,
                          handicapText: member.handicapDisplay || '-',
                          isPreviousWinner: Boolean(member.isPreviousWinner),
                          isDefendingChampion: Boolean(member.isDefendingChampion),
                          className: 'border rounded px-2 py-1 bg-white small d-inline-flex align-items-center gap-1'
                        }) %>
                      <% }) %>
                    </div>
                  <% } %>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <p class="text-muted mb-0">No score entries found.</p>
          <% } %>
        </div>
      </section>

      <% const missingEntries = (confirmation.entries || []).filter((entry) => (entry.missingHoles || []).length > 0); %>
      <section id="validationCard" class="card border-0 shadow-sm mb-3 <%= (missingEntries.length || staleScores) ? '' : 'd-none' %>">
        <div class="card-body">
          <h2 class="h6 mb-2">Validation</h2>

          <% if (staleScores) { %>
            <div class="alert alert-danger mb-2">
              Scores changed since your last confirmation view. Validation has been refreshed; review conflicts and missing scores before submitting.
            </div>
          <% } %>

          <% if (missingEntries.length) { %>
            <div class="alert alert-warning mb-2">
              <strong>Missing scores:</strong>
              <ul class="mb-0 mt-2">
                <% missingEntries.forEach((entry) => { %>
                  <li><%= entry.fullName || entry.displayName %> - holes <%= entry.missingHoles.join(', ') %></li>
                <% }) %>
              </ul>
            </div>
          <% } %>

          <div id="localConflictBox" class="alert alert-danger mb-0 d-none">
            <strong>Unresolved conflicts:</strong>
            <ul id="localConflictList" class="mb-0 mt-2"></ul>
          </div>
        </div>
      </section>

      <% if (scorecard.status === 'submitted') { %>
        <div class="alert alert-info">This scorecard has been submitted and locked.</div>
        <a class="btn btn-outline-secondary" href="/scoring">Back to Scoring</a>
      <% } else { %>
        <form id="submitScorecardForm" data-submit-snapshot="<%= submitSnapshot || '' %>" action="/scoring/confirm/<%= scorecard.id %>/submit" method="post" class="d-flex gap-2">
          <button id="submitBtn" type="submit" class="btn btn-success" <%= canSubmit ? '' : 'disabled' %>>
            Submit Scores
          </button>
          <a class="btn btn-outline-secondary" href="/scoring/live/<%= scorecard.id %>">Back to Live Scorecard</a>
        </form>
        <p class="small text-muted mt-2 mb-0">Submitting locks this scorecard. After submission, only an admin can change scores.</p>

        <div class="modal fade" id="submitConfirmModal" tabindex="-1" aria-labelledby="submitConfirmModalLabel" aria-hidden="true">
          <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
              <div class="modal-header">
                <h2 class="modal-title fs-6" id="submitConfirmModalLabel">Submit and Lock Scores</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <div class="modal-body">
                Once submitted, these scores are locked. Only an admin can update them afterwards.
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button id="confirmSubmitBtn" type="button" class="btn btn-success">Submit Scores</button>
              </div>
            </div>
          </div>
        </div>
      <% } %>
    </main>

    <script>
      (function initConfirmPage() {
        const scorecardId = <%= Number(scorecard.id) %>;
        const storageKey = `scorecardConflictState:${scorecardId}`;
        const box = document.getElementById('localConflictBox');
        const list = document.getElementById('localConflictList');
        const validationCard = document.getElementById('validationCard');
        const submitBtn = document.getElementById('submitBtn');
        const form = document.getElementById('submitScorecardForm');
        const modalEl = document.getElementById('submitConfirmModal');
        const confirmSubmitBtn = document.getElementById('confirmSubmitBtn');
        let submitModal = null;
        function getSubmitModal() {
          if (submitModal) return submitModal;
          if (!modalEl || !window.bootstrap) return null;
          submitModal = new window.bootstrap.Modal(modalEl);
          return submitModal;
        }

        let conflicts = [];
        try {
          const raw = sessionStorage.getItem(storageKey);
          const parsed = raw ? JSON.parse(raw) : null;
          conflicts = Array.isArray(parsed?.conflicts) ? parsed.conflicts : [];
        } catch (_error) {
          conflicts = [];
        }

        if (box && list && conflicts.length) {
          if (validationCard) validationCard.classList.remove('d-none');
          box.classList.remove('d-none');
          list.innerHTML = conflicts
            .map((c) => `<li>${c.ownerName || 'Another scorer'} set hole ${Number(c.holeNumber)} to ${Number(c.canonicalGross || 0)}.</li>`)
            .join('');
          if (submitBtn) submitBtn.disabled = true;
        }

        async function submitScores() {
          if (!form) return;
          if (submitBtn) submitBtn.disabled = true;
          if (confirmSubmitBtn) confirmSubmitBtn.disabled = true;
          try {
            const res = await fetch(form.action, {
              method: 'POST',
              headers: { Accept: 'application/json', 'Content-Type': 'application/json' },
              body: JSON.stringify({
                submitSnapshot: form.dataset.submitSnapshot || ''
              }),
              credentials: 'same-origin'
            });
            const data = await res.json().catch(() => ({}));
            if (res.status === 409 && data && data.redirect) {
              window.location.assign(data.redirect);
              return;
            }
            if (!res.ok) {
              window.alert(data.message || 'Unable to submit scores right now.');
              if (submitBtn) submitBtn.disabled = false;
              if (confirmSubmitBtn) confirmSubmitBtn.disabled = false;
              return;
            }
            window.location.assign(data.redirect || '/scoring?message=Scorecard%20submitted%20successfully');
          } catch (_error) {
            window.alert('Unable to submit scores right now.');
            if (submitBtn) submitBtn.disabled = false;
            if (confirmSubmitBtn) confirmSubmitBtn.disabled = false;
          }
        }

        if (form) {
          form.addEventListener('submit', (event) => {
            if (submitBtn && submitBtn.disabled) {
              event.preventDefault();
              return;
            }
            event.preventDefault();
            const modal = getSubmitModal();
            if (modal) {
              modal.show();
            } else {
              submitScores();
            }
          });
        }

        if (confirmSubmitBtn) {
          confirmSubmitBtn.addEventListener('click', () => {
            const modal = getSubmitModal();
            if (modal) modal.hide();
            submitScores();
          });
        }
      })();
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  </body>
</html>
