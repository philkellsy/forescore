<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | Legends</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/app.css" />
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container py-3 py-md-4">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4 mb-0">Scoring</h1>
        <% if (canEditAll) { %><span class="badge text-bg-success">Global edit access</span><% } %>
      </div>

      <div class="row g-3">
        <% scorecards.forEach((scorecard) => { %>
          <div class="col-12 col-lg-6">
            <article class="card h-100 border-0 shadow-sm">
              <div class="card-body">
                <h2 class="h6 mb-1">Day <%= scorecard.day %> - <%= scorecard.first_name || 'Team' %> <%= scorecard.last_name || '' %></h2>
                <p class="text-muted small mb-3">Status: <%= scorecard.status %></p>
                <form action="/scoring/<%= scorecard.id %>/hole" method="post" class="row g-2 align-items-end">
                  <div class="col-4">
                    <label class="form-label small">Hole</label>
                    <input name="holeNumber" type="number" min="1" max="18" class="form-control" required />
                  </div>
                  <div class="col-4">
                    <label class="form-label small">Gross</label>
                    <input name="grossScore" type="number" min="1" max="20" class="form-control" required />
                  </div>
                  <div class="col-4 d-grid">
                    <button class="btn btn-legends" type="submit">Save</button>
                  </div>
                </form>
              </div>
            </article>
          </div>
        <% }) %>

        <% if (!scorecards.length) { %>
          <div class="col-12">
            <div class="alert alert-info mb-0">No scorecards are available yet.</div>
          </div>
        <% } %>
      </div>
    </main>
  </body>
</html>
