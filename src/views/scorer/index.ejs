<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | ForeScore</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#215463" />
    <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
    <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container py-3 py-md-4">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4 mb-0">Scoring</h1>
        <% if (canEditAll) { %><span class="badge text-bg-success">Global edit access</span><% } %>
      </div>
      <% if (message) { %>
        <div class="alert alert-success"><%= message %></div>
      <% } %>
      <% if (errorMessage) { %>
        <div class="alert alert-danger"><%= errorMessage %></div>
      <% } %>

      <div class="row g-3">
        <% scorecards.forEach((scorecard) => { %>
          <div class="col-12 col-lg-6">
            <article class="card h-100 border-0 shadow-sm">
              <div class="card-body">
                <h2 class="h6 mb-1">
                  <%= dayLabel(scorecard.round_number) %>
                  <% if (scorecard.type === 'team') { %>
                    - <%= scorecard.team_name || 'Team' %>
                    <% if (scorecard.ambroseTeamHandicapDisplay) { %><span class="text-muted">(Hcp <%= scorecard.ambroseTeamHandicapDisplay %>)</span><% } %>
                  <% } %>
                </h2>
                <p class="text-muted small mb-1">
                  Group
                  <%= scorecard.type === 'team'
                    ? (scorecard.ambrose_group_number || '-')
                    : (scorecard.individual_group_number || '-') %>
                </p>
                <p class="text-muted small mb-1">
                  Tee Time
                  <%= scorecard.type === 'team'
                    ? (scorecard.ambrose_tee_time || '-')
                    : (scorecard.individual_tee_time || '-') %>
                </p>
                <p class="text-muted small mb-3">
                  Starting Tee
                  <%= scorecard.type === 'team'
                    ? (scorecard.ambrose_starting_hole || '-')
                    : (scorecard.individual_starting_hole || '-') %>
                </p>
                <% if (scorecard.status === 'submitted') { %>
                  <% if (scorecard.groupSummary && scorecard.groupSummary.length) { %>
                    <p class="text-muted small mb-1">Group</p>
                    <div class="d-grid gap-2 mb-3">
                      <% scorecard.groupSummary.forEach((entry) => { %>
                        <% if (!entry.isTeam && entry.submitted && entry.scorecardId) { %>
                          <a href="<%= tenantPath(`/scoring/card/${entry.scorecardId}?back=scoring`) %>" class="border rounded px-2 py-1 bg-light small text-decoration-none text-dark d-block">
                            <div class="d-flex justify-content-between align-items-center gap-2">
                              <span><%= entry.fullName %><% if (entry.handicapDisplay) { %> <span class="text-muted">(Hcp <%= entry.handicapDisplay %>)</span><% } %></span>
                              <strong><%= entry.scoreLabel %></strong>
                            </div>
                          </a>
                        <% } else { %>
                          <div class="border rounded px-2 py-1 bg-light small">
                            <div class="d-flex justify-content-between align-items-center gap-2">
                              <span><%= entry.fullName %><% if (entry.handicapDisplay) { %> <span class="text-muted">(Hcp <%= entry.handicapDisplay %>)</span><% } %></span>
                              <strong><%= entry.scoreLabel %></strong>
                            </div>
                            <% if (entry.detail) { %><div class="text-muted"><%= entry.detail %></div><% } %>
                          </div>
                        <% } %>
                      <% }) %>
                    </div>
                  <% } %>
                <% } else { %>
                  <p class="text-muted small mb-1">Group</p>
                  <% if (scorecard.otherPlayers && scorecard.otherPlayers.length) { %>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                      <% scorecard.otherPlayers.forEach((player) => { %>
                        <%- include('../partials/participant-card', {
                          name: player.fullName,
                          handicapText: player.handicapDisplay
                        }) %>
                      <% }) %>
                    </div>
                  <% } else { %>
                    <p class="text-muted small mb-3">-</p>
                  <% } %>

                  <% if (scorecard.type === 'team') { %>
                    <p class="text-muted small mb-1">Other Teams</p>
                    <% if (scorecard.ambroseOtherTeams && scorecard.ambroseOtherTeams.length) { %>
                      <div class="d-flex flex-wrap gap-2 mb-3">
                        <% scorecard.ambroseOtherTeams.forEach((team) => { %>
                          <%- include('../partials/participant-card', {
                            name: team.name,
                            handicapText: `Hcp ${team.handicapDisplay}`
                          }) %>
                        <% }) %>
                      </div>
                    <% } else { %>
                      <p class="text-muted small mb-3">-</p>
                    <% } %>
                  <% } %>
                <% } %>

                <% if (scorecard.twoBallInfo) { %>
                  <div class="mt-3 pt-3 border-top mb-3">
                    <p class="text-muted small fw-semibold mb-2">
                      2-ball (<%= scorecard.twoBallInfo.twoBallType === 'aggregate' ? 'Aggregate' : 'Best Ball' %>)
                    </p>
                    <% if (scorecard.twoBallInfo.groupSize === 4) { %>
                      <% if (scorecard.twoBallInfo.myPartner) { %>
                        <p class="small mb-2">Partner: <strong><%= scorecard.twoBallInfo.myPartner.fullName %></strong></p>
                      <% } %>
                      <% if (scorecard.twoBallInfo.selectablePartners && scorecard.twoBallInfo.selectablePartners.length) { %>
                        <div class="d-flex gap-2 flex-wrap mb-2">
                          <% scorecard.twoBallInfo.selectablePartners.forEach((p) => { %>
                            <form action="<%= tenantPath('/scoring/select-partner') %>" method="post" class="m-0" data-no-loading>
                              <input type="hidden" name="scorecardId" value="<%= scorecard.id %>" />
                              <input type="hidden" name="partnerId" value="<%= p.userId %>" />
                              <button type="submit" class="btn btn-sm btn-outline-secondary">
                                Pair with <%= p.fullName %>
                              </button>
                            </form>
                          <% }) %>
                        </div>
                      <% } %>
                      <% if (scorecard.twoBallInfo.playerTwoBall && scorecard.twoBallInfo.playerTwoBall.selectablePartners.length) { %>
                        <% const ptb = scorecard.twoBallInfo.playerTwoBall; %>
                        <p class="small text-muted mb-1"><%= ptb.playerName %>: <% if (ptb.myPartner) { %><span class="fw-semibold text-body"><%= ptb.myPartner.fullName %></span><% } %></p>
                        <div class="d-flex gap-2 flex-wrap">
                          <% ptb.selectablePartners.forEach((p) => { %>
                            <form action="<%= tenantPath('/scoring/select-partner') %>" method="post" class="m-0" data-no-loading>
                              <input type="hidden" name="scorecardId" value="<%= ptb.scorecardId %>" />
                              <input type="hidden" name="partnerId" value="<%= p.userId %>" />
                              <button type="submit" class="btn btn-sm btn-outline-secondary">
                                Pair with <%= p.fullName %>
                              </button>
                            </form>
                          <% }) %>
                        </div>
                      <% } %>
                    <% } else if (scorecard.twoBallInfo.groupSize === 3) { %>
                      <% scorecard.twoBallInfo.teams.forEach((team) => { %>
                        <p class="small mb-1">
                          <span class="text-muted"><%= team.label %>:</span>
                          <%= team.players.map((p) => p.isShared ? `${p.fullName} *` : p.fullName).join(' + ') %>
                        </p>
                      <% }) %>
                      <p class="text-muted mb-0" style="font-size:0.7rem">* Shared player (lowest handicap)</p>
                    <% } %>
                  </div>
                <% } %>

                <% if (scorecard.status !== 'submitted') { %>
                  <% if (scorecard.round_status === 'open') { %>
                    <% if (scorecard.type === 'individual' && scorecard.markerInfo) { %>
                      <% if (scorecard.markerInfo.assigned) { %>
                        <% if (scorecard.markerInfo.playerBeingMarked) { %>
                          <p class="small mb-2"><span class="text-muted">Marking:</span> <strong><%= scorecard.markerInfo.playerBeingMarked %></strong></p>
                        <% } %>
                        <% if (scorecard.markerInfo.markedBy) { %>
                          <p class="small mb-3 text-muted">Your marker: <%= scorecard.markerInfo.markedBy %></p>
                        <% } %>
                        <div class="d-flex gap-2 flex-wrap align-items-center">
                          <a class="btn btn-sm btn-success" href="<%= tenantPath(`/scoring/session/${scorecard.round_number}`) %>">
                            <i class="fa-solid fa-mobile-screen-button me-1"></i>Open Scoring
                          </a>
                          <a class="btn btn-sm btn-outline-secondary" href="<%= tenantPath(`/scoring/${scorecard.id}/group`) %>">
                            <i class="fa-solid fa-users me-1"></i>Group
                          </a>
                        </div>
                      <% } else { %>
                        <p class="text-muted small mb-0">Waiting for tee time assignment.</p>
                      <% } %>
                    <% } else if (scorecard.type === 'team') { %>
                      <div class="d-flex gap-2 flex-wrap align-items-center">
                        <a class="btn btn-sm btn-success" href="<%= tenantPath(`/scoring/live/${scorecard.id}`) %>">
                          <i class="fa-solid fa-mobile-screen-button me-1"></i>Open Live Scorecard
                        </a>
                      </div>
                    <% } %>
                  <% } else { %>
                    <p class="text-danger small fw-semibold mb-0">Scoring not yet open</p>
                  <% } %>
                <% } %>
              </div>
            </article>
          </div>
        <% }) %>

        <% if (!scorecards.length) { %>
          <div class="col-12">
            <div class="alert alert-info mb-0">No scorecards are available yet.</div>
          </div>
        <% } %>
      </div>
    </main>
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  </body>
</html>
