<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | Legends</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/css/app.css" />
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container py-3">
      <section class="mb-4">
        <h1 class="h4 mb-1">Player Dashboard</h1>
        <p class="text-muted mb-0">Mobile-first score access for your rounds and standings.</p>
      </section>

      <section class="card border-0 shadow-sm">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th>Day</th>
                  <th>Status</th>
                  <th>Gross</th>
                  <th>Stableford</th>
                </tr>
              </thead>
              <tbody>
                <% if (!recentScores.length) { %>
                  <tr><td colspan="4" class="text-muted px-3 py-3">No scorecards yet.</td></tr>
                <% } %>
                <% recentScores.forEach((score) => { %>
                  <tr>
                    <td>Day <%= score.day %></td>
                    <td><span class="badge text-bg-secondary"><%= score.status %></span></td>
                    <td><%= Number(score.totalGross || 0) %></td>
                    <td><%= Number(score.totalStableford || 0) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
