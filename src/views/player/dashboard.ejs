<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | ForeScore</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#215463" />
    <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
    <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container py-3 py-md-4" style="max-width:680px">
      <%
        const TYPE_META = {
          accommodation: { label: 'Accommodation', icon: 'fa-bed' },
          transfer:      { label: 'Transfer',       icon: 'fa-van-shuttle' },
          meal:          { label: 'Meal',            icon: 'fa-utensils' },
          activity:      { label: 'Activity',        icon: 'fa-person-hiking' },
          note:          { label: 'Note',            icon: 'fa-circle-info' },
          flight:        { label: 'Flight',          icon: 'fa-plane-departure' },
        };
        const CALC_LABELS = {
          stableford:   'Stableford',
          ambrose_nett: 'Ambrose',
          stroke:       'Stroke Play',
        };
        function fmtDate(d) {
          if (!d) return '';
          return new Date(d).toLocaleDateString('en-AU', { weekday: 'short', day: 'numeric', month: 'short', timeZone: 'UTC' });
        }
        function fmtTime(t) {
          if (!t) return '';
          return String(t).slice(0, 5);
        }
        <%
          const todayItems      = (byDate[todayKey]    || []).filter(e => e._kind === 'item');
          const tomorrowEntries = byDate[tomorrowKey] || [];
          const todayHasContent    = !!(openRound || championshipStanding || skinsSummary || todayItems.length);
          const tomorrowHasContent = tomorrowEntries.length > 0;
          const showTabs  = todayHasContent || tomorrowHasContent;
          const activeTab = todayHasContent ? 'today' : 'tomorrow';
          const allDateKeys = Object.keys(byDate).sort();
        %>

      <% if (!activeTour) { %>
        <div class="alert alert-info">No active tour at the moment. Check back soon.</div>
      <% } else { %>

        <div class="d-flex justify-content-between align-items-center mb-3">
          <h1 class="h5 mb-0"><%= activeTour.label %></h1>
          <% if (showTabs) { %>
            <a href="<%= tenantPath('/itinerary') %>" class="btn btn-sm btn-outline-secondary">
              <i class="fa-solid fa-calendar-days me-1"></i>Itinerary
            </a>
          <% } %>
        </div>

        <% if (showTabs) { %>

          <%# Tab nav — only render tabs that have content %>
          <div class="d-flex align-items-end mb-3">
            <ul class="nav nav-tabs flex-grow-1" id="dashTabs" role="tablist" style="border-bottom:0">
              <% if (todayHasContent) { %>
                <li class="nav-item" role="presentation">
                  <button class="nav-link <%= activeTab === 'today' ? 'active' : '' %>" id="tab-today-btn"
                    data-bs-toggle="tab" data-bs-target="#tab-today" type="button" role="tab"
                    aria-controls="tab-today" aria-selected="<%= activeTab === 'today' %>">Today</button>
                </li>
              <% } %>
              <% if (tomorrowHasContent) { %>
                <li class="nav-item" role="presentation">
                  <button class="nav-link <%= activeTab === 'tomorrow' ? 'active' : '' %>" id="tab-tomorrow-btn"
                    data-bs-toggle="tab" data-bs-target="#tab-tomorrow" type="button" role="tab"
                    aria-controls="tab-tomorrow" aria-selected="<%= activeTab === 'tomorrow' %>">Tomorrow</button>
                </li>
              <% } %>
            </ul>
          </div>
          <div style="border-top:1px solid var(--bs-border-color);margin-top:-1px;margin-bottom:1rem"></div>

          <div class="tab-content" id="dashTabContent">

            <%# ── TODAY TAB ── %>
            <% if (todayHasContent) { %>
              <div class="tab-pane fade <%= activeTab === 'today' ? 'show active' : '' %>"
                   id="tab-today" role="tabpanel" aria-labelledby="tab-today-btn">

                <%# Open round %>
                <% if (openRound) { %>
                  <section class="card border-0 shadow-sm mb-3">
                    <div class="card-body">
                      <h2 class="h6 text-muted text-uppercase mb-3" style="letter-spacing:.05em;font-size:.7rem">
                        Today &middot; <%= dayLabel(openRound.round_number) %>
                      </h2>
                      <% if (todayGroup) { %>
                        <div class="d-flex justify-content-between align-items-start mb-3">
                          <div>
                            <div class="fw-semibold">Group <%= todayGroup.groupNumber %></div>
                            <div class="small text-muted">
                              Tee <%= todayGroup.startingHole || '-' %>
                              <% if (todayGroup.teeLocation) { %> &middot; <%= todayGroup.teeLocation %><% } %>
                            </div>
                          </div>
                          <div class="text-end">
                            <div class="fs-5 fw-bold"><%= todayGroup.teeTime || '-' %></div>
                            <% if (todayHandicap !== null) { %>
                              <div class="small text-muted">Hcp <%= todayHandicap %></div>
                            <% } %>
                          </div>
                        </div>
                        <div class="d-flex flex-wrap gap-2 mb-3">
                          <% todayGroup.players.forEach((p) => { %>
                            <span class="badge <%= p.isMe ? 'text-bg-dark' : 'text-bg-light border' %>"><%= p.name %></span>
                          <% }) %>
                        </div>
                        <% if (todayGroup.scorecard) { %>
                          <% if (todayGroup.scorecard.status === 'submitted') { %>
                            <span class="badge text-bg-secondary">Submitted</span>
                          <% } else { %>
                            <a href="<%= tenantPath(`/scoring/live/${todayGroup.scorecard.id}`) %>" class="btn btn-success btn-sm">
                              <i class="fa-solid fa-mobile-screen-button me-1"></i>Open Live Scorecard
                            </a>
                          <% } %>
                        <% } else { %>
                          <p class="small text-muted mb-0">Scorecard not yet available.</p>
                        <% } %>
                      <% } else { %>
                        <p class="text-muted small mb-0">You are not in a tee group for today.</p>
                      <% } %>
                    </div>
                  </section>
                <% } %>

                <%# Standings %>
                <% if (championshipStanding || skinsSummary) { %>
                  <section class="card border-0 shadow-sm mb-3">
                    <div class="card-body">
                      <h2 class="h6 text-muted text-uppercase mb-3" style="letter-spacing:.05em;font-size:.7rem">Standings</h2>
                      <div class="row g-3">
                        <% if (championshipStanding) { %>
                          <div class="col">
                            <div class="border rounded p-3 text-center h-100">
                              <div class="text-muted small mb-1">Championship</div>
                              <div class="display-6 fw-bold lh-1">#<%= championshipStanding.place %></div>
                              <div class="fw-semibold mt-1"><%= championshipStanding.points %> pts</div>
                              <div class="small text-muted mt-1">
                                <%= championshipStanding.pointsFromLeader === 0 ? 'Leader' : `${championshipStanding.pointsFromLeader} from lead` %>
                              </div>
                            </div>
                          </div>
                        <% } %>
                        <% if (skinsSummary) { %>
                          <div class="col">
                            <div class="border rounded p-3 text-center h-100">
                              <div class="text-muted small mb-1">Skins</div>
                              <div class="display-6 fw-bold lh-1"><%= skinsSummary.totalSkins %></div>
                              <div class="fw-semibold text-success mt-1">$<%= skinsSummary.totalPayout.toFixed(2) %></div>
                              <div class="small text-muted mt-1">$<%= skinsSummary.baseSkinPot.toFixed(2) %> / skin</div>
                            </div>
                          </div>
                        <% } %>
                      </div>
                    </div>
                  </section>
                <% } %>

                <%# Today's non-golf itinerary items %>
                <% if (todayItems.length) { %>
                  <section class="card border-0 shadow-sm mb-3">
                    <% todayItems.forEach((entry, i) => { %>
                      <%- include('../partials/itinerary-entry', { entry, i, TYPE_META, CALC_LABELS, fmtTime }) %>
                    <% }) %>
                  </section>
                <% } %>

              </div>
            <% } %>

            <%# ── TOMORROW TAB ── %>
            <% if (tomorrowHasContent) { %>
              <div class="tab-pane fade <%= activeTab === 'tomorrow' ? 'show active' : '' %>"
                   id="tab-tomorrow" role="tabpanel" aria-labelledby="tab-tomorrow-btn">
                <h2 class="h6 text-muted text-uppercase small fw-semibold mb-2 ps-1"><%= fmtDate(tomorrowKey) %></h2>
                <div class="card border-0 shadow-sm mb-3">
                  <% tomorrowEntries.forEach((entry, i) => { %>
                    <%- include('../partials/itinerary-entry', { entry, i, TYPE_META, CALC_LABELS, fmtTime }) %>
                  <% }) %>
                </div>
              </div>
            <% } %>

          </div>

        <% } else { %>

          <%# Both tabs empty — show full itinerary %>
          <% if (allDateKeys.length) { %>
            <% allDateKeys.forEach((dateKey) => { %>
              <section class="mb-4">
                <h2 class="h6 text-muted text-uppercase small fw-semibold mb-2 ps-1"><%= fmtDate(dateKey) %></h2>
                <div class="card border-0 shadow-sm">
                  <% byDate[dateKey].forEach((entry, i) => { %>
                    <%- include('../partials/itinerary-entry', { entry, i, TYPE_META, CALC_LABELS, fmtTime }) %>
                  <% }) %>
                </div>
              </section>
            <% }) %>
          <% } else { %>
            <div class="text-center py-5 text-muted">
              <i class="fa-solid fa-calendar-days fa-3x mb-3 opacity-25"></i>
              <p class="mb-0">Nothing scheduled yet — check back soon.</p>
            </div>
          <% } %>

        <% } %>

      <% } %>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  </body>
</html>
