<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | ForeScore</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#215463" />
    <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
    <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container py-3 py-md-4" style="max-width:720px">
      <%
        const CALC_LABELS = { stableford: 'Stableford', ambrose_nett: 'Ambrose', stroke: 'Stroke' };
        const TYPE_META = {
          accommodation: { label: 'Accommodation', icon: 'fa-bed' },
          transfer:      { label: 'Transfer',       icon: 'fa-van-shuttle' },
          meal:          { label: 'Meal',            icon: 'fa-utensils' },
          activity:      { label: 'Activity',        icon: 'fa-person-hiking' },
          note:          { label: 'Note',            icon: 'fa-circle-info' },
          flight:        { label: 'Flight',          icon: 'fa-plane-departure' },
        };
        function fmtDate(d) {
          if (!d) return '';
          return new Date(d + 'T00:00:00').toLocaleDateString('en-AU', { weekday: 'short', day: 'numeric', month: 'short' });
        }
        function fmtTime(t) {
          if (!t) return '';
          return String(t).slice(0, 5);
        }
        function roundRelLabel(tourDate) {
          if (!tourDate) return null;
          if (tourDate === todayKey) return 'Today';
          if (tourDate === tomorrowKey) return 'Tomorrow';
          return null;
        }
      %>

      <% if (!activeTour) { %>
        <div class="alert alert-info">No active tour at the moment. Check back soon.</div>
      <% } else { %>

        <div class="d-flex justify-content-between align-items-center mb-4">
          <h1 class="h5 mb-0"><%= activeTour.label %></h1>
        </div>

        <div class="d-grid gap-3">

          <%# ── ROUNDS WIDGET ── %>
          <section class="card border-0 shadow-sm">
            <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
              <h2 class="h6 mb-0"><i class="fa-solid fa-flag fa-sm me-2 text-muted"></i>Rounds</h2>
              <a href="<%= tenantPath('/scoring') %>" class="text-muted small">Scoring <i class="fa-solid fa-chevron-right fa-xs"></i></a>
            </div>
            <%
              const closedRounds = (rounds || []).filter(r => r.status === 'closed');
              const lastPlayed = closedRounds.length ? closedRounds[closedRounds.length - 1] : null;
              const nextRound = (rounds || []).find(r => r.status === 'open') || (rounds || []).find(r => r.status === 'draft');
              const dashRounds = [lastPlayed, nextRound].filter(Boolean).filter((r, i, a) => a.findIndex(x => x.roundNumber === r.roundNumber) === i);
            %>
            <% if (!dashRounds.length) { %>
              <div class="card-body text-muted small">No rounds scheduled yet.</div>
            <% } else { %>
              <ul class="list-group list-group-flush">
                <% dashRounds.forEach((r) => {
                  const relLabel = roundRelLabel(r.tourDate);
                  const dateStr = relLabel || fmtDate(r.tourDate);
                  const isPast = r.tourDate && r.tourDate < todayKey;
                  const isToday = r.tourDate === todayKey;
                  const isFuture = r.tourDate && r.tourDate > todayKey;
                  const hasScorecard = !!r.scorecardId;
                  const isSubmitted = r.scorecardStatus === 'submitted';
                %>
                  <li class="list-group-item px-3 py-3">
                    <div class="d-flex justify-content-between align-items-start gap-2">
                      <div style="min-width:0">
                        <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                          <span class="fw-semibold"><%= dayLabel(r.roundNumber) %></span>
                          <% if (r.calcType && r.calcType !== 'stableford') { %>
                            <span class="badge text-bg-secondary fw-normal"><%= CALC_LABELS[r.calcType] || r.calcType %></span>
                          <% } %>
                          <% if (r.status === 'open') { %>
                            <span class="badge text-bg-success fw-normal">Open</span>
                          <% } else if (r.status === 'closed') { %>
                            <span class="badge text-bg-light border fw-normal text-muted">Closed</span>
                          <% } %>
                        </div>
                        <div class="small text-muted">
                          <% if (dateStr) { %><span class="<%= isToday ? 'fw-semibold text-dark' : '' %>"><%= dateStr %></span><% } %>
                          <% if (r.courseName) { %><% if (dateStr) { %> &middot; <% } %><%= r.courseName %><% } %>
                          <% if (r.teeTime) { %> &middot; <%= r.teeTime %><% } %>
                          <% if (r.groupNumber) { %> &middot; Group <%= r.groupNumber %><% } %>
                        </div>
                        <% if (r.dayPosition) { %>
                          <div class="small text-muted mt-1">
                            <i class="fa-solid fa-ranking-star fa-xs me-1"></i>#<%= r.dayPosition.position %> of <%= r.dayPosition.total %> &middot; <%= r.dayPosition.points %> pts
                          </div>
                        <% } %>
                      </div>
                      <div class="d-flex gap-1 flex-shrink-0 align-items-center">
                        <% if (r.status === 'open' && hasScorecard && !isSubmitted) { %>
                          <a href="<%= tenantPath(`/scoring/live/${r.scorecardId}`) %>" class="btn btn-success btn-sm">
                            <i class="fa-solid fa-mobile-screen-button me-1"></i>Score
                          </a>
                        <% } else if (hasScorecard && isSubmitted) { %>
                          <span class="badge text-bg-secondary">Submitted</span>
                        <% } else if (hasScorecard) { %>
                          <a href="<%= tenantPath(`/scoring/live/${r.scorecardId}`) %>" class="btn btn-outline-secondary btn-sm">View</a>
                        <% } %>
                      </div>
                    </div>
                  </li>
                <% }) %>
              </ul>
            <% } %>
          </section>

          <%# ── POSITION + PRIZES ROW ── %>
          <% if (championshipStanding || (prizeWins && prizeWins.length)) { %>
          <div class="row g-3">

            <%# Championship position %>
            <% if (championshipStanding) { %>
            <div class="<%= (prizeWins && prizeWins.length) ? 'col-12 col-sm-5' : 'col-12' %>">
              <a href="<%= tenantPath(`/leaderboards/tour/${activeTour.id}?view=championship`) %>" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100">
                  <div class="card-header bg-transparent">
                    <h2 class="h6 mb-0 text-muted"><i class="fa-solid fa-trophy fa-sm me-2"></i>Championship</h2>
                  </div>
                  <div class="card-body text-center py-3">
                    <div class="display-5 fw-bold lh-1 text-dark">#<%= championshipStanding.place %></div>
                    <div class="fw-semibold mt-2"><%= championshipStanding.points %> pts</div>
                    <div class="small text-muted mt-1">
                      <%= championshipStanding.pointsFromLeader === 0 ? 'Leading' : `${championshipStanding.pointsFromLeader} behind` %>
                    </div>
                  </div>
                </div>
              </a>
            </div>
            <% } %>

            <%# All prizes %>
            <% if (prizeWins && prizeWins.length) { %>
            <div class="<%= championshipStanding ? 'col-12 col-sm-7' : 'col-12' %>">
              <a href="<%= tenantPath(`/leaderboards/tour/${activeTour.id}`) %>" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100">
                  <div class="card-header bg-transparent">
                    <h2 class="h6 mb-0 text-muted"><i class="fa-solid fa-dollar-sign fa-sm me-2"></i>Prizes</h2>
                  </div>
                  <ul class="list-group list-group-flush">
                    <% prizeWins.forEach((p) => { %>
                      <li class="list-group-item px-3 py-2 d-flex justify-content-between align-items-center">
                        <span class="small"><%= p.label %></span>
                        <% if (p.amount > 0) { %><span class="fw-semibold text-success small">$<%= Number(p.amount).toFixed(0) %></span><% } %>
                      </li>
                    <% }) %>
                    <% const totalPrizes = prizeWins.reduce((s, p) => s + (Number(p.amount) || 0), 0); %>
                    <% if (totalPrizes > 0 && prizeWins.length > 1) { %>
                      <li class="list-group-item px-3 py-2 d-flex justify-content-between align-items-center bg-light">
                        <span class="small fw-semibold">Total</span>
                        <span class="fw-bold text-success small">$<%= totalPrizes.toFixed(0) %></span>
                      </li>
                    <% } %>
                  </ul>
                </div>
              </a>
            </div>
            <% } %>

          </div>
          <% } %>

          <%# ── NEXT ITINERARY WIDGET ── %>
          <% if (nextItinerary && nextItinerary.length) { %>
          <section class="card border-0 shadow-sm">
            <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
              <h2 class="h6 mb-0"><i class="fa-solid fa-calendar-days fa-sm me-2 text-muted"></i>Up Next</h2>
              <a href="<%= tenantPath('/itinerary') %>" class="text-muted small">Full itinerary <i class="fa-solid fa-chevron-right fa-xs"></i></a>
            </div>
            <ul class="list-group list-group-flush">
              <% nextItinerary.forEach((entry) => {
                const meta = TYPE_META[entry.type] || { label: entry.type, icon: 'fa-calendar' };
                const relLabel = roundRelLabel(entry.dateKey);
                const dateDisplay = relLabel || fmtDate(entry.dateKey);
              %>
                <li class="list-group-item px-3 py-2">
                  <div class="d-flex align-items-center gap-2">
                    <i class="fa-solid <%= meta.icon %> fa-fw text-muted"></i>
                    <div style="min-width:0">
                      <div class="fw-semibold small text-truncate"><%= entry.label || entry.title || meta.label %></div>
                      <div class="text-muted" style="font-size:0.75rem">
                        <%= dateDisplay %><% if (entry.start_time) { %> &middot; <%= fmtTime(entry.start_time) %><% } %>
                      </div>
                    </div>
                  </div>
                </li>
              <% }) %>
            </ul>
          </section>
          <% } %>

        </div>

      <% } %>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  </body>
</html>
