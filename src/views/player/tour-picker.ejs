<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> | ForeScore</title>
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="theme-color" content="#215463" />
  <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
  <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
</head>
<body>
  <%- include('../partials/nav') %>
  <main class="container py-4" style="max-width:480px">
    <%
      function fmtDateRange(start, end) {
        if (!start) return null;
        const opts = { day: 'numeric', month: 'short', timeZone: 'UTC' };
        const s = new Date(start).toLocaleDateString('en-AU', opts);
        if (!end || String(end).slice(0, 10) === String(start).slice(0, 10)) return s;
        const e = new Date(end).toLocaleDateString('en-AU', { ...opts, year: 'numeric' });
        return `${s} – ${e}`;
      }
    %>

    <div class="text-center mb-4">
      <h1 class="h5 mb-1">Choose a tour</h1>
      <p class="text-muted small mb-0">You're on multiple active tours. Which one do you want to view?</p>
    </div>

    <div class="d-flex flex-column gap-3">
      <% tours.forEach((tour) => { %>
        <%
          const dateRange = fmtDateRange(tour.start_date, tour.end_date);
        %>
        <a href="<%= tenantPath('/dashboard') %>?tourId=<%= tour.id %>"
           class="card border-0 shadow-sm text-decoration-none text-body">
          <div class="card-body d-flex align-items-center gap-3">
            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                 style="width:44px;height:44px;background:#eaf6ea">
              <i class="fa-solid fa-golf-ball-tee" style="color:#3a7a3a"></i>
            </div>
            <div class="flex-grow-1 min-width-0">
              <div class="fw-semibold"><%= tour.label %></div>
              <% if (dateRange) { %>
                <div class="text-muted small"><%= dateRange %></div>
              <% } %>
            </div>
            <i class="fa-solid fa-chevron-right text-muted"></i>
          </div>
        </a>
      <% }) %>
    </div>
  </main>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
</body>
</html>
