<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | ForeScore</title>
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#215463" />
    <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
    <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container py-3 py-md-4" style="max-width:520px">

      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h5 mb-0">My Profile</h1>
        <a href="<%= tenantPath('/dashboard') %>" class="btn btn-sm btn-outline-secondary">
          <i class="fa-solid fa-arrow-left me-1"></i>Back
        </a>
      </div>

      <% if (saved) { %>
        <div class="alert alert-success alert-dismissible fade show py-2" role="alert">
          Profile updated.
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <% if (errors.length) { %>
        <div class="alert alert-danger py-2">
          <% errors.forEach(e => { %><div><%= e %></div><% }) %>
        </div>
      <% } %>

      <div class="card border-0 shadow-sm">
        <div class="card-body">

          <%# Email section — kept outside the profile form to avoid nested-form issues %>
          <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" class="form-control" value="<%= profileUser.email %>"
                   disabled readonly />

            <% if (profileUser.pending_email) { %>
              <div class="alert alert-info py-2 mt-2 mb-2 small">
                A verification code was sent to <strong><%= profileUser.pending_email %></strong>.
                Enter it below to confirm the change.
              </div>
              <form method="post" action="<%= tenantPath('/profile/verify-email-change') %>" class="mb-1">
                <div class="input-group input-group-sm">
                  <input type="text" class="form-control" name="code"
                         placeholder="6-digit code" maxlength="6" pattern="\d{6}"
                         inputmode="numeric" autocomplete="one-time-code" required />
                  <button type="submit" class="btn btn-primary">Verify</button>
                </div>
              </form>
              <div class="d-flex gap-2 align-items-center form-text">
                <form method="post" action="<%= tenantPath('/profile/request-email-change') %>" class="m-0">
                  <input type="hidden" name="newEmail" value="<%= profileUser.pending_email %>" />
                  <button type="submit" class="btn btn-link btn-sm p-0 link-secondary" style="font-size:inherit">Resend code</button>
                </form>
                <span class="text-muted">·</span>
                <form method="post" action="<%= tenantPath('/profile/cancel-email-change') %>" class="m-0">
                  <button type="submit" class="btn btn-link btn-sm p-0 link-secondary" style="font-size:inherit">Cancel</button>
                </form>
              </div>
            <% } else { %>
              <div class="form-text" id="changeEmailHint">
                <a href="#" class="link-secondary" id="changeEmailToggle">Change email</a>
              </div>
              <div class="mt-2 <%= showEmailChangeForm ? '' : 'd-none' %>" id="changeEmailForm">
                <form method="post" action="<%= tenantPath('/profile/request-email-change') %>">
                  <div class="input-group input-group-sm">
                    <input type="email" class="form-control" name="newEmail"
                           value="<%= emailChangeValue %>"
                           placeholder="New email address"
                           autocomplete="email" required />
                    <button type="submit" class="btn btn-outline-secondary">Send code</button>
                  </div>
                  <div class="form-text">We'll send a 6-digit code to the new address to verify it.</div>
                </form>
              </div>
            <% } %>
          </div>

          <form method="post" action="<%= tenantPath('/profile') %>">

            <div class="row g-3 mb-3">
              <div class="col">
                <label class="form-label" for="firstName">First name</label>
                <input type="text" class="form-control" id="firstName" name="firstName"
                       value="<%= profileUser.first_name || '' %>" autocomplete="given-name" />
              </div>
              <div class="col">
                <label class="form-label" for="lastName">Last name</label>
                <input type="text" class="form-control" id="lastName" name="lastName"
                       value="<%= profileUser.last_name || '' %>" autocomplete="family-name" />
              </div>
            </div>

            <div class="mb-3">
              <label class="form-label" for="phoneNumber">Mobile number</label>
              <input type="tel" class="form-control" id="phoneNumber" name="phoneNumber"
                     value="<%= profileUser.phone_number || '' %>"
                     placeholder="Optional — used for login by SMS"
                     autocomplete="tel" />
            </div>

            <div class="mb-4">
              <label class="form-label">Gender</label>
              <div class="d-flex gap-4">
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="gender" id="genderMale" value="male"
                         <%= (!profileUser.gender || profileUser.gender === 'male') ? 'checked' : '' %> />
                  <label class="form-check-label" for="genderMale">Male</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="gender" id="genderFemale" value="female"
                         <%= profileUser.gender === 'female' ? 'checked' : '' %> />
                  <label class="form-check-label" for="genderFemale">Female</label>
                </div>
              </div>
              <div class="form-text">Used to assign the correct tees on mixed-gender tours.</div>
            </div>

            <button type="submit" class="btn btn-primary w-100">Save changes</button>

          </form>
        </div>
      </div>

    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
    <script>
      document.getElementById('changeEmailToggle')?.addEventListener('click', function (e) {
        e.preventDefault();
        document.getElementById('changeEmailHint').classList.add('d-none');
        document.getElementById('changeEmailForm').classList.remove('d-none');
        document.getElementById('changeEmailForm').querySelector('input')?.focus();
      });
    </script>
  </body>
</html>
