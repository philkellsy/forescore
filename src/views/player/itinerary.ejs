<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> | ForeScore</title>
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="theme-color" content="#215463" />
  <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
  <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
</head>
<body>
  <%- include('../partials/nav') %>
  <main class="container py-3 py-md-4" style="max-width:680px">
    <%
      const TYPE_META = {
        accommodation: { label: 'Accommodation', icon: 'fa-bed' },
        transfer:      { label: 'Transfer',       icon: 'fa-van-shuttle' },
        meal:          { label: 'Meal',            icon: 'fa-utensils' },
        activity:      { label: 'Activity',        icon: 'fa-person-hiking' },
        note:          { label: 'Note',            icon: 'fa-circle-info' },
        flight:        { label: 'Flight',          icon: 'fa-plane-departure' },
      };
      const CALC_LABELS = {
        stableford:   'Stableford',
        ambrose_nett: 'Ambrose',
        stroke:       'Stroke Play',
      };
      function fmtDate(d) {
        if (!d) return '';
        return new Date(d).toLocaleDateString('en-AU', { weekday: 'short', day: 'numeric', month: 'short', timeZone: 'UTC' });
      }
      function fmtTime(t) {
        if (!t) return '';
        return String(t).slice(0, 5);
      }
      const allDateKeys = Object.keys(byDate).sort();
    %>

    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h1 class="h5 mb-0">Itinerary</h1>
        <p class="text-muted small mb-0"><%= tour.label %></p>
      </div>
      <button class="btn btn-sm btn-outline-secondary"
              data-bs-toggle="modal" data-bs-target="#personalItemModal"
              onclick="resetPersonalModal()">
        <i class="fa-solid fa-circle-plus me-1"></i>Add personal item
      </button>
    </div>

    <% if (!allDateKeys.length) { %>
      <div class="text-center py-5 text-muted">
        <i class="fa-solid fa-calendar-days fa-3x mb-3 opacity-25"></i>
        <p class="mb-0">No itinerary published yet.</p>
      </div>
    <% } else { %>
      <% allDateKeys.forEach((dateKey) => { %>
        <section class="mb-4">
          <h2 class="h6 text-muted text-uppercase small fw-semibold mb-2 ps-1"><%= fmtDate(dateKey) %></h2>
          <div class="card border-0 shadow-sm">
            <% byDate[dateKey].forEach((entry, i) => { %>
              <%- include('../partials/itinerary-entry', { entry, i, TYPE_META, CALC_LABELS, fmtTime, canEditPersonal: true }) %>
            <% }) %>
          </div>
        </section>
      <% }) %>
    <% } %>
  </main>

  <%# Personal item modal %>
  <div class="modal fade" id="personalItemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h2 class="modal-title fs-5" id="personalItemModalTitle">Add personal item</h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <form id="personalItemForm" method="post" action="<%= tenantPath('/itinerary/personal') %>">
          <input type="hidden" name="redirectBack" value="itinerary">
          <div class="modal-body">

            <div class="mb-3">
              <label class="form-label">Type</label>
              <div class="d-flex gap-3">
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="type" id="ptNote" value="note" checked>
                  <label class="form-check-label" for="ptNote"><i class="fa-solid fa-circle-info me-1"></i>Note</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="type" id="ptFlight" value="flight">
                  <label class="form-check-label" for="ptFlight"><i class="fa-solid fa-plane-departure me-1"></i>Flight</label>
                </div>
              </div>
            </div>

            <div class="mb-3">
              <label class="form-label">Title</label>
              <input type="text" name="title" id="pTitle" class="form-control" required />
            </div>

            <div class="row g-3 mb-3">
              <div class="col">
                <label class="form-label" id="pDateLabel">Date</label>
                <input type="date" name="itemDate" id="pItemDate" class="form-control" required />
              </div>
              <div class="col" id="pEndDateCol" style="display:none">
                <label class="form-label">Arrival Date</label>
                <input type="date" name="endDate" id="pEndDate" class="form-control" />
              </div>
            </div>

            <%# Flight-specific fields %>
            <div id="pFlightFields" style="display:none">
              <div class="row g-2 mb-3">
                <div class="col-6">
                  <label class="form-label">Departure Airport</label>
                  <input type="text" name="detail_departure_airport" id="pDepAirport" class="form-control"
                         placeholder="e.g. SYD" style="text-transform:uppercase" />
                </div>
                <div class="col-6">
                  <label class="form-label">Arrival Airport</label>
                  <input type="text" name="detail_arrival_airport" id="pArrAirport" class="form-control"
                         placeholder="e.g. BNE" style="text-transform:uppercase" />
                </div>
              </div>
              <div class="row g-2 mb-3">
                <div class="col-6">
                  <label class="form-label">Airline</label>
                  <input type="text" name="detail_airline" id="pAirline" class="form-control" placeholder="e.g. Qantas" />
                </div>
                <div class="col-6">
                  <label class="form-label">Flight No.</label>
                  <input type="text" name="detail_flight_number" id="pFlightNum" class="form-control" placeholder="e.g. QF123" />
                </div>
              </div>
              <div class="row g-2 mb-3">
                <div class="col-6">
                  <label class="form-label">Departure Time</label>
                  <input type="time" name="startTime" id="pStartTime" class="form-control" />
                </div>
                <div class="col-6">
                  <label class="form-label">Arrival Time</label>
                  <input type="time" name="endTime" id="pEndTime" class="form-control" />
                </div>
              </div>
              <div class="row g-2 mb-3">
                <div class="col-6">
                  <label class="form-label">Terminal</label>
                  <input type="text" name="detail_terminal" id="pTerminal" class="form-control" placeholder="e.g. T1" />
                </div>
                <div class="col-6">
                  <label class="form-label">Booking Ref</label>
                  <input type="text" name="detail_booking_ref" id="pBookingRef" class="form-control" placeholder="e.g. ABC123" />
                </div>
              </div>
            </div>

            <%# Note-specific fields %>
            <div id="pNoteFields">
              <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea name="description" id="pDescription" class="form-control" rows="3"></textarea>
              </div>
            </div>

          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary" id="pSubmitBtn">Add</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <%# Delete confirmation modal %>
  <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
      <div class="modal-content">
        <div class="modal-header border-0 pb-1">
          <h2 class="modal-title fs-6">Delete item?</h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body pt-0 pb-2">
          <p class="mb-0 small text-muted"><strong id="deleteItemTitle"></strong> will be permanently removed.</p>
        </div>
        <div class="modal-footer border-0 pt-0">
          <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
          <form id="deleteForm" method="post" class="m-0">
            <input type="hidden" name="redirectBack" value="itinerary">
            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
  <script>
    const PERSONAL_BASE = '<%= tenantPath('/itinerary/personal') %>';

    function applyPersonalType(type) {
      const isFlight = type === 'flight';
      document.getElementById('pFlightFields').style.display = isFlight ? '' : 'none';
      document.getElementById('pNoteFields').style.display   = isFlight ? 'none' : '';
      document.getElementById('pEndDateCol').style.display   = isFlight ? '' : 'none';
      document.getElementById('pDateLabel').textContent      = isFlight ? 'Departure Date' : 'Date';
    }

    document.querySelectorAll('input[name="type"]').forEach((r) => {
      r.addEventListener('change', () => applyPersonalType(r.value));
    });

    function resetPersonalModal() {
      document.getElementById('personalItemModalTitle').textContent = 'Add personal item';
      document.getElementById('pSubmitBtn').textContent = 'Add';
      document.getElementById('personalItemForm').action = PERSONAL_BASE;
      document.getElementById('personalItemForm').reset();
      document.getElementById('ptNote').checked = true;
      applyPersonalType('note');
    }

    document.querySelectorAll('.personal-edit-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const item = JSON.parse(btn.dataset.item.replace(/&quot;/g, '"'));
        const d = item.details || {};
        document.getElementById('personalItemModalTitle').textContent = 'Edit';
        document.getElementById('pSubmitBtn').textContent = 'Save';
        document.getElementById('personalItemForm').action = PERSONAL_BASE + '/' + item.id;
        document.getElementById('pTitle').value       = item.title || '';
        document.getElementById('pItemDate').value    = item.item_date ? String(item.item_date).slice(0, 10) : '';
        document.getElementById('pEndDate').value     = item.end_date  ? String(item.end_date).slice(0, 10)  : '';
        document.getElementById('pDescription').value = item.description || '';
        document.getElementById('pDepAirport').value  = d.departure_airport || '';
        document.getElementById('pArrAirport').value  = d.arrival_airport   || '';
        document.getElementById('pAirline').value     = d.airline            || '';
        document.getElementById('pFlightNum').value   = d.flight_number      || '';
        document.getElementById('pStartTime').value   = item.start_time ? String(item.start_time).slice(0, 5) : '';
        document.getElementById('pEndTime').value     = item.end_time   ? String(item.end_time).slice(0, 5)   : '';
        document.getElementById('pTerminal').value    = d.terminal     || '';
        document.getElementById('pBookingRef').value  = d.booking_ref  || '';
        const typeRadio = document.querySelector(`input[name="type"][value="${item.type}"]`);
        if (typeRadio) { typeRadio.checked = true; applyPersonalType(item.type); }
      });
    });

    document.getElementById('deleteModal').addEventListener('show.bs.modal', function (e) {
      const btn = e.relatedTarget;
      document.getElementById('deleteItemTitle').textContent = btn.dataset.itemTitle || 'This item';
      document.getElementById('deleteForm').action = btn.dataset.deleteUrl;
    });

    applyPersonalType('note');
  </script>
</body>
</html>
