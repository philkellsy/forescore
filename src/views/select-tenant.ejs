<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> | ForeScore</title>
  <meta name="theme-color" content="#215463" />
  <link rel="icon" type="image/svg+xml" href="/img/forescore-shield.svg" />
  <link rel="apple-touch-icon" href="/img/icons/apple-touch-icon.png?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/app.css?v=<%= assetVersion %>" />
</head>
<body class="auth-body">
  <main class="container py-5">
    <div class="row justify-content-center">
      <div class="col-12 col-md-7 col-lg-5">
        <div class="card shadow-sm border-0">
          <div class="card-body p-4">
            <div class="text-center mb-2">
              <img src="/img/forescore-shield.svg" alt="ForeScore" style="height:72px;width:auto;" />
            </div>
            <h1 class="h5 mb-1 text-center"><span style="color:#8AD84A">Fore</span><span style="color:#215463">Score</span></h1>
            <p class="text-center text-muted small mb-4">Select your tour</p>
            <div class="d-grid gap-2">
              <% memberships.forEach(function(m) { %>
                <a href="/<%= m.slug %>/" class="btn btn-legends"><%= m.name %></a>
              <% }); %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>
</body>
</html>
