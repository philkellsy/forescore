{
  "name": "forescore",
  "version": "1.4.45",
  "description": "Golf trip scoring and admin PWA",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "knex migrate:latest --knexfile knexfile.js",
    "migrate:make": "knex migrate:make --knexfile knexfile.js",
    "lint": "node scripts/lint.js",
    "test": "npm run lint && npm run test:unit && npm run test:integration",
    "test:unit": "node --test test/unit/**/*.test.js",
    "test:integration": "node --test test/integration/**/*.test.js",
    "test:watch": "node --test --watch test/unit/**/*.test.js test/integration/**/*.test.js",
    "audit": "npm audit --audit-level=moderate",
    "audit:offline": "npm audit --offline",
    "audit:fix": "npm audit fix",
    "deps:update": "npm update",
    "deploy": "bash scripts/deploy.sh",
    "deploy:minor": "bash scripts/deploy.sh minor",
    "deploy:major": "bash scripts/deploy.sh major"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "knex": "^3.2.9",
    "multer": "^2.0.2",
    "pg": "^8.20.0"
  },
  "overrides": {
    "tar": "^7.5.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
